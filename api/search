:5,"1363":5,"1364":5,"1365":5,"1366":5,"1367":5,"1368":5,"1369":5,"1370":5,"1371":4,"1372":4,"1373":4,"1374":4,"1375":4,"1376":4,"1377":4,"1378":4,"1379":4,"1380":4,"1381":4,"1382":4,"1383":4,"1384":4,"1385":4,"1386":4,"1387":4,"1388":4,"1389":4,"1390":4}}},"docs":{"docs":{"1":{"id":"/docs/architecture","page_id":"/docs/architecture","type":"page","content":"Architecture","breadcrumbs":["Docs"],"tags":[],"url":"/docs/architecture"},"2":{"id":"/docs/architecture-0","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture","content":"How Bitcoin Core, Electrs, LND, RTL, Tor, Tailscale, and Caddy fit together on one Raspberry Pi."},"3":{"id":"/docs/architecture-1","page_id":"/docs/architecture","type":"heading","tags":[],"url":"/docs/architecture#services-and-traffic","content":"Services and traffic"},"4":{"id":"/docs/architecture-2","page_id":"/docs/architecture","type":"heading","tags":[],"url":"/docs/architecture#what-each-component-does","content":"What each component does"},"5":{"id":"/docs/architecture-3","page_id":"/docs/architecture","type":"heading","tags":[],"url":"/docs/architecture#data-and-storage","content":"Data and storage"},"6":{"id":"/docs/architecture-4","page_id":"/docs/architecture","type":"heading","tags":[],"url":"/docs/architecture#reaching-the-pi-and-what-the-outside-world-sees","content":"Reaching the Pi, and what the outside world sees"},"7":{"id":"/docs/architecture-5","page_id":"/docs/architecture","type":"heading","tags":[],"url":"/docs/architecture#where-to-go-next","content":"Where to go next"},"8":{"id":"/docs/architecture-6","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture","content":"You're about to install roughly a dozen services on a single box. It\nhelps to see the map before you start laying the track. This page is\nthat map: what talks to what, which ports matter, where your node\nfaces the public internet and where it faces you."},"9":{"id":"/docs/architecture-7","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture","content":"No commands here. The install steps live in the sections that\nfollow. This is strictly orientation."},"10":{"id":"/docs/architecture-8","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#services-and-traffic","content":"**Reading the arrows.** A one-way arrow is the direction a request\nflows: the caller talks, the callee answers. The protocol label is\nthe channel. **RPC** is JSON-over-HTTP to Bitcoin Core. **gRPC** is\nLND's binary protocol. **ZMQ** is Bitcoin Core pushing new-block and\nnew-transaction events to LND without polling. **SOCKS** is Tor's\nway of letting an application route its outbound traffic through the\nonion network. **TLS** is Electrum over stunnel, HTTPS is everything\ngoing through Caddy, and SSH is how you reach the Pi (directly on\nthe LAN, or through Tailscale from anywhere else)."},"11":{"id":"/docs/architecture-9","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#services-and-traffic","content":"**Main takeaway:** Bitcoin Core is the only service that actually\nvalidates the chain. Everything else is a consumer of that one\nanswer."},"12":{"id":"/docs/architecture-10","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Service"},"13":{"id":"/docs/architecture-11","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"One-liner"},"14":{"id":"/docs/architecture-12","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Bitcoin Core"},"15":{"id":"/docs/architecture-13","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"The full node. Verifies every block, maintains the UTXO set, speaks the peer-to-peer protocol."},"16":{"id":"/docs/architecture-14","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Electrs"},"17":{"id":"/docs/architecture-15","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Indexes Bitcoin Core's data so wallets can ask \"what's the balance of this address?\" in milliseconds."},"18":{"id":"/docs/architecture-16","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"LND"},"19":{"id":"/docs/architecture-17","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Your Lightning node. Opens channels, routes payments, holds the hot wallet."},"20":{"id":"/docs/architecture-18","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"BTC RPC Explorer"},"21":{"id":"/docs/architecture-19","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"A private web explorer for your own blockchain. Mempool, fees, block details, all without leaking queries to a third party."},"22":{"id":"/docs/architecture-20","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"RTL"},"23":{"id":"/docs/architecture-21","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Web dashboard for LND. Channels, payments, routing stats."},"24":{"id":"/docs/architecture-22","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Tor"},"25":{"id":"/docs/architecture-23","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Routes the P2P traffic of Bitcoin Core and LND through the onion network, keeping your home IP off the public peer maps."},"26":{"id":"/docs/architecture-24","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Tailscale"},"27":{"id":"/docs/architecture-25","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"A private WireGuard mesh between your devices. The Pi gets a stable `100.x.y.z` address that only your devices can reach."},"28":{"id":"/docs/architecture-26","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Caddy"},"29":{"id":"/docs/architecture-27","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Reverse proxy. Puts web apps (RTL, BTC RPC Explorer) behind HTTPS with a single three-line config block per site."},"30":{"id":"/docs/architecture-28","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"stunnel"},"31":{"id":"/docs/architecture-29","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#what-each-component-does","content":"Wraps plain TCP in TLS. Electrum wallets want an encrypted connection to Electrs, so stunnel handles the handshake."},"32":{"id":"/docs/architecture-30","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"Everything critical lives on the SSD, mounted at `/data`. Here are\nthe key paths and their approximate footprints:"},"33":{"id":"/docs/architecture-31","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"Path"},"34":{"id":"/docs/architecture-32","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"What lives there"},"35":{"id":"/docs/architecture-33","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"Size"},"36":{"id":"/docs/architecture-34","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"`/data/bitcoin`"},"37":{"id":"/docs/architecture-35","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"Full blockchain and UTXO set"},"38":{"id":"/docs/architecture-36","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"\\~700 GB, +7 GB/month"},"39":{"id":"/docs/architecture-37","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"`/data/electrs`"},"40":{"id":"/docs/architecture-38","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"Address and transaction index"},"41":{"id":"/docs/architecture-39","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"\\~70 GB"},"42":{"id":"/docs/architecture-40","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"`/data/lnd`"},"43":{"id":"/docs/architecture-41","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"Wallet, channels, macaroons, config"},"44":{"id":"/docs/architecture-42","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"small, but irreplaceable"},"45":{"id":"/docs/architecture-43","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"`/data/lnd/data/chain/bitcoin/mainnet/channel.backup`"},"46":{"id":"/docs/architecture-44","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"Static channel backup"},"47":{"id":"/docs/architecture-45","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"tiny: back it up off-Pi"},"48":{"id":"/docs/architecture-46","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"The SD card or eMMC holds the OS and application configs only. No\nBitcoin data lives there."},"49":{"id":"/docs/architecture-47","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#data-and-storage","content":"**Main takeaway:** if the SD card fails, your funds are safe on the\nSSD. If the SSD fails and you have the seed phrase and the latest\n`channel.backup`, you can recover funds from every channel. The\nChannel backup page sets that up."},"50":{"id":"/docs/architecture-48","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#reaching-the-pi-and-what-the-outside-world-sees","content":"Three routes into your Pi, in increasing order of privacy:"},"51":{"id":"/docs/architecture-49","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#reaching-the-pi-and-what-the-outside-world-sees","content":"**LAN** over your home network. Fastest, works only when you're\non the same Wi-Fi. Same hardened SSH config as everywhere else."},"52":{"id":"/docs/architecture-50","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#reaching-the-pi-and-what-the-outside-world-sees","content":"**Tailscale mesh** from any of your own devices, anywhere in the\nworld. No ports open on your router, no dynamic DNS, WireGuard\nend-to-end."},"53":{"id":"/docs/architecture-51","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#reaching-the-pi-and-what-the-outside-world-sees","content":"**Tor hidden service** for mobile Lightning (Zeus). Your phone\nreaches LND's REST interface over an `.onion` address nobody else\nknows."},"54":{"id":"/docs/architecture-52","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#reaching-the-pi-and-what-the-outside-world-sees","content":"**Main takeaway:** Bitcoin Core and LND use Tor to hide **your**\nidentity from the peer network. Tailscale lets **you** reach the Pi\nfrom anywhere without exposing it to the peer network. Different\nprivacy problems, different tools."},"55":{"id":"/docs/architecture-53","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#where-to-go-next","content":"Start at the top and walk down:"},"56":{"id":"/docs/architecture-54","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#where-to-go-next","content":"Hardware — Pi, SSD, OS, SSH, firewall, Tor, Tailscale."},"57":{"id":"/docs/architecture-55","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#where-to-go-next","content":"Bitcoin — Bitcoin Core, Electrs, BTC RPC Explorer, Sparrow."},"58":{"id":"/docs/architecture-56","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#where-to-go-next","content":"Lightning — LND, RTL, Zeus, channel backup."},"59":{"id":"/docs/architecture-57","page_id":"/docs/architecture","tags":[],"type":"text","url":"/docs/architecture#where-to-go-next","content":"If anything on the map surprised you, the matching install page has\nthe why and the how."},"60":{"id":"/docs/backstory","page_id":"/docs/backstory","type":"page","content":"Backstory","breadcrumbs":["Docs"],"tags":[],"url":"/docs/backstory"},"61":{"id":"/docs/backstory-0","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory","content":"Why this guide exists, who built it, and what \"self-sovereign\" really means."},"62":{"id":"/docs/backstory-1","page_id":"/docs/backstory","type":"heading","tags":[],"url":"/docs/backstory#why-bitcoin-why-a-node","content":"Why Bitcoin? Why a node?"},"63":{"id":"/docs/backstory-2","page_id":"/docs/backstory","type":"heading","tags":[],"url":"/docs/backstory#why-lightning","content":"Why Lightning?"},"64":{"id":"/docs/backstory-3","page_id":"/docs/backstory","type":"heading","tags":[],"url":"/docs/backstory#why-raspibolt","content":"Why RaspiBolt?"},"65":{"id":"/docs/backstory-4","page_id":"/docs/backstory","type":"heading","tags":[],"url":"/docs/backstory#the-good-old-days","content":"The good old days"},"66":{"id":"/docs/backstory-5","page_id":"/docs/backstory","type":"heading","tags":[],"url":"/docs/backstory#a-community-project","content":"A community project"},"67":{"id":"/docs/backstory-6","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory","content":"Hey, I'm Stadicus. I wrote the first version of\nthis guide back in 2017, when Lightning was still pretty obscure, the\nmainnet wasn't even live yet, and running a node meant stringing\ntogether a hundred half-documented commands you hoped someone on\nReddit had gotten right. I love to tinker and build things, so I\nwrote down what worked, put it on Medium, and moved it to GitHub\nwhen it outgrew a single blog post."},"68":{"id":"/docs/backstory-7","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory","content":"It hasn't been \"my own\" guide for a long time. Dozens of contributors\nhave shaped it over the years. RaspiBolt is a community project now,\nand the community keeps it honest."},"69":{"id":"/docs/backstory-8","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#why-bitcoin-why-a-node","content":"Bitcoin is doing something quietly revolutionary: it lets you hold\nmoney that nobody else can freeze, inflate, or quietly reassign.\nThat only works if **the network stays decentralised**, if enough\nof us run our own full nodes to enforce the rules rather than\ntrusting somebody else to tell us what the rules are."},"70":{"id":"/docs/backstory-9","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#why-bitcoin-why-a-node","content":"A full node is, in plain terms, your own personal goldsmith. When a\npayment arrives, your node verifies it from first principles: the\nsignatures, the scripts, the history, the supply cap. No trust, no\nmiddleman, no API key away from being cut off. If Bitcoin is digital\ngold, a full node is the set of scales you own and trust."},"71":{"id":"/docs/backstory-10","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#why-bitcoin-why-a-node","content":"That kind of independence shouldn't be reserved for people with a\nrack in a datacentre. A Raspberry Pi in the corner of your office,\nquietly validating every block that's ever been mined, is a\ndelightfully democratic piece of infrastructure."},"72":{"id":"/docs/backstory-11","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#why-lightning","content":"Bitcoin's base layer is deliberately slow and deliberately expensive.\nThat's a feature, not a bug, a genuinely decentralised blockchain\nis a scarce resource, and it cannot scale to every coffee purchase\non the planet without breaking exactly the property that makes it\nvaluable."},"73":{"id":"/docs/backstory-12","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#why-lightning","content":"This is why the **Lightning Network** exists. It's a second layer\nbuilt on top of Bitcoin that settles small payments instantly,\nroutes them between strangers via a mesh of payment channels, and\nfalls back to the base chain only when it has to. It sounds almost\ntoo good to be true. The technology is solid, well-researched, and\nstays faithful to the open-source, cypherpunk roots of Bitcoin\nitself."},"74":{"id":"/docs/backstory-13","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#why-lightning","content":"Running your own Lightning node means you're not just a spectator,\nyou're part of the network that makes instant, low-fee Bitcoin\npayments possible."},"75":{"id":"/docs/backstory-14","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#why-raspibolt","content":"Through many iterations, I've arrived at a setup I think is worth\nsharing. It's opinionated, I picked the tools that are reliable,\nwell-maintained, and possible to reason about. I'm not a systems\nspecialist, so if you spot improvements, please say so. The GitHub\nissues list is where the guide gets better."},"76":{"id":"/docs/backstory-15","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#the-good-old-days","content":"The original goal of the RaspiBolt guide, back in 2017, was simply\nbuying a Blockaccino. I used the\nEclair Lightning implementation\non testnet, because mainnet wasn't running yet. Oh, how time flies."},"77":{"id":"/docs/backstory-16","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#a-community-project","content":"Thanks to every contributor who has filed an issue, opened a pull\nrequest, tested a fix on their own Pi, or helped a newcomer in the\nTelegram group. Thanks to everyone who\ncares about Bitcoin enough to run their own node, and to understand\nwhat it's actually doing."},"78":{"id":"/docs/backstory-17","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#a-community-project","content":"The top 20 contributors on GitHub, by commit count:"},"79":{"id":"/docs/backstory-18","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#a-community-project","content":"Full list on github.com/raspibolt/raspibolt/graphs/contributors."},"80":{"id":"/docs/backstory-19","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#a-community-project","content":"This guide is for you."},"81":{"id":"/docs/backstory-20","page_id":"/docs/backstory","tags":[],"type":"text","url":"/docs/backstory#a-community-project","content":"Curious how the pieces fit together before you start? See\nArchitecture for the 10,000-foot view."},"82":{"id":"/docs/faq","page_id":"/docs/faq","type":"page","content":"FAQ","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/faq"},"83":{"id":"/docs/faq-0","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq","content":"Upgrading from v3, reading an ext4 SSD on Windows, restoring LND data, common Linux commands, setting a fixed IP. Answers to the questions that come up again and again in the Telegram group."},"84":{"id":"/docs/faq-1","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#how-long-does-the-initial-blockchain-sync-take","content":"How long does the initial blockchain sync take?"},"85":{"id":"/docs/faq-2","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#can-i-get-rich-by-routing-lightning-payments","content":"Can I get rich by routing Lightning payments?"},"86":{"id":"/docs/faq-3","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#can-i-read-the-ext4-ssd-on-a-windows-computer","content":"Can I read the Ext4 SSD on a Windows computer?"},"87":{"id":"/docs/faq-4","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#how-much-disk-space-do-i-need","content":"How much disk space do I need?"},"88":{"id":"/docs/faq-5","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#can-i-migrate-an-older-raspibolt-to-v4","content":"Can I migrate an older RaspiBolt to v4?"},"89":{"id":"/docs/faq-6","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#back-up-lnd-before-you-start","content":"Back up LND before you start"},"90":{"id":"/docs/faq-7","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#restore-onto-the-new-node","content":"Restore onto the new node"},"91":{"id":"/docs/faq-8","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#what-about-the-bitcoin-blockchain","content":"What about the Bitcoin blockchain?"},"92":{"id":"/docs/faq-9","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#can-i-run-this-on-something-other-than-a-raspberry-pi-5","content":"Can I run this on something other than a Raspberry Pi 5?"},"93":{"id":"/docs/faq-10","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#my-node-was-offline-for-a-few-days-what-now","content":"My node was offline for a few days. What now?"},"94":{"id":"/docs/faq-11","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#how-do-i-update-bitcoin-core-or-lnd","content":"How do I update Bitcoin Core or LND?"},"95":{"id":"/docs/faq-12","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#what-do-all-the-linux-commands-do","content":"What do all the Linux commands do?"},"96":{"id":"/docs/faq-13","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#where-can-i-learn-more-about-bitcoin-and-lightning","content":"Where can I learn more about Bitcoin and Lightning?"},"97":{"id":"/docs/faq-14","page_id":"/docs/faq","type":"heading","tags":[],"url":"/docs/faq#how-do-i-give-the-pi-a-fixed-ip-address","content":"How do I give the Pi a fixed IP address?"},"98":{"id":"/docs/faq-15","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq","content":"Short answers to the questions that come up most often. If yours\nisn't here, the Telegram group and the\nGitHub issues are\nthe two places to ask."},"99":{"id":"/docs/faq-16","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#how-long-does-the-initial-blockchain-sync-take","content":"Expect 3-5 days on a Pi 5 with a fast SSD. The bottleneck is not\ndownload speed. Bitcoin Core verifies every digital signature in\nevery transaction ever recorded, and that takes time. A slower\nmachine or a spinning hard drive can push past a week."},"100":{"id":"/docs/faq-17","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#how-long-does-the-initial-blockchain-sync-take","content":"Once you're synced, catching up after a restart takes minutes, not\ndays. Initial sync is a one-time cost."},"101":{"id":"/docs/faq-18","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-get-rich-by-routing-lightning-payments","content":"Nobody really knows. Probably not. Routing fees on a well-placed\nnode cover electricity and a bit of the hardware, not much more.\nRun a Lightning node because you want payments to work, not\nbecause you want a yield-bearing business. Enjoy the ride."},"102":{"id":"/docs/faq-19","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-read-the-ext4-ssd-on-a-windows-computer","content":"Ext4 isn't compatible with Windows out of the box. Tools like\nLinux File Systems for Windows\n(Paragon, 10-day free trial) let you mount the drive read/write. On\nmacOS, extFS for Mac\ndoes the same."},"103":{"id":"/docs/faq-20","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-read-the-ext4-ssd-on-a-windows-computer","content":"If you just need to copy files off the drive once, plugging it into\nanother Linux box, or the Pi itself, is usually the path of least\nresistance."},"104":{"id":"/docs/faq-21","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#how-much-disk-space-do-i-need","content":"A 2 TB SSD. The blockchain is around 700 GB as of 2026, growing\nroughly 7 GB per month. The Electrs index adds another \\~70 GB, and\nthe OS takes \\~20 GB. A 1 TB drive is basically full on day one. See\nHardware for what to buy and\nwhich SSD enclosure chipsets to avoid."},"105":{"id":"/docs/faq-22","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-migrate-an-older-raspibolt-to-v4","content":"Not cleanly. v4 is built on Debian 13 \"Trixie\" with a different\npackage set, a different reverse proxy, and a different layout for\nsecrets and data directories. The safest upgrade is a **fresh\ninstall**, then restore the parts that are hard to recreate."},"106":{"id":"/docs/faq-23","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-migrate-an-older-raspibolt-to-v4","content":"The things worth keeping from an older node:"},"107":{"id":"/docs/faq-24","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-migrate-an-older-raspibolt-to-v4","content":"**LND data** (`/data/lnd` or `/mnt/ext/lnd`, depending on version)"},"108":{"id":"/docs/faq-25","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-migrate-an-older-raspibolt-to-v4","content":"**Static channel backup** (`channel.backup`)"},"109":{"id":"/docs/faq-26","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-migrate-an-older-raspibolt-to-v4","content":"**Seed phrase and passwords** (you wrote those down, right?)"},"110":{"id":"/docs/faq-27","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#back-up-lnd-before-you-start","content":"Once you've copied the LND data directory off the old node, move it\naside so the old node can't start again by accident. A second LND\nnode broadcasting stale channel state means force-closed channels\nand, in the worst case, lost funds."},"111":{"id":"/docs/faq-28","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#back-up-lnd-before-you-start","content":"On the old node:"},"112":{"id":"/docs/faq-29","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#back-up-lnd-before-you-start","content":"Grab the static channel backup file too, it's cheap insurance\nagainst anything going wrong with the full directory restore."},"113":{"id":"/docs/faq-30","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#restore-onto-the-new-node","content":"Finish the v4 setup through the Lightning section, but **don't\ncreate a wallet** when LND first starts. Stop LND, mount the\nthumb drive, and copy the backup into place:"},"114":{"id":"/docs/faq-31","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#restore-onto-the-new-node","content":"LND should come up with your existing wallet, peers, and channels."},"115":{"id":"/docs/faq-32","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-about-the-bitcoin-blockchain","content":"Bitcoin Core doesn't need a backup, it can download and verify the\nentire chain from scratch. That takes a few days on a Pi, so if you\nwant to skip the resync, `rsync` the old `bitcoin` data directory\nacross from the old drive before you point the new node at it."},"116":{"id":"/docs/faq-33","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#can-i-run-this-on-something-other-than-a-raspberry-pi-5","content":"The guide targets the Pi 5. The Pi 4 with 8 GB RAM works but\ninitial sync and Electrs indexing are noticeably slower. Any 64-bit\nARM or x86 board running Debian 13 \"Trixie\" should be compatible,\nbut is untested. The hard requirements are 8 GB RAM and a fast SSD."},"117":{"id":"/docs/faq-34","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#my-node-was-offline-for-a-few-days-what-now","content":"Nothing special. Bitcoin Core picks up from where it stopped and\ncatches up with the chain. LND reconnects to channel peers\nautomatically. Give it 30-60 minutes after startup before worrying\nabout anything. Lightning channels stay safe while your node is\noffline. They just can't route or send payments while it's down."},"118":{"id":"/docs/faq-35","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#how-do-i-update-bitcoin-core-or-lnd","content":"Follow the same install steps, starting from the download section.\nStop the service, download and verify the new binary, replace it,\nand restart. Config files don't change between minor versions unless\nthe release notes say so. Read the LND release notes before\nupgrading; it occasionally requires a database migration."},"119":{"id":"/docs/faq-36","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"A short reference for commands that show up repeatedly in this\nguide. For any specific one, `man <command>` has the full manual,\ntype `q` to exit."},"120":{"id":"/docs/faq-37","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"Command"},"121":{"id":"/docs/faq-38","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"What it does"},"122":{"id":"/docs/faq-39","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"Example"},"123":{"id":"/docs/faq-40","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`cd`"},"124":{"id":"/docs/faq-41","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"change directory"},"125":{"id":"/docs/faq-42","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`cd /home/bitcoin`"},"126":{"id":"/docs/faq-43","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`ls`"},"127":{"id":"/docs/faq-44","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"list directory contents"},"128":{"id":"/docs/faq-45","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`ls -la /data`"},"129":{"id":"/docs/faq-46","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`cp`"},"130":{"id":"/docs/faq-47","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"copy"},"131":{"id":"/docs/faq-48","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`cp file.txt newfile.txt`"},"132":{"id":"/docs/faq-49","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`mv`"},"133":{"id":"/docs/faq-50","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"move or rename"},"134":{"id":"/docs/faq-51","page_id":"/doc