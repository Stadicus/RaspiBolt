t","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"archive tool"},"161":{"id":"/docs/faq-78","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`tar -cvf a.tar file1.txt file2.txt`"},"162":{"id":"/docs/faq-79","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`exit`"},"163":{"id":"/docs/faq-80","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"leave current shell"},"164":{"id":"/docs/faq-81","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`exit`"},"165":{"id":"/docs/faq-82","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`systemctl`"},"166":{"id":"/docs/faq-83","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"control a systemd service"},"167":{"id":"/docs/faq-84","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`sudo systemctl start bitcoind`"},"168":{"id":"/docs/faq-85","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`journalctl`"},"169":{"id":"/docs/faq-86","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"read systemd logs"},"170":{"id":"/docs/faq-87","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`sudo journalctl -u bitcoind`"},"171":{"id":"/docs/faq-88","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`htop`"},"172":{"id":"/docs/faq-89","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"live process and resource view"},"173":{"id":"/docs/faq-90","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`htop`"},"174":{"id":"/docs/faq-91","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`shutdown`"},"175":{"id":"/docs/faq-92","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"power off or reboot"},"176":{"id":"/docs/faq-93","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#what-do-all-the-linux-commands-do","content":"`sudo shutdown -r now`"},"177":{"id":"/docs/faq-94","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#where-can-i-learn-more-about-bitcoin-and-lightning","content":"A few hand-picked starting points that actually teach rather than\npitch:"},"178":{"id":"/docs/faq-95","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#where-can-i-learn-more-about-bitcoin-and-lightning","content":"What is Bitcoin?: Bitcoin Magazine's introduction."},"179":{"id":"/docs/faq-96","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#where-can-i-learn-more-about-bitcoin-and-lightning","content":"Understanding the Lightning Network:\nthe original walkthrough of payment channels."},"180":{"id":"/docs/faq-97","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#where-can-i-learn-more-about-bitcoin-and-lightning","content":"Bitcoin resources\nand Lightning resources\nby Jameson Lopp."},"181":{"id":"/docs/faq-98","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#how-do-i-give-the-pi-a-fixed-ip-address","content":"The cleanest answer is to set it in your router, assign a DHCP\nreservation for the Pi's MAC address so it always lands on the same\nIP. Every consumer router can do this; the menu is usually called\n\"DHCP reservations\" or \"static leases\"."},"182":{"id":"/docs/faq-99","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#how-do-i-give-the-pi-a-fixed-ip-address","content":"If your router can't, configure the address directly on the Pi via\nNetworkManager (the default on Debian 13 \"Trixie\"):"},"183":{"id":"/docs/faq-100","page_id":"/docs/faq","tags":[],"type":"text","url":"/docs/faq#how-do-i-give-the-pi-a-fixed-ip-address","content":"Replace the addresses with values that fit your network, and pick\none **outside** the DHCP range your router hands out, otherwise\nyou'll collide with some other device the next time it boots."},"184":{"id":"/docs/troubleshooting","page_id":"/docs/troubleshooting","type":"page","content":"Troubleshooting","breadcrumbs":["Docs","Reference"],"tags":[],"url":"/docs/troubleshooting"},"185":{"id":"/docs/troubleshooting-0","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting","content":"SSH locked out, hdparm too slow, UAS quirks, fail2ban unban, ufw rules, bitcoind won't start, stuck IBD, LND chain sync. Fix the frikkin' little thing."},"186":{"id":"/docs/troubleshooting-1","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#jump-to-the-thing-thats-on-fire","content":"Jump to the thing that's on fire"},"187":{"id":"/docs/troubleshooting-2","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#before-you-start-digging","content":"Before you start digging"},"188":{"id":"/docs/troubleshooting-3","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#hardware-and-operating-system","content":"Hardware and operating system"},"189":{"id":"/docs/troubleshooting-4","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#ssh-lockout-login-via-console","content":"SSH lockout: login via console"},"190":{"id":"/docs/troubleshooting-5","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"USB SSD is too slow"},"191":{"id":"/docs/troubleshooting-6","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#are-the-right-ports-open-on-the-firewall","content":"Are the right ports open on the firewall?"},"192":{"id":"/docs/troubleshooting-7","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#users-and-directories","content":"Users and directories"},"193":{"id":"/docs/troubleshooting-8","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#have-the-application-users-been-created","content":"Have the application users been created?"},"194":{"id":"/docs/troubleshooting-9","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#are-the-data-symlinks-pointing-at-data","content":"Are the data symlinks pointing at `/data`?"},"195":{"id":"/docs/troubleshooting-10","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#bitcoin-core","content":"Bitcoin Core"},"196":{"id":"/docs/troubleshooting-11","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#lnd","content":"LND"},"197":{"id":"/docs/troubleshooting-12","page_id":"/docs/troubleshooting","type":"heading","tags":[],"url":"/docs/troubleshooting#when-you-need-more-help","content":"When you need more help"},"198":{"id":"/docs/troubleshooting-13","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting","content":"Things break. Usually it's something small, a typo in a config\nfile, a permission that got flipped, a drive enclosure doing\nsomething funky. This page walks the common layers of a RaspiBolt\nsetup so you can find the break systematically rather than\nguess-and-check your way through it."},"199":{"id":"/docs/troubleshooting-14","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting","content":"Where the fix lives elsewhere in the guide, I'll link it. Check the\noutput against what's expected, and if something doesn't match,\njump back to the relevant section."},"200":{"id":"/docs/troubleshooting-15","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#jump-to-the-thing-thats-on-fire","content":"Wrong key, mistyped password, fail2ban banned your LAN. Console fallback."},"201":{"id":"/docs/troubleshooting-16","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#jump-to-the-thing-thats-on-fire","content":"UAS quirks, usb-storage.quirks in cmdline.txt, ASMedia vs JMicron."},"202":{"id":"/docs/troubleshooting-17","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#jump-to-the-thing-thats-on-fire","content":"Ports 22, 8333, 9735. Subnet mismatch. LAN reachability."},"203":{"id":"/docs/troubleshooting-18","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#jump-to-the-thing-thats-on-fire","content":"admin, bitcoin, lnd users. Broken symlinks to /data. Permissions."},"204":{"id":"/docs/troubleshooting-19","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#jump-to-the-thing-thats-on-fire","content":"Foreground mode, \"Cannot obtain lock\", \"Error opening block database\", reindex."},"205":{"id":"/docs/troubleshooting-20","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#jump-to-the-thing-thats-on-fire","content":"ZMQ, RPC credentials, IBD dependency, \"Chain backend fully synced\" flag."},"206":{"id":"/docs/troubleshooting-21","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#before-you-start-digging","content":"Three quick places to look, in this order:"},"207":{"id":"/docs/troubleshooting-22","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#before-you-start-digging","content":"**Your own notes.** The most common cause of a broken node is a\nstep that was skipped or done in a different order."},"208":{"id":"/docs/troubleshooting-23","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#before-you-start-digging","content":"**Open issues on GitHub.**\nSomeone probably hit it first. If you find the issue, the fix\nmight already be in the comments."},"209":{"id":"/docs/troubleshooting-24","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#before-you-start-digging","content":"**The FAQ.** Answers to the questions that aren't\nreally \"bugs\", upgrading, restoring backups, Linux basics."},"210":{"id":"/docs/troubleshooting-25","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#before-you-start-digging","content":"If the answer isn't in any of those, file a new issue and include\nenough detail that someone can reproduce the problem: what you did,\nwhat you expected, what you saw, and the output of any relevant\ncommands."},"211":{"id":"/docs/troubleshooting-26","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#ssh-lockout-login-via-console","content":"If SSH refuses to let you in, wrong key, mistyped password,\nfail2ban banned you from your own LAN, plug a display and\nkeyboard into the Pi and log in locally. From there, fix the\nsshd config, unban yourself (`sudo fail2ban-client set sshd\nunbanip 192.168.x.x`), or add a new authorised key."},"212":{"id":"/docs/troubleshooting-27","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#ssh-lockout-login-via-console","content":"This is why we set a strong password on the `admin` account even\nwhen we later disable password SSH: the console fallback still\nneeds it."},"213":{"id":"/docs/troubleshooting-28","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"Ran `hdparm` and got abysmal read speeds? Likely cause: the\nkernel is talking to the drive over UAS (USB Attached SCSI), and\nyour enclosure's UAS implementation is broken. The fix is to tell\nthe kernel to fall back to plain USB mass-storage."},"214":{"id":"/docs/troubleshooting-29","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"Get the vendor and product IDs for the adapter:"},"215":{"id":"/docs/troubleshooting-30","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"Find the entry for your enclosure. The interesting bit is the\n`idVendor:idProduct` pair, something like `0bda:9210`."},"216":{"id":"/docs/troubleshooting-31","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"Open the kernel command line:"},"217":{"id":"/docs/troubleshooting-32","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"At the start of the line, add `usb-storage.quirks=VENDOR:PRODUCT:u`\nwith your values, keep the single space before whatever follows:"},"218":{"id":"/docs/troubleshooting-33","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"For multiple drives, comma-separate them:"},"219":{"id":"/docs/troubleshooting-34","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"Reboot and re-test:"},"220":{"id":"/docs/troubleshooting-35","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#usb-ssd-is-too-slow","content":"You should see a large jump in read speed. If it's still\ncrawling, the enclosure (or its chipset) might just not be a\ngreat match for the Pi, swap it out. ASMedia ASM1153E-based\nenclosures are the safe bet."},"221":{"id":"/docs/troubleshooting-36","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-right-ports-open-on-the-firewall","content":"The firewall should allow at least SSH (22), Bitcoin P2P (8333),\nand Lightning P2P (9735). If you're exposing Electrum or LND gRPC\nto your LAN, those too."},"222":{"id":"/docs/troubleshooting-37","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-right-ports-open-on-the-firewall","content":"Check:"},"223":{"id":"/docs/troubleshooting-38","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-right-ports-open-on-the-firewall","content":"Expected output (your subnet will differ):"},"224":{"id":"/docs/troubleshooting-39","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-right-ports-open-on-the-firewall","content":"If your subnet doesn't match what the rules say (`192.168.0.0/24`\nversus `192.168.1.0/24`, for example), nothing on your LAN can\nreach the node. See Security for\nthe canonical ufw rules."},"225":{"id":"/docs/troubleshooting-40","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#have-the-application-users-been-created","content":"Each line should start with the username and list `/home/<user>`\nas the home directory. Missing entries mean that user never got\ncreated, revisit the relevant section of the guide."},"226":{"id":"/docs/troubleshooting-41","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-data-symlinks-pointing-at-data","content":"The whole point of running from an SSD is that application data\nlives on `/data`, not on the root filesystem. Each service user\nhas a symlink from `~/.<service>` to its data directory."},"227":{"id":"/docs/troubleshooting-42","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-data-symlinks-pointing-at-data","content":"You want to see entries like:"},"228":{"id":"/docs/troubleshooting-43","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-data-symlinks-pointing-at-data","content":"A red, broken symlink means the target directory doesn't exist,\ncreate `/data/bitcoin` (or `/data/lnd`) with the right ownership\nand re-link."},"229":{"id":"/docs/troubleshooting-44","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-data-symlinks-pointing-at-data","content":"The service user also needs write permission in the target\ndirectory. Verify by touching a file as that user:"},"230":{"id":"/docs/troubleshooting-45","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#are-the-data-symlinks-pointing-at-data","content":"No error means the permissions are correct."},"231":{"id":"/docs/troubleshooting-46","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"If something's wrong with `bitcoind`, the quickest way to see what\nis to run it in the foreground, attached to a terminal, where the\nstartup output is visible."},"232":{"id":"/docs/troubleshooting-47","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"Stop the service and start it manually:"},"233":{"id":"/docs/troubleshooting-48","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"`bitcoind` will log its entire startup sequence: config file\nparsing, data directory checks, cache sizing, block index load,\nnetwork bootstrap. Most problems reveal themselves here:"},"234":{"id":"/docs/troubleshooting-49","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"**\"Cannot obtain a lock on data directory\"**, another\n`bitcoind` is already running, or a previous one didn't shut\ndown cleanly. Check with `pgrep bitcoind`."},"235":{"id":"/docs/troubleshooting-50","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"**\"Error opening block database\"**, disk is full, disk is\nfailing, or the indexes are corrupt. If the filesystem is\nhealthy, reindex with `-reindex`."},"236":{"id":"/docs/troubleshooting-51","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"**\"Cannot bind to 0.0.0.0:8333\"**, port 8333 is already in\nuse, likely by a leftover process. Kill it and retry."},"237":{"id":"/docs/troubleshooting-52","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"When you're done, `Ctrl-C` to stop, then bring the service back up:"},"238":{"id":"/docs/troubleshooting-53","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#bitcoin-core","content":"Tail the debug log if you want to keep watching:"},"239":{"id":"/docs/troubleshooting-54","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"Same approach: stop the service, run in the foreground, read the\nstartup output carefully."},"240":{"id":"/docs/troubleshooting-55","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"LND will start, then pause waiting for you to unlock the wallet.\nIn a **second SSH session**, unlock it:"},"241":{"id":"/docs/troubleshooting-56","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"Back in the first session, LND continues: loads the wallet,\nconnects to `bitcoind` via ZMQ, starts rescanning, and eventually\nlogs `Chain backend is fully synced`. Any configuration or\nconnectivity errors show up in this output."},"242":{"id":"/docs/troubleshooting-57","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"Common things to check:"},"243":{"id":"/docs/troubleshooting-58","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"**`lnd.conf`**, the `[Bitcoin]` and `[Bitcoind]` sections must\npoint at the right ZMQ ports and RPC credentials."},"244":{"id":"/docs/troubleshooting-59","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"**RPC credentials**, if you rotated `bitcoind`'s cookie or\nRPC password without updating `lnd.conf`, LND will fail to\nconnect."},"245":{"id":"/docs/troubleshooting-60","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"**Chain sync**, LND won't start routing until `bitcoind` is\nfully synced. A stuck IBD will look like a stuck LND."},"246":{"id":"/docs/troubleshooting-61","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"`Ctrl-C` to stop, then:"},"247":{"id":"/docs/troubleshooting-62","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#lnd","content":"LND's log lives in `/data/lnd/logs/bitcoin/mainnet/lnd.log`, tail\nit the same way:"},"248":{"id":"/docs/troubleshooting-63","page_id":"/docs/troubleshooting","tags":[],"type":"text","url":"/docs/troubleshooting#when-you-need-more-help","content":"This troubleshooting guide gets extended whenever a pattern shows\nup enough times to be worth documenting. If you've worked through a\ngnarly problem that isn't here, an issue or pull request is the way\nto add it, future-you (and everyone else) will thank you."},"249":{"id":"/docs/bitcoin/bitcoin-client","page_id":"/docs/bitcoin/bitcoin-client","type":"page","content":"Bitcoin client","breadcrumbs":["Docs","Bitcoin"],"tags":[],"url":"/docs/bitcoin/bitcoin-client"},"250":{"id":"/docs/bitcoin/bitcoin-client-0","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client","content":"Install and run Bitcoin Core (bitcoind), GPG-verify the release, tune bitcoin.conf for a Pi 5 (dbcache, maxmempool), and sync the full blockchain (IBD, initial block download) through Tor."},"251":{"id":"/docs/bitcoin/bitcoin-client-1","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#what-to-expect","content":"What to expect"},"252":{"id":"/docs/bitcoin/bitcoin-client-2","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#create-the-bitcoin-user","content":"Create the bitcoin user"},"253":{"id":"/docs/bitcoin/bitcoin-client-3","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#create-the-data-directory","content":"Create the data directory"},"254":{"id":"/docs/bitcoin/bitcoin-client-4","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"Download and verify Bitcoin Core"},"255":{"id":"/docs/bitcoin/bitcoin-client-5","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#install-the-binaries","content":"Install the binaries"},"256":{"id":"/docs/bitcoin/bitcoin-client-6","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#generate-rpc-credentials","content":"Generate RPC credentials"},"257":{"id":"/docs/bitcoin/bitcoin-client-7","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#write-bitcoinconf","content":"Write bitcoin.conf"},"258":{"id":"/docs/bitcoin/bitcoin-client-8","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#systemd-unit","content":"Systemd unit"},"259":{"id":"/docs/bitcoin/bitcoin-client-9","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"Verify it's syncing"},"260":{"id":"/docs/bitcoin/bitcoin-client-10","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#after-the-initial-sync","content":"After the initial sync"},"261":{"id":"/docs/bitcoin/bitcoin-client-11","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#opentimestamps-client-optional","content":"OpenTimestamps client (optional)"},"262":{"id":"/docs/bitcoin/bitcoin-client-12","page_id":"/docs/bitcoin/bitcoin-client","type":"heading","tags":[],"url":"/docs/bitcoin/bitcoin-client#updating-bitcoin-core-later","content":"Updating Bitcoin Core later"},"263":{"id":"/docs/bitcoin/bitcoin-client-13","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client","content":"Bitcoin Core is the reference client for\nthe Bitcoin network. It downloads the entire blockchain, validates\nevery transaction since the genesis block, and from then on holds\nthe authoritative answer to \"is this UTXO real?\", no third party\nasked, no trust extended. Everything else in this guide, Electrs,\nLightning, the block explorer, is a consumer of this node."},"264":{"id":"/docs/bitcoin/bitcoin-client-14","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#what-to-expect","content":"Installing `bitcoind` is a short job. Syncing it is not. On a Pi 5\nwith a good USB 3 SSD (or NVMe via the M.2 HAT+), the initial block\ndownload takes roughly **two to five days**. You don't have to sit\nwith it, start it, check in once a day, come back when\n`verificationprogress` is a hair below 1."},"265":{"id":"/docs/bitcoin/bitcoin-client-15","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#what-to-expect","content":"A Pi 4 with 8 GB RAM still gets there, just slower, plan for five to\nseven days for the initial sync and keep the `dbcache` a little lower\n(see below). Anything less than 8 GB of RAM will struggle once LND\nand Electrs join the party; upgrade if you can."},"266":{"id":"/docs/bitcoin/bitcoin-client-16","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#create-the-bitcoin-user","content":"`bitcoind` runs as its own system user. No shell password, no\nsudo, if something ever does manage to break out of the daemon, it\nlands in a sandbox, not on your `admin` account."},"267":{"id":"/docs/bitcoin/bitcoin-client-17","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#create-the-bitcoin-user","content":"Create the user and add `admin` to its group so you can read its\nfiles without juggling `sudo`:"},"268":{"id":"/docs/bitcoin/bitcoin-client-18","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#create-the-bitcoin-user","content":"Put the `bitcoin` user into the `debian-tor` group so it can read\nTor's cookie file and use the control port you set up earlier:"},"269":{"id":"/docs/bitcoin/bitcoin-client-19","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#create-the-data-directory","content":"Bitcoin Core defaults to `~/.bitcoin` inside the user's home. On\nthis node the chain lives under `/data/bitcoin` on the SSD, a\nseparate mount you carved out in System configuration.\nA symlink from `/home/bitcoin/.bitcoin` to that location keeps the\ndefaults happy while the actual data sits on the fast disk."},"270":{"id":"/docs/bitcoin/bitcoin-client-20","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"Never run a Bitcoin binary you haven't verified. The point of a\nfull node is to trust your own software, which means the software\nhas to be what the developers actually signed."},"271":{"id":"/docs/bitcoin/bitcoin-client-21","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"As `admin`, drop into `/tmp` (cleared on every reboot) and pull\nthe binary, the checksum file, and the signature file:"},"272":{"id":"/docs/bitcoin/bitcoin-client-22","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"Check the checksum of the archive against the reference. The\n\"improperly formatted\" warning is about unrelated platforms in\nthe same file, ignore it:"},"273":{"id":"/docs/bitcoin/bitcoin-client-23","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"You want to see:"},"274":{"id":"/docs/bitcoin/bitcoin-client-24","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"Bitcoin Core releases are signed by multiple maintainers through\nthe guix.sigs repository.\nImport all current signing keys in one sweep:"},"275":{"id":"/docs/bitcoin/bitcoin-client-25","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"Verify the checksum file's signatures. You want several `Good\nsignature` lines, one signature alone is not enough:"},"276":{"id":"/docs/bitcoin/bitcoin-client-26","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"Skim the output for multiple lines like:"},"277":{"id":"/docs/bitcoin/bitcoin-client-27","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#download-and-verify-bitcoin-core","content":"A matching SHA256 only proves the file matches the checksum file.\nThe GPG step is what proves the checksum file itself came from the\nBitcoin Core maintainers and not someone who also controls the\ndownload server. Verify both, or verify neither."},"278":{"id":"/docs/bitcoin/bitcoin-client-28","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#install-the-binaries","content":"If checksum and signature are happy, extract and install:"},"279":{"id":"/docs/bitcoin/bitcoin-client-29","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#install-the-binaries","content":"Expected output:"},"280":{"id":"/docs/bitcoin/bitcoin-client-30","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#generate-rpc-credentials","content":"Other programs (Electrs, LND, the block explorer) talk to `bitcoind`\nthrough its RPC interface. Bitcoin Core doesn't store the password\nin plaintext, it stores a salted hash. A short Python script ships\nwith the source tree to generate the config line."},"281":{"id":"/docs/bitcoin/bitcoin-client-31","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#generate-rpc-credentials","content":"As the `bitcoin` user, fetch the helper script:"},"282":{"id":"/docs/bitcoin/bitcoin-client-32","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#generate-rpc-credentials","content":"Run it with the username `raspibolt` and your &#x2A;*password \\[B]**\nfrom Preparations.\nPut a leading space in front of the command so bash keeps it out\nof your shell history, passwords don't belong in `~/.bash_history`:"},"283":{"id":"/docs/bitcoin/bitcoin-client-33","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#generate-rpc-credentials","content":"The script prints a line starting with `rpcauth=raspibolt:...$...`.\nCopy it, you'll paste it into the config file next."},"284":{"id":"/docs/bitcoin/bitcoin-client-34","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#write-bitcoinconf","content":"This config is tuned for a Pi 5 with 8 GB of RAM: a generous `dbcache`\nto accelerate the initial sync, outbound traffic through Tor, ZMQ\nports exposed for LND later on, and RPC locked to localhost."},"285":{"id":"/docs/bitcoin/bitcoin-client-35","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#write-bitcoinconf","content":"Still as the `bitcoin` user, open the config:"},"286":{"id":"/docs/bitcoin/bitcoin-client-36","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#write-bitcoinconf","content":"Paste the following. Replace the `rpcauth=` line with the one\n`rpcauth.py` just printed for you:"},"287":{"id":"/docs/bitcoin/bitcoin-client-37","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#write-bitcoinconf","content":"Lock the file down so only `bitcoin` and its group can read it,\nthe `rpcauth` hash isn't exactly a secret, but it's a credential:"},"288":{"id":"/docs/bitcoin/bitcoin-client-38","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#write-bitcoinconf","content":"`blocksonly=1` tells `bitcoind` to skip relaying loose transactions\nduring the initial sync. It cuts bandwidth use significantly while\nthe node is chewing through history. You'll turn it off after the\nsync completes, alongside the `dbcache` reduction, see the bottom\nof this page."},"289":{"id":"/docs/bitcoin/bitcoin-client-39","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#systemd-unit","content":"The node needs to start on boot and stay running, that's what\nsystemd is for. This unit runs `bitcoind` as the `bitcoin` user,\nlocks it into a few standard hardening primitives, and restarts on\nfailure with a sensible backoff."},"290":{"id":"/docs/bitcoin/bitcoin-client-40","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#systemd-unit","content":"Drop back to `admin`:"},"291":{"id":"/docs/bitcoin/bitcoin-client-41","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#systemd-unit","content":"Create the unit file:"},"292":{"id":"/docs/bitcoin/bitcoin-client-42","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#systemd-unit","content":"Paste:"},"293":{"id":"/docs/bitcoin/bitcoin-client-43","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#systemd-unit","content":"Enable it (so it runs on boot) and start it now:"},"294":{"id":"/docs/bitcoin/bitcoin-client-44","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#systemd-unit","content":"Also symlink the data directory into `admin`'s home so\n`bitcoin-cli` works without a `-datadir` flag:"},"295":{"id":"/docs/bitcoin/bitcoin-client-45","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"Check the service is up:"},"296":{"id":"/docs/bitcoin/bitcoin-client-46","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"You want `Active: active (running)`."},"297":{"id":"/docs/bitcoin/bitcoin-client-47","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"Confirm the cookie file is group-readable, Electrs and LND need\nthis later:"},"298":{"id":"/docs/bitcoin/bitcoin-client-48","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"The mode should be `-rw-r-----` with owner `bitcoin` and group\n`bitcoin`."},"299":{"id":"/docs/bitcoin/bitcoin-client-49","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"Ask the running node for its view of the chain:"},"300":{"id":"/docs/bitcoin/bitcoin-client-50","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"Early on you'll see a low `blocks` number and a `verificationprogress`\nfar below 1. That's the initial block download in progress. Check\nback each day; when `verificationprogress` reads `0.99999...`, the\nnode is caught up."},"301":{"id":"/docs/bitcoin/bitcoin-client-51","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"To watch it work in real time, tail the debug log (`Ctrl`-`C` to\nexit):"},"302":{"id":"/docs/bitcoin/bitcoin-client-52","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"Bitcoin Core on the RaspiBolt is **not** where you should store\nfunds, the Electrum server and Sparrow Wallet in the next pages\nare. If you do create a wallet here for testing, the file lives at\n`/data/bitcoin/wallets/<name>/wallet.dat`. Copy it to an encrypted\nUSB stick before you load any real sats into it. The Pi is a node,\nnot a vault."},"303":{"id":"/docs/bitcoin/bitcoin-client-53","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#verify-its-syncing","content":"**Main takeaway:** `bitcoind` is running under its own user, syncing\nthe chain through Tor, and exposing the RPC and ZMQ surfaces the\nnext services in this guide will plug into."},"304":{"id":"/docs/bitcoin/bitcoin-client-54","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#after-the-initial-sync","content":"Once `verificationprogress` clears `0.99999...`, trim the `dbcache`\nback to a sensible steady-state value so Electrs and LND have room\nto breathe, and turn transaction relay back on so the node earns\nits keep on the network."},"305":{"id":"/docs/bitcoin/bitcoin-client-55","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#after-the-initial-sync","content":"Open the config:"},"306":{"id":"/docs/bitcoin/bitcoin-client-56","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#after-the-initial-sync","content":"Comment out the IBD tuning lines:"},"307":{"id":"/docs/bitcoin/bitcoin-client-57","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#after-the-initial-sync","content":"Restart the daemon:"},"308":{"id":"/docs/bitcoin/bitcoin-client-58","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#after-the-initial-sync","content":"Bitcoin Core now uses its default \\~450 MB cache and relays\ntransactions in addition to blocks."},"309":{"id":"/docs/bitcoin/bitcoin-client-59","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#opentimestamps-client-optional","content":"Later in this guide you'll verify signatures on LND, Electrs, and\nother software. Those projects ship OpenTimestamps proofs for their\nrelease files, cryptographic evidence that a given file existed\nbefore a particular Bitcoin block. Your node can verify those proofs\nagainst its own chain data, so you're not trusting a third-party\ntimestamp server."},"310":{"id":"/docs/bitcoin/bitcoin-client-60","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#opentimestamps-client-optional","content":"The `--break-system-packages` flag is Debian 13's way of telling you\nthat it prefers packaged installs, in this case, upstream pip is\nthe only current source for the client, and it's an isolated tool\nthat does not touch the system Python."},"311":{"id":"/docs/bitcoin/bitcoin-client-61","page_id":"/docs/bitcoin/bitcoin-client","tags":[],"type":"text","url":"/docs/bitcoin/bitcoin-client#updating-bitcoin-core-later","content":"Upgrades follow the same download-verify-install rhythm as a fresh\ninstall. Always read the release notes\nfirst, some releases change the data format or default behaviour.\nThe `30.2` token and its derived URL in\n`lib/versions.ts` are the single source of truth in this guide; bump\nthat file when a new version lands."},"312":{"id":"/docs/bitcoin/blockchain-explorer","page_id":"/docs/bitcoin/blockchain-explorer","type":"page","content":"Blockchain explorer","breadcrumbs":["Docs","Bitcoin"],"tags":[],"url":"/docs/bitcoin/blockchain-explorer"},"313":{"id":"/docs/bitcoin/blockchain-explorer-0","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer","content":"Run BTC RPC Explorer on Node.js 22 behind Caddy HTTPS. Private lookup for blocks, transactions, mempool, fee estimates, UTXO queries. No leakage to public explorers."},"314":{"id":"/docs/bitcoin/blockchain-explorer-1","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#what-youll-do","content":"What you'll do"},"315":{"id":"/docs/bitcoin/blockchain-explorer-2","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#prerequisites","content":"Prerequisites"},"316":{"id":"/docs/bitcoin/blockchain-explorer-3","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#install-nodejs-22-lts","content":"Install Node.js 22 LTS"},"317":{"id":"/docs/bitcoin/blockchain-explorer-4","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#create-the-service-user","content":"Create the service user"},"318":{"id":"/docs/bitcoin/blockchain-explorer-5","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#install-btc-rpc-explorer","content":"Install BTC RPC Explorer"},"319":{"id":"/docs/bitcoin/blockchain-explorer-6","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#configure","content":"Configure"},"320":{"id":"/docs/bitcoin/blockchain-explorer-7","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#run-it-once-by-hand","content":"Run it once by hand"},"321":{"id":"/docs/bitcoin/blockchain-explorer-8","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#systemd-unit","content":"Systemd unit"},"322":{"id":"/docs/bitcoin/blockchain-explorer-9","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#https-on-the-lan-with-caddy","content":"HTTPS on the LAN with Caddy"},"323":{"id":"/docs/bitcoin/blockchain-explorer-10","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#install-caddy","content":"Install Caddy"},"324":{"id":"/docs/bitcoin/blockchain-explorer-11","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"Configure the reverse proxy"},"325":{"id":"/docs/bitcoin/blockchain-explorer-12","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#remote-access-over-tor-optional","content":"Remote access over Tor (optional)"},"326":{"id":"/docs/bitcoin/blockchain-explorer-13","page_id":"/docs/bitcoin/blockchain-explorer","type":"heading","tags":[],"url":"/docs/bitcoin/blockchain-explorer#updating-btc-rpc-explorer-later","content":"Updating BTC RPC Explorer later"},"327":{"id":"/docs/bitcoin/blockchain-explorer-14","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer","content":"Querying a public block explorer is one of the sneakiest ways to\nleak your financial activity. Every address you search, every\ntransaction ID you paste, every fee chart you refresh tells the\nexplorer operator \"this address matters to somebody at this IP.\"\nTrust your own node instead."},"328":{"id":"/docs/bitcoin/blockchain-explorer-15","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer","content":"BTC RPC Explorer is\na small, database-free web UI by Daniel McNally. It talks to your\nBitcoin Core over RPC and to Electrs for address balance queries,\ngives you a clean browser interface for blocks, transactions,\nmempool, and fee estimates, and never phones home."},"329":{"id":"/docs/bitcoin/blockchain-explorer-16","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#what-youll-do","content":"Install Node.js 22 LTS from NodeSource."},"330":{"id":"/docs/bitcoin/blockchain-explorer-17","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#what-youll-do","content":"Create a dedicated `btcrpcexplorer` user and clone the app."},"331":{"id":"/docs/bitcoin/blockchain-explorer-18","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#what-youll-do","content":"Wire up the `.env` config so it reads `bitcoind`'s cookie and\nqueries Electrs for address data."},"332":{"id":"/docs/bitcoin/blockchain-explorer-19","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#what-youll-do","content":"Run it as a systemd service."},"333":{"id":"/docs/bitcoin/blockchain-explorer-20","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#what-youll-do","content":"Put **Caddy** in front for HTTPS on the LAN."},"334":{"id":"/docs/bitcoin/blockchain-explorer-21","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#prerequisites","content":"You finished Bitcoin client and\nElectrum server. Bitcoin Core is\nfully synced (`verificationprogress` at 1.0), `txindex=1`\nis in `bitcoin.conf` (the default config in this guide already has\nit), and Electrs is indexed and answering queries."},"335":{"id":"/docs/bitcoin/blockchain-explorer-22","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-nodejs-22-lts","content":"Debian 13 ships Node.js 20; BTC RPC Explorer is tested against\nNode 22. Add the NodeSource repo so `apt upgrade` keeps it current."},"336":{"id":"/docs/bitcoin/blockchain-explorer-23","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-nodejs-22-lts","content":"Add NodeSource and install:"},"337":{"id":"/docs/bitcoin/blockchain-explorer-24","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-nodejs-22-lts","content":"Confirm the version:"},"338":{"id":"/docs/bitcoin/blockchain-explorer-25","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-nodejs-22-lts","content":"Expected output, a `v22.x` line from `node`, and a `10.x` or newer\nline from `npm`:"},"339":{"id":"/docs/bitcoin/blockchain-explorer-26","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#create-the-service-user","content":"The `bitcoin` group membership is what lets the explorer read\n`/data/bitcoin/.cookie` for RPC authentication."},"340":{"id":"/docs/bitcoin/blockchain-explorer-27","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-btc-rpc-explorer","content":"Switch to the new user and fetch the latest release tag:"},"341":{"id":"/docs/bitcoin/blockchain-explorer-28","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-btc-rpc-explorer","content":"Clone the source and pull in dependencies with npm. Expect this\nto take 10 to 20 minutes on a Pi 5, a lot of native modules get\nbuilt from source:"},"342":{"id":"/docs/bitcoin/blockchain-explorer-29","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-btc-rpc-explorer","content":"`npm install` will print warnings about vulnerabilities in transitive\ndependencies. Read them, but don't panic. The explorer serves only\nto **you** on your LAN; the realistic threat surface is your own\nbrowser, not a remote attacker poking at the Express server. Don't\nblindly `npm audit fix`, it'll break things."},"343":{"id":"/docs/bitcoin/blockchain-explorer-30","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"The explorer reads its config from `.env` in the install directory.\nA heavily commented template ships with the source. You only need to\nchange a handful of lines."},"344":{"id":"/docs/bitcoin/blockchain-explorer-31","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"Copy the template and open it:"},"345":{"id":"/docs/bitcoin/blockchain-explorer-32","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"Set the Bitcoin Core connection (cookie auth, no password to\nleak):"},"346":{"id":"/docs/bitcoin/blockchain-explorer-33","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"Route address-balance queries through your local Electrs so they\nnever leak to a third party:"},"347":{"id":"/docs/bitcoin/blockchain-explorer-34","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"Pick a privacy posture. \"More information\" mode pulls exchange\nrates and a few other externally-hosted tidbits over the public\ninternet:"},"348":{"id":"/docs/bitcoin/blockchain-explorer-35","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"Or lock it down completely:"},"349":{"id":"/docs/bitcoin/blockchain-explorer-36","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"(Optional) Gate the UI with a password. Any username works; only\nthe password is checked. Use &#x2A;*password \\[D]** from\nPreparations:"},"350":{"id":"/docs/bitcoin/blockchain-explorer-37","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"Dark theme, because it's a block explorer and you're not a\nmonster:"},"351":{"id":"/docs/bitcoin/blockchain-explorer-38","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure","content":"Save, exit, and drop back to `admin`:"},"352":{"id":"/docs/bitcoin/blockchain-explorer-39","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#run-it-once-by-hand","content":"Before handing it to systemd, start it manually to shake out any\nconfig mistakes:"},"353":{"id":"/docs/bitcoin/blockchain-explorer-40","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#run-it-once-by-hand","content":"The explorer should bind to `http://127.0.0.1:3002`. If the console\nfills with RPC errors, Bitcoin Core is either not running or still\nreindexing, leave this alone until `bitcoin-cli getblockchaininfo`\nreports a `verificationprogress` at 1.0."},"354":{"id":"/docs/bitcoin/blockchain-explorer-41","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#run-it-once-by-hand","content":"Stop it with `Ctrl`-`C` and exit back to `admin`:"},"355":{"id":"/docs/bitcoin/blockchain-explorer-42","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#systemd-unit","content":"Create the service file:"},"356":{"id":"/docs/bitcoin/blockchain-explorer-43","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#systemd-unit","content":"Paste:"},"357":{"id":"/docs/bitcoin/blockchain-explorer-44","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#systemd-unit","content":"Enable and start:"},"358":{"id":"/docs/bitcoin/blockchain-explorer-45","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#systemd-unit","content":"Watch the log for a \"listening on port 3002\" line, then\n`Ctrl`-`C`."},"359":{"id":"/docs/bitcoin/blockchain-explorer-46","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#https-on-the-lan-with-caddy","content":"The explorer's Express server speaks HTTP on port 3002. You want\nbrowser access over HTTPS, and you want it without fighting\ncertificate tooling. **Caddy** handles this in five lines of config\nand issues itself a certificate from its own internal CA."},"360":{"id":"/docs/bitcoin/blockchain-explorer-47","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#install-caddy","content":"The official Caddy apt repo is the right source. One-time setup:"},"361":{"id":"/docs/bitcoin/blockchain-explorer-48","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"Open the Caddyfile:"},"362":{"id":"/docs/bitcoin/blockchain-explorer-49","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"Replace the default welcome-page stanza with:"},"363":{"id":"/docs/bitcoin/blockchain-explorer-50","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"`tls internal` tells Caddy to mint and manage a self-signed\ncertificate from its own CA, no public DNS needed."},"364":{"id":"/docs/bitcoin/blockchain-explorer-51","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"Reload Caddy and open the firewall:"},"365":{"id":"/docs/bitcoin/blockchain-explorer-52","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"Point your browser at `https://raspibolt.local:4000` (or the\nPi's IP address). Click past the browser's one-time certificate\nwarning, self-signed certs trigger that, and on a LAN it's fine."},"366":{"id":"/docs/bitcoin/blockchain-explorer-53","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"Tired of the certificate warning? Caddy's internal CA root lives\nat `/var/lib/caddy/.local/share/caddy/pki/authorities/local/root.crt`\non the Pi. Copy that file to your computer, import it into the\nsystem trust store, and all the Caddy-fronted services on this node\nwill be trusted without prompting. Skip this if you'd rather keep\nthe CA contained to the Pi, first-use trust is fine too."},"367":{"id":"/docs/bitcoin/blockchain-explorer-54","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#configure-the-reverse-proxy","content":"**Main takeaway:** you can now browse blocks, transactions, and\nfee estimates at `https://raspibolt.local:4000` without telling\nanyone else what you're looking at."},"368":{"id":"/docs/bitcoin/blockchain-explorer-55","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#remote-access-over-tor-optional","content":"Want the explorer available from a phone on mobile data? Expose it\nas a Tor hidden service and visit it through Tor Browser."},"369":{"id":"/docs/bitcoin/blockchain-explorer-56","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#remote-access-over-tor-optional","content":"Add a stanza to `/etc/tor/torrc`:"},"370":{"id":"/docs/bitcoin/blockchain-explorer-57","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#remote-access-over-tor-optional","content":"Reload Tor and fetch the `.onion`:"},"371":{"id":"/docs/bitcoin/blockchain-explorer-58","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#remote-access-over-tor-optional","content":"Open that address in the Tor Browser.\nNo certificates, no warnings, Tor's own end-to-end encryption\nreplaces TLS."},"372":{"id":"/docs/bitcoin/blockchain-explorer-59","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#updating-btc-rpc-explorer-later","content":"Stop the service and switch to the app user:"},"373":{"id":"/docs/bitcoin/blockchain-explorer-60","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#updating-btc-rpc-explorer-later","content":"Update to the latest tag:"},"374":{"id":"/docs/bitcoin/blockchain-explorer-61","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#updating-btc-rpc-explorer-later","content":"Restart:"},"375":{"id":"/docs/bitcoin/blockchain-explorer-62","page_id":"/docs/bitcoin/blockchain-explorer","tags":[],"type":"text","url":"/docs/bitcoin/blockchain-explorer#updating-btc-rpc-explorer-later","content":"Always skim the changelog\nfirst, breaking changes are rare but not unheard of."},"376":{"id":"/docs/bitcoin/desktop-wallet","page_id":"/docs/bitcoin/desktop-wallet","type":"page","content":"Desktop wallet","breadcrumbs":["Docs","Bitcoin"],"tags":[],"url":"/docs/bitcoin/desktop-wallet"},"377":{"id":"/docs/bitcoin/desktop-wallet-0","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet","content":"Point Sparrow Wallet at your own Electrs over TLS. Watch-only wallets, hardware wallet integration, coin control, labelling UTXOs, air-gapped PSBT signing."},"378":{"id":"/docs/bitcoin/desktop-wallet-1","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#not-sparrow","content":"Not Sparrow?"},"379":{"id":"/docs/bitcoin/desktop-wallet-2","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#hot-wallet-watch-only-and-why-hardware-matters","content":"Hot wallet, watch-only, and why hardware matters"},"380":{"id":"/docs/bitcoin/desktop-wallet-3","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"Install Sparrow"},"381":{"id":"/docs/bitcoin/desktop-wallet-4","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"Connect Sparrow to your node"},"382":{"id":"/docs/bitcoin/desktop-wallet-5","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#troubleshooting-a-failed-connect","content":"Troubleshooting a failed connect"},"383":{"id":"/docs/bitcoin/desktop-wallet-6","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#core-workflow","content":"Core workflow"},"384":{"id":"/docs/bitcoin/desktop-wallet-7","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#label-your-utxos","content":"Label your UTXOs"},"385":{"id":"/docs/bitcoin/desktop-wallet-8","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#optional-connect-over-tor","content":"(Optional) Connect over Tor"},"386":{"id":"/docs/bitcoin/desktop-wallet-9","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"(Optional) Tor proxy for external services"},"387":{"id":"/docs/bitcoin/desktop-wallet-10","page_id":"/docs/bitcoin/desktop-wallet","type":"heading","tags":[],"url":"/docs/bitcoin/desktop-wallet#updating-sparrow","content":"Updating Sparrow"},"388":{"id":"/docs/bitcoin/desktop-wallet-11","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet","content":"A node with no wallet is a useful thing, but it's not a personal\nthing. This page closes the loop: a wallet on your computer, talking\nto your node on the Pi, signing with a hardware wallet you hold in\nyour hand. That's the endgame, your keys, your node, your\nvalidation, your privacy."},"389":{"id":"/docs/bitcoin/desktop-wallet-12","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet","content":"The pick: **Sparrow Wallet** by Craig\nRaw. Active development, transparent about what it's doing under the\nhood, first-class support for every common hardware wallet, excellent\ncoin control, PSBTs, and batching. Sparrow is the right default for\nmost people using a RaspiBolt."},"390":{"id":"/docs/bitcoin/desktop-wallet-13","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#not-sparrow","content":"If Sparrow doesn't fit your workflow, these are all fine companions\nto a RaspiBolt:"},"391":{"id":"/docs/bitcoin/desktop-wallet-14","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#not-sparrow","content":"**BitBoxApp**, the natural choice\nif you hold a BitBox02 hardware wallet."},"392":{"id":"/docs/bitcoin/desktop-wallet-15","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#not-sparrow","content":"**Electrum desktop**, the original.\nPowerful, a little austere, and still the yardstick for Electrum\nserver compatibility."},"393":{"id":"/docs/bitcoin/desktop-wallet-16","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#not-sparrow","content":"**Specter Desktop**,\nfocused on multisig and air-gapped workflows. Connects directly\nto Bitcoin Core rather than Electrs."},"394":{"id":"/docs/bitcoin/desktop-wallet-17","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#not-sparrow","content":"**Ledger Live** or **Trezor Suite**, OK if you're already in\nthose ecosystems; both can point at your Bitcoin Core RPC. Less\nflexible than Sparrow."},"395":{"id":"/docs/bitcoin/desktop-wallet-18","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#not-sparrow","content":"The rest of this page walks through Sparrow. The other wallets\nfollow roughly the same pattern, pick the \"Private Electrum\nServer\" option and point it at your Pi."},"396":{"id":"/docs/bitcoin/desktop-wallet-19","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#hot-wallet-watch-only-and-why-hardware-matters","content":"A quick piece of framing before you install anything."},"397":{"id":"/docs/bitcoin/desktop-wallet-20","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#hot-wallet-watch-only-and-why-hardware-matters","content":"A **hot wallet** holds its private keys in plaintext on a device\nconnected to the internet. Fine for small amounts; dangerous for\nsavings."},"398":{"id":"/docs/bitcoin/desktop-wallet-21","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#hot-wallet-watch-only-and-why-hardware-matters","content":"A **watch-only wallet** holds only your *public* keys. It can\nshow balances, build transactions, and tell a hardware wallet\nwhat to sign, but it cannot spend anything without the hardware\nwallet present."},"399":{"id":"/docs/bitcoin/desktop-wallet-22","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#hot-wallet-watch-only-and-why-hardware-matters","content":"A **hardware wallet** keeps private keys on a small dedicated\ndevice that never exposes them to your computer. Signing happens\non the device itself; your computer only sees the signed\ntransaction."},"400":{"id":"/docs/bitcoin/desktop-wallet-23","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#hot-wallet-watch-only-and-why-hardware-matters","content":"Sparrow is happiest when it's watch-only plus a hardware wallet on\na USB port. This is why, if you can swing it, you'll want a\nBitBox02, Coldcard, Jade, Ledger, or Trezor before you load real\nfunds into this setup."},"401":{"id":"/docs/bitcoin/desktop-wallet-24","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"Sparrow ships signed releases for Windows, macOS, and Linux. Verify\nbefore you run."},"402":{"id":"/docs/bitcoin/desktop-wallet-25","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"Open sparrowwallet.com/download\nand grab:"},"403":{"id":"/docs/bitcoin/desktop-wallet-26","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"the installer for your OS,"},"404":{"id":"/docs/bitcoin/desktop-wallet-27","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"the `sparrow-<version>-manifest.txt`,"},"405":{"id":"/docs/bitcoin/desktop-wallet-28","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"the `sparrow-<version>-manifest.txt.asc` signature."},"406":{"id":"/docs/bitcoin/desktop-wallet-29","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"Follow Sparrow's own release verification guide.\nThe short version: import Craig Raw's PGP key, verify the\nmanifest signature, then verify the installer against the\nmanifest's SHA256."},"407":{"id":"/docs/bitcoin/desktop-wallet-30","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"Install and launch Sparrow."},"408":{"id":"/docs/bitcoin/desktop-wallet-31","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#install-sparrow","content":"If the signature check fails, stop. Don't install. Ask on Sparrow's\nTelegram before doing anything else, this is not the moment to\ngive a random binary your seed words."},"409":{"id":"/docs/bitcoin/desktop-wallet-32","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"Sparrow's first-run wizard walks you straight into server\nconfiguration. If you're past that screen, you can reach the same\ndialog at any time with **Preferences → Server** (`Ctrl`-`P` on\nWindows/Linux, `Cmd`-`,` on macOS)."},"410":{"id":"/docs/bitcoin/desktop-wallet-33","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"Select the **Private Electrum** tab."},"411":{"id":"/docs/bitcoin/desktop-wallet-34","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"**URL:** `raspibolt.local` (or your Pi's IP, e.g. `192.168.0.20`)."},"412":{"id":"/docs/bitcoin/desktop-wallet-35","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"**Port:** `50002`."},"413":{"id":"/docs/bitcoin/desktop-wallet-36","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"Toggle **Use SSL** on."},"414":{"id":"/docs/bitcoin/desktop-wallet-37","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"Click **Test Connection**. On first connect, Sparrow shows the\nself-signed certificate from stunnel, read the fingerprint, then\n**Accept**. The button turns green and reports something like\n`Connected to electrs/0.11.1 on protocol version 1.4`."},"415":{"id":"/docs/bitcoin/desktop-wallet-38","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"Close the dialog. Bottom-right of the main window, the server\nicon should be solid blue, \"Connected to ... at height ...\" on\nhover."},"416":{"id":"/docs/bitcoin/desktop-wallet-39","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#connect-sparrow-to-your-node","content":"You saw it coming: the cert was minted by stunnel's openssl command\non the Pi, so no public CA has heard of it. The fingerprint you\naccept now is the one Sparrow will expect on every future connect;\nif it ever changes unexpectedly, something's off. That's the\nsecurity value of first-use trust."},"417":{"id":"/docs/bitcoin/desktop-wallet-40","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#troubleshooting-a-failed-connect","content":"**Guest WiFi strikes again.** \"Guest\" or \"isolated\" WiFi networks\non most home routers block client-to-client traffic, which is\nexactly what you need. Switch to the main WiFi."},"418":{"id":"/docs/bitcoin/desktop-wallet-41","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#troubleshooting-a-failed-connect","content":"**Stale certificate.** If you used Sparrow before connecting to\na *different* Electrum server at the same hostname, delete the\ncached certs and try again:"},"419":{"id":"/docs/bitcoin/desktop-wallet-42","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#troubleshooting-a-failed-connect","content":"Windows: `C:\\Users\\<you>\\AppData\\Roaming\\Sparrow\\certs`"},"420":{"id":"/docs/bitcoin/desktop-wallet-43","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#troubleshooting-a-failed-connect","content":"macOS: `~/.sparrow/certs`"},"421":{"id":"/docs/bitcoin/desktop-wallet-44","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#troubleshooting-a-failed-connect","content":"Linux: `~/.sparrow/certs`"},"422":{"id":"/docs/bitcoin/desktop-wallet-45","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#troubleshooting-a-failed-connect","content":"**Hostname resolution.** If `raspibolt.local` doesn't resolve,\nuse the Pi's IP address. Some Windows setups never enable mDNS by\ndefault."},"423":{"id":"/docs/bitcoin/desktop-wallet-46","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#core-workflow","content":"Once you're connected, Sparrow is your window into the on-chain\nworld. A quick tour:"},"424":{"id":"/docs/bitcoin/desktop-wallet-47","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#core-workflow","content":"**Create a wallet** → **New Wallet** → choose a name. For real\nfunds, pick **Connect Hardware Wallet** and let Sparrow import the\npublic keys (xpubs) from your device. The wallet is now watch-only:\nit can see, but not spend."},"425":{"id":"/docs/bitcoin/desktop-wallet-48","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#core-workflow","content":"**Receive:** go to the **Receive** tab, give the next address a\nlabel, and share it. Label everything you can. Future-you will\nthank present-you every time you look at a transaction history."},"426":{"id":"/docs/bitcoin/desktop-wallet-49","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#core-workflow","content":"**Send:** pick the UTXOs you want to spend from the **UTXOs** tab\n(this is coin control, an underrated privacy tool), draft the\ntransaction, and let your hardware wallet sign it. Sparrow shows\nthe exact bytes the device will sign, every fee, and every\nchange output. Nothing is hidden."},"427":{"id":"/docs/bitcoin/desktop-wallet-50","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#core-workflow","content":"**PSBT:** if the signing device lives air-gapped (a Coldcard with\nan SD card, for example), export a Partially Signed Bitcoin\nTransaction, sign on the cold device, and import the signed PSBT\nback. Same result; no USB."},"428":{"id":"/docs/bitcoin/desktop-wallet-51","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#label-your-utxos","content":"This deserves its own beat. An unlabeled UTXO set is a chain-analysis\nparadise waiting to happen, you'll absent-mindedly combine a KYC\nexchange UTXO with one from a peer-to-peer trade and quietly doxx\nyourself. Labels in Sparrow persist across wallet opens, get\nexported with the wallet file, and show up in every coin-selection\ndialog. Use them."},"429":{"id":"/docs/bitcoin/desktop-wallet-52","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#label-your-utxos","content":"**Main takeaway:** with Sparrow talking to your node and a hardware\nwallet plugged in, you have a setup that sits cleanly at the top of\nthe self-custody tree, private, verified, spendable, and yours."},"430":{"id":"/docs/bitcoin/desktop-wallet-53","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-connect-over-tor","content":"Travelling? Point Sparrow at the Tor hidden service you set up in\nElectrum server\nso you can reach your node from anywhere."},"431":{"id":"/docs/bitcoin/desktop-wallet-54","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-connect-over-tor","content":"In **Preferences → Server → Private Electrum**, click **Edit\nExisting Connection**."},"432":{"id":"/docs/bitcoin/desktop-wallet-55","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-connect-over-tor","content":"**URL:** your `.onion` address. &#x2A;*Port:** `50002`. &#x2A;*SSL:** on."},"433":{"id":"/docs/bitcoin/desktop-wallet-56","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-connect-over-tor","content":"Test. Sparrow's bundled Tor client handles the routing, you\ndon't need to run Tor on the laptop separately, as long as the\nURL ends in `.onion`."},"434":{"id":"/docs/bitcoin/desktop-wallet-57","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"Sparrow occasionally reaches outside your wallet: exchange rate\nfeeds, CoinJoin coordinators, block broadcasts through public APIs.\nBy default those go over clearnet and leak your laptop's public IP\nto whoever runs the other end."},"435":{"id":"/docs/bitcoin/desktop-wallet-58","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"If you're connecting to your node over a `.onion` already, Sparrow's\nbuilt-in Tor proxy covers all of that automatically. Done."},"436":{"id":"/docs/bitcoin/desktop-wallet-59","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"If you're connecting over the LAN (`raspibolt.local` or IP), tell\nSparrow to route external traffic through Tor running on your laptop:"},"437":{"id":"/docs/bitcoin/desktop-wallet-60","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"Install and start Tor on the computer:"},"438":{"id":"/docs/bitcoin/desktop-wallet-61","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"macOS: `brew install tor && brew services start tor` (SOCKS\non port 9050), or run Tor Browser (SOCKS on port 9150)."},"439":{"id":"/docs/bitcoin/desktop-wallet-62","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"Linux: `sudo apt install tor && sudo systemctl enable --now tor`\n(port 9050)."},"440":{"id":"/docs/bitcoin/desktop-wallet-63","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"Windows: install the Tor Browser or the Tor Expert Bundle; see\nPrivacy for the specifics."},"441":{"id":"/docs/bitcoin/desktop-wallet-64","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"In **Preferences → Server**, toggle **Use Proxy** on."},"442":{"id":"/docs/bitcoin/desktop-wallet-65","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"**Proxy URL:** `127.0.0.1`. &#x2A;*Port:** `9050` (daemon) or `9150`\n(Tor Browser)."},"443":{"id":"/docs/bitcoin/desktop-wallet-66","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#optional-tor-proxy-for-external-services","content":"Test. The secondary icon at bottom-right now reads \"External\nTor proxy enabled\"."},"444":{"id":"/docs/bitcoin/desktop-wallet-67","page_id":"/docs/bitcoin/desktop-wallet","tags":[],"type":"text","url":"/docs/bitcoin/desktop-wallet#updating-sparrow","content":"Sparrow checks for updates on launch and tells you when a new\nversion is out. Download from the releases page,\nverify the signature the same way you did at install, and replace\nthe installed version. The wallet files live in your user profile\nand survive any reinstall."},"445":{"id":"/docs/bitcoin/electrum-server","page_id":"/docs/bitcoin/electrum-server","type":"page","content":"Electrum server","breadcrumbs":["Docs","Bitcoin"],"tags":[],"url":"/docs/bitcoin/electrum-server"},"446":{"id":"/docs/bitcoin/electrum-server-0","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server","content":"Build Electrs from source, index the blockchain for Electrum-protocol wallets, wrap the raw TCP port in TLS with stunnel so Sparrow, Electrum, and hardware wallets can connect privately."},"447":{"id":"/docs/bitcoin/electrum-server-1","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#what-youll-do","content":"What you'll do"},"448":{"id":"/docs/bitcoin/electrum-server-2","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#build-dependencies","content":"Build dependencies"},"449":{"id":"/docs/bitcoin/electrum-server-3","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"Build Electrs from source"},"450":{"id":"/docs/bitcoin/electrum-server-4","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#service-user-and-data-directory","content":"Service user and data directory"},"451":{"id":"/docs/bitcoin/electrum-server-5","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#configuration","content":"Configuration"},"452":{"id":"/docs/bitcoin/electrum-server-6","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#systemd-unit","content":"Systemd unit"},"453":{"id":"/docs/bitcoin/electrum-server-7","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#tls-on-the-lan-with-stunnel","content":"TLS on the LAN with stunnel"},"454":{"id":"/docs/bitcoin/electrum-server-8","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#install-stunnel","content":"Install stunnel"},"455":{"id":"/docs/bitcoin/electrum-server-9","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#mint-a-self-signed-certificate","content":"Mint a self-signed certificate"},"456":{"id":"/docs/bitcoin/electrum-server-10","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#configure-stunnel","content":"Configure stunnel"},"457":{"id":"/docs/bitcoin/electrum-server-11","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#remote-access-over-tor-optional","content":"Remote access over Tor (optional)"},"458":{"id":"/docs/bitcoin/electrum-server-12","page_id":"/docs/bitcoin/electrum-server","type":"heading","tags":[],"url":"/docs/bitcoin/electrum-server#updating-electrs-later","content":"Updating Electrs later"},"459":{"id":"/docs/bitcoin/electrum-server-13","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server","content":"Your own Bitcoin Core is great at answering questions about blocks.\nIt's lousy at answering \"what's the balance of this address?\",\nbecause doing that means walking the entire chain every time.\nElectrs bridges the gap: it\nreads blocks from Bitcoin Core, builds an index keyed by address and\nscript, and serves answers on the Electrum protocol that desktop\nwallets like Sparrow, the BitBoxApp, Electrum, or Specter already\nspeak."},"460":{"id":"/docs/bitcoin/electrum-server-14","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server","content":"This is why running Electrs next to your node matters for privacy.\nWithout it, a wallet querying \"public\" Electrum servers tells\nstrangers exactly which addresses belong to you. With Electrs local,\nthe query never leaves the Pi."},"461":{"id":"/docs/bitcoin/electrum-server-15","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#what-youll-do","content":"Install Rust so you can build Electrs, the project doesn't ship\nprebuilt binaries for ARM."},"462":{"id":"/docs/bitcoin/electrum-server-16","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#what-youll-do","content":"Compile and install `electrs` 0.11.1."},"463":{"id":"/docs/bitcoin/electrum-server-17","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#what-youll-do","content":"Put it behind **stunnel** for TLS on the LAN."},"464":{"id":"/docs/bitcoin/electrum-server-18","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#what-youll-do","content":"Wire it up as a systemd service so it starts on boot and stays up."},"465":{"id":"/docs/bitcoin/electrum-server-19","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#what-youll-do","content":"Hands-on setup is about 30 minutes. The slow part comes after: once\n`electrs` starts, it reads the whole chain from `bitcoind` and builds\nits own address index. On a Pi 5 with NVMe that's roughly **8 to 12\nhours**; on a Pi 4 with USB SSD it can stretch past a day. The Pi\nwill feel sluggish while it runs, disk I/O is the bottleneck.\nNothing to babysit, check back the next day. Make sure Bitcoin Core\nis fully synced (`verificationprogress` at 1.0) before you start,\notherwise `electrs` will happily index a moving target and thrash."},"466":{"id":"/docs/bitcoin/electrum-server-20","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#what-youll-do","content":"Earlier versions of this guide used NGINX's stream module to wrap\nElectrum's plain-TCP protocol in TLS. In v4, HTTP services get\nCaddy (you'll see that in the next page), but the Electrum protocol\nisn't HTTP, it's JSON-RPC over a raw TCP socket. `stunnel` is the\ntime-tested, one-config-file tool for exactly that job."},"467":{"id":"/docs/bitcoin/electrum-server-21","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-dependencies","content":"Electrs is written in Rust and links against `clang` and `cmake` for\nits native dependencies (mostly RocksDB). Install them once:"},"468":{"id":"/docs/bitcoin/electrum-server-22","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-dependencies","content":"Using Debian's packaged `cargo` avoids the extra step of installing\n`rustup` just for this one crate. The tradeoff is a slightly older\nRust toolchain, still current enough for Electrs 0.11.1."},"469":{"id":"/docs/bitcoin/electrum-server-23","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"No binaries, no shortcuts: you build from a signed tag. That's the\nonly way to know the thing running on your node matches what the\nmaintainer, Roman Zeyde, actually\nreleased."},"470":{"id":"/docs/bitcoin/electrum-server-24","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"As `admin`, clone the repo at a specific tag:"},"471":{"id":"/docs/bitcoin/electrum-server-25","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"Verify the release tag. Starting with v0.11.1 Roman signs tags\nwith SSH instead of PGP; he publishes the signing key in a\ndedicated repo whose `README.md`\nis itself PGP-signed by his old GPG key, binding the transition."},"472":{"id":"/docs/bitcoin/electrum-server-26","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"Register his SSH signing key as a trusted signer for `git` and\npoint git's SSH-signature verification at that file:"},"473":{"id":"/docs/bitcoin/electrum-server-27","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"Expected output:"},"474":{"id":"/docs/bitcoin/electrum-server-28","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"The fingerprint `SHA256:GifMn7F2swVKyn6MewbQHrYCs4i/bPK7gnwxhuPz/YA`\nis what matters; compare it against what you see in your terminal\nand against the key published in Roman's\nkeys repo."},"475":{"id":"/docs/bitcoin/electrum-server-29","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"Build it. On a Pi 5 this takes somewhere between 30 minutes and\nan hour; the Pi will work hard, and that's fine:"},"476":{"id":"/docs/bitcoin/electrum-server-30","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"Install the resulting binary to `/usr/local/bin`:"},"477":{"id":"/docs/bitcoin/electrum-server-31","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#build-electrs-from-source","content":"Expected output:"},"478":{"id":"/docs/bitcoin/electrum-server-32","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#service-user-and-data-directory","content":"Like `bitcoind`, Electrs runs as its own user with no shell password\nand a tidy data directory on the SSD."},"479":{"id":"/docs/bitcoin/electrum-server-33","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#service-user-and-data-directory","content":"The `bitcoin` group membership is what lets Electrs read\n`/data/bitcoin/.cookie` for RPC auth."},"480":{"id":"/docs/bitcoin/electrum-server-34","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configuration","content":"Switch to the `electrs` user and open a fresh config:"},"481":{"id":"/docs/bitcoin/electrum-server-35","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configuration","content":"Paste:"},"482":{"id":"/docs/bitcoin/electrum-server-36","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configuration","content":"Do a first dry run to make sure the config is sane and Electrs\ncan talk to Bitcoin Core. It'll immediately start indexing, that\nis expected and will take hours, but you only need to see the\nfirst few lines of progress before you cancel:"},"483":{"id":"/docs/bitcoin/electrum-server-37","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configuration","content":"Within a few seconds you should see lines like\n`serving Electrum RPC on 127.0.0.1:50001` and\n`indexing 2000 blocks: [1..2000]`. Good. Hit `Ctrl`-`C` and exit\nback to `admin`:"},"484":{"id":"/docs/bitcoin/electrum-server-38","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#systemd-unit","content":"As `admin`, create the unit file:"},"485":{"id":"/docs/bitcoin/electrum-server-39","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#systemd-unit","content":"Paste:"},"486":{"id":"/docs/bitcoin/electrum-server-40","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#systemd-unit","content":"Enable and start:"},"487":{"id":"/docs/bitcoin/electrum-server-41","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#systemd-unit","content":"Watch it index in real time (`Ctrl`-`C` to exit):"},"488":{"id":"/docs/bitcoin/electrum-server-42","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#systemd-unit","content":"The first index pass walks the entire chain and builds the address\nindex on disk. On a Pi 5 with an SSD plan on **eight to twelve\nhours**; on a Pi 4, closer to a day. Don't try to connect Sparrow\nuntil the log quiets down and Electrs reports a caught-up tip,\npointing a wallet at an Electrum server that's still indexing will\njust time out."},"489":{"id":"/docs/bitcoin/electrum-server-43","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#tls-on-the-lan-with-stunnel","content":"Sparrow and other wallets connect to Electrum servers over TLS on\nport 50002. Electrs itself serves plaintext on 50001, which is\nfine *inside* the Pi, but you want the network traffic encrypted\neven on your home LAN. `stunnel` is a tiny, purpose-built proxy that\nwraps a plain TCP socket in TLS and has been doing exactly that for\ntwo decades."},"490":{"id":"/docs/bitcoin/electrum-server-44","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#mint-a-self-signed-certificate","content":"stunnel doesn't do automatic CA issuance the way Caddy does for HTTP.\nYou generate a self-signed certificate once and point the config at\nit. This takes a single command:"},"491":{"id":"/docs/bitcoin/electrum-server-45","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#mint-a-self-signed-certificate","content":"Ten-year validity is fine for a LAN certificate. Wallets will warn\nonce that the certificate isn't from a public CA, you accept it,\nand they remember it from then on."},"492":{"id":"/docs/bitcoin/electrum-server-46","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configure-stunnel","content":"Create the service config:"},"493":{"id":"/docs/bitcoin/electrum-server-47","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configure-stunnel","content":"Paste:"},"494":{"id":"/docs/bitcoin/electrum-server-48","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configure-stunnel","content":"Enable and start:"},"495":{"id":"/docs/bitcoin/electrum-server-49","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configure-stunnel","content":"Open the firewall for Electrum over TLS:"},"496":{"id":"/docs/bitcoin/electrum-server-50","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configure-stunnel","content":"Wallets will flag the certificate the first time, that's expected.\nYou accept it manually once (Sparrow does this well) or pin the\ncertificate fingerprint in the wallet config. Getting a public-CA\ncertificate would require a real domain name and DNS setup that most\nhome networks don't have. Internal CA plus first-use trust is the\nsane default here."},"497":{"id":"/docs/bitcoin/electrum-server-51","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#configure-stunnel","content":"**Main takeaway:** Electrs is indexing on `:50001`, stunnel wraps it\nin TLS on `:50002`, and the firewall lets LAN wallets in. The next\npage points Sparrow at it."},"498":{"id":"/docs/bitcoin/electrum-server-52","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#remote-access-over-tor-optional","content":"You can reach your Electrum server from outside the home network by\nexposing it as a Tor hidden service. The wallet will need Tor\nrunning locally too."},"499":{"id":"/docs/bitcoin/electrum-server-53","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#remote-access-over-tor-optional","content":"Add a stanza to `/etc/tor/torrc`:"},"500":{"id":"/docs/bitcoin/electrum-server-54","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#remote-access-over-tor-optional","content":"Reload Tor and read the generated `.onion` address:"},"501":{"id":"/docs/bitcoin/electrum-server-55","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#remote-access-over-tor-optional","content":"Save that `abcdefg...xyz.onion` in your password manager alongside\nthe one you may already have for SSH. The desktop-wallet page\nshows how to connect Sparrow to it."},"502":{"id":"/docs/bitcoin/electrum-server-56","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#updating-electrs-later","content":"Upgrades follow the same pattern as the first build: check the\nrelease notes,\nbump `0.11.1` in `lib/versions.ts`, then:"},"503":{"id":"/docs/bitcoin/electrum-server-57","page_id":"/docs/bitcoin/electrum-server","tags":[],"type":"text","url":"/docs/bitcoin/electrum-server#updating-electrs-later","content":"Keep the old binary around until the new one has served traffic\nfor a few hours, rolling back is as simple as copying\n`electrs.old` back on top."},"504":{"id":"/docs/bitcoin","page_id":"/docs/bitcoin","type":"page","content":"Overview","breadcrumbs":["Docs","Bitcoin"],"tags":[],"url":"/docs/bitcoin"},"505":{"id":"/docs/bitcoin-0","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin","content":"Install Bitcoin Core, Electrs, and a block explorer, then point a desktop wallet at your own node."},"506":{"id":"/docs/bitcoin-1","page_id":"/docs/bitcoin","type":"heading","tags":[],"url":"/docs/bitcoin#prerequisites","content":"Prerequisites"},"507":{"id":"/docs/bitcoin-2","page_id":"/docs/bitcoin","type":"heading","tags":[],"url":"/docs/bitcoin#about-the-time-commitment","content":"About the time commitment"},"508":{"id":"/docs/bitcoin-3","page_id":"/docs/bitcoin","type":"heading","tags":[],"url":"/docs/bitcoin#pages-in-this-section","content":"Pages in this section"},"509":{"id":"/docs/bitcoin-4","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin","content":"With the Pi hardened and Tor humming along, the fun part starts.\nYou'll turn this neat little box into a first-class citizen of the\nBitcoin network, a node that validates every block back to the\ngenesis block, indexes every transaction for your own software and\nhardware wallets, and serves a private block explorer you never have\nto trust a third party for again."},"510":{"id":"/docs/bitcoin-5","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin","content":"By the time you finish this section, you'll have:"},"511":{"id":"/docs/bitcoin-6","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin","content":"**Bitcoin Core 30.2** running as a systemd\nservice, syncing the full blockchain, routing outbound through Tor."},"512":{"id":"/docs/bitcoin-7","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin","content":"**Electrs 0.11.1** indexing the chain for your desktop\nwallet, no more leaking addresses to public Electrum servers."},"513":{"id":"/docs/bitcoin-8","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin","content":"**BTC RPC Explorer** giving you a private web UI for blocks,\ntransactions, mempool, and fee estimates."},"514":{"id":"/docs/bitcoin-9","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin","content":"**Sparrow Wallet** on your laptop, talking to your own Electrum\nserver over TLS, ready to drive a hardware wallet."},"515":{"id":"/docs/bitcoin-10","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#prerequisites","content":"You've finished the Raspberry Pi section. The\nPi is on the network, SSH is locked to keys, `ufw` and `fail2ban`\nare on watch, and the Tor daemon is listening on its control port\nready for Bitcoin Core to plug in."},"516":{"id":"/docs/bitcoin-11","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#prerequisites","content":"If you want the big picture first, Architecture\nshows how Bitcoin Core, Electrs, and the block explorer fit together\nwith the rest of the stack."},"517":{"id":"/docs/bitcoin-12","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#about-the-time-commitment","content":"The install commands themselves take an afternoon. The blockchain\nsync is the long pole: on a Pi 5 with a decent SSD, the initial block\ndownload runs about two to five days, and Electrs then spends another\nhalf day to a day indexing on top of that. Neither step needs\nbabysitting, kick it off, glance at the log once a day, and come\nback when it's done."},"518":{"id":"/docs/bitcoin-13","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#pages-in-this-section","content":"Bitcoin client, install Bitcoin\nCore 30.2, verify the release, tune the config\nfor a Pi 5, start syncing."},"519":{"id":"/docs/bitcoin-14","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#pages-in-this-section","content":"Electrum server, compile\nElectrs 0.11.1, index the chain, put Caddy in front\nof it for TLS on the LAN."},"520":{"id":"/docs/bitcoin-15","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#pages-in-this-section","content":"Blockchain explorer, install\nBTC RPC Explorer on Node.js 22, proxy it through Caddy, view your\nown chain."},"521":{"id":"/docs/bitcoin-16","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#pages-in-this-section","content":"Desktop wallet, point Sparrow\n(or an alternative) at your Electrum server, drive a hardware\nwallet, label UTXOs, take coin control seriously."},"522":{"id":"/docs/bitcoin-17","page_id":"/docs/bitcoin","tags":[],"type":"text","url":"/docs/bitcoin#pages-in-this-section","content":"When the dust settles, head to the Lightning\nsection to turn this node into a Lightning node as well."},"523":{"id":"/docs/bonus","page_id":"/docs/bonus","type":"page","content":"Bonus","breadcrumbs":["Docs","Bonus"],"tags":[],"url":"/docs/bonus"},"524":{"id":"/docs/bonus-0","page_id":"/docs/bonus","tags":[],"type":"text","url":"/docs/bonus","content":"Optional guides for extra tooling, alternative software, and niche setups that complement the main RaspiBolt."},"525":{"id":"/docs/bonus-1","page_id":"/docs/bonus","type":"heading","tags":[],"url":"/docs/bonus#whats-in-this-section","content":"What's in this section"},"526":{"id":"/docs/bonus-2","page_id":"/docs/bonus","tags":[],"type":"text","url":"/docs/bonus","content":"The bonus section collects everything that isn't part of the core\nBitcoin and Lightning node setup, alternative wallets, additional\ndashboards, privacy add-ons, quality-of-life tweaks, and experiments.\nThese guides are optional: the main path works without any of them."},"527":{"id":"/docs/bonus-3","page_id":"/docs/bonus","tags":[],"type":"text","url":"/docs/bonus","content":"The bonus pages are still being rewritten for v4. Each page links to\nthe v3 source while we work through the backlog."},"528":{"id":"/docs/bonus-4","page_id":"/docs/bonus","tags":[],"type":"text","url":"/docs/bonus#whats-in-this-section","content":"Extra explorers, wallets, alternative Electrum servers, privacy tools, and testnet setup."},"529":{"id":"/docs/bonus-5","page_id":"/docs/bonus","tags":[],"type":"text","url":"/docs/bonus#whats-in-this-section","content":"Dashboards, liquidity tools, fee managers, alternative Lightning implementations, and wallets."},"530":{"id":"/docs/bonus-6","page_id":"/docs/bonus","tags":[],"type":"text","url":"/docs/bonus#whats-in-this-section","content":"System overviews, aliases, UPS integration, alternative hardware, and hardware-wallet SSH."},"531":{"id":"/docs/raspberry-pi","page_id":"/docs/raspberry-pi","type":"page","content":"Overview","breadcrumbs":["Docs","Hardware"],"tags":[],"url":"/docs/raspberry-pi"},"532":{"id":"/docs/raspberry-pi-0","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"From bare hardware to a hardened Bitcoin-ready computer."},"533":{"id":"/docs/raspberry-pi-1","page_id":"/docs/raspberry-pi","type":"heading","tags":[],"url":"/docs/raspberry-pi#assumptions","content":"Assumptions"},"534":{"id":"/docs/raspberry-pi-2","page_id":"/docs/raspberry-pi","type":"heading","tags":[],"url":"/docs/raspberry-pi#pages-in-this-section","content":"Pages in this section"},"535":{"id":"/docs/raspberry-pi-3","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"Where does a full node actually start? Right here: a bare Raspberry\nPi, an empty SSD, and an afternoon. By the end of this section\nyou'll have a hardened, network-ready computer that's ready to carry\na Bitcoin node, no screen, no keyboard, just a well-behaved little\nbox in the corner."},"536":{"id":"/docs/raspberry-pi-4","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"By the time you finish, you'll have:"},"537":{"id":"/docs/raspberry-pi-5","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"A **Raspberry Pi 5** (or Pi 4) booting Debian 13 \"Trixie\" straight\nfrom a 2 TB USB SSD."},"538":{"id":"/docs/raspberry-pi-6","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"Remote access over SSH using an **Ed25519 key**, with password\nlogins firmly switched off."},"539":{"id":"/docs/raspberry-pi-7","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"A running firewall (`ufw`) and brute-force protection (`fail2ban`)."},"540":{"id":"/docs/raspberry-pi-8","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"The **Tor** daemon active, with its control port ready for\nBitcoin Core and Lightning to route their peer traffic privately."},"541":{"id":"/docs/raspberry-pi-9","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"**Tailscale** installed so you can SSH into the Pi from anywhere,\nno router ports opened, no dynamic DNS."},"542":{"id":"/docs/raspberry-pi-10","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi","content":"Bluetooth and unused Wi-Fi radios switched off."},"543":{"id":"/docs/raspberry-pi-11","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#assumptions","content":"You have the hardware listed in Preparations:\na Pi 5 (8 GB), a 27W USB-C PD power supply, a 2 TB USB 3 SSD, and\nactive cooling."},"544":{"id":"/docs/raspberry-pi-12","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#assumptions","content":"You have a regular computer (macOS, Linux, or Windows 10/11) to\nflash the SSD and open SSH sessions from."},"545":{"id":"/docs/raspberry-pi-13","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#assumptions","content":"You have roughly a **couple of hours** for a first pass, not\ncounting the time `apt upgrade` spends doing its thing in the\nbackground."},"546":{"id":"/docs/raspberry-pi-14","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#pages-in-this-section","content":"Preparations, hardware list, passwords,\nhome-network hygiene."},"547":{"id":"/docs/raspberry-pi-15","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#pages-in-this-section","content":"Operating system, flash Raspberry Pi OS\nLite (64-bit) to the SSD and boot the Pi."},"548":{"id":"/docs/raspberry-pi-16","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#pages-in-this-section","content":"Remote access, connect over SSH, learn the\ncommand-line basics, set up an SSH key."},"549":{"id":"/docs/raspberry-pi-17","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#pages-in-this-section","content":"System configuration, update\npackages, verify SSD speed, create the data directory, check swap."},"550":{"id":"/docs/raspberry-pi-18","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#pages-in-this-section","content":"Security, disable password SSH, harden sshd,\nfirewall, fail2ban, open-files limit, disable Bluetooth/Wi-Fi."},"551":{"id":"/docs/raspberry-pi-19","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#pages-in-this-section","content":"Privacy, install Tor for Bitcoin and Lightning\npeer traffic, then add Tailscale for remote SSH access."},"552":{"id":"/docs/raspberry-pi-20","page_id":"/docs/raspberry-pi","tags":[],"type":"text","url":"/docs/raspberry-pi#pages-in-this-section","content":"When this section is in the bag, move on to the\nBitcoin section. This is why the upcoming\nchapters can focus on Bitcoin and Lightning itself rather than\ndoubling back to patch the plumbing."},"553":{"id":"/docs/raspberry-pi/operating-system","page_id":"/docs/raspberry-pi/operating-system","type":"page","content":"Operating system","breadcrumbs":["Docs","Hardware"],"tags":[],"url":"/docs/raspberry-pi/operating-system"},"554":{"id":"/docs/raspberry-pi/operating-system-0","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system","content":"Write Raspberry Pi OS to the SSD, pre-configure it, and boot the Pi for the first time."},"555":{"id":"/docs/raspberry-pi/operating-system-1","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#which-operating-system","content":"Which operating system?"},"556":{"id":"/docs/raspberry-pi/operating-system-2","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#install-raspberry-pi-imager","content":"Install Raspberry Pi Imager"},"557":{"id":"/docs/raspberry-pi/operating-system-3","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#flash-the-operating-system","content":"Flash the operating system"},"558":{"id":"/docs/raspberry-pi/operating-system-4","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"Pre-configure the system"},"559":{"id":"/docs/raspberry-pi/operating-system-5","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#write-to-the-ssd","content":"Write to the SSD"},"560":{"id":"/docs/raspberry-pi/operating-system-6","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#boot-your-pi","content":"Boot your Pi"},"561":{"id":"/docs/raspberry-pi/operating-system-7","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#is-it-alive","content":"Is it alive?"},"562":{"id":"/docs/raspberry-pi/operating-system-8","page_id":"/docs/raspberry-pi/operating-system","type":"heading","tags":[],"url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"If your Pi refuses to boot from USB"},"563":{"id":"/docs/raspberry-pi/operating-system-9","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system","content":"Time to breathe life into the hardware. You'll write Raspberry Pi OS\nto the SSD on your regular computer, pre-configure it with a user and\nSSH access, and boot the Pi for the very first time, all without\never connecting a screen or keyboard to it."},"564":{"id":"/docs/raspberry-pi/operating-system-10","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#which-operating-system","content":"Which flavour of Linux belongs on a node? You'll use &#x2A;*Raspberry Pi\nOS Lite (64-bit)**: a minimal, headless Debian-based system with no\ndesktop environment. No wasted RAM on things you'll never see."},"565":{"id":"/docs/raspberry-pi/operating-system-11","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#which-operating-system","content":"It's based on &#x2A;*Debian 13 \"Trixie\"**, the current Debian stable\nrelease (since August 2025) and the same OS that powers a good slice\nof the internet's servers. Trixie gets security updates well into\nthe 2030s. Because the guide only uses standard Debian commands,\neverything you learn here also applies to other Debian machines."},"566":{"id":"/docs/raspberry-pi/operating-system-12","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#which-operating-system","content":"In the Imager you'll also see Raspberry Pi OS based on Debian 12\n\"Bookworm\" under the **Legacy** menu. Don't pick it, this guide\ntargets Trixie."},"567":{"id":"/docs/raspberry-pi/operating-system-13","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#install-raspberry-pi-imager","content":"The official Raspberry Pi Imager\nhandles the whole \"write OS to SSD\" dance with a friendly interface.\nThis guide was written against **v1.9.4**; any recent version works."},"568":{"id":"/docs/raspberry-pi/operating-system-14","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#install-raspberry-pi-imager","content":"Download the Imager for your OS (macOS, Windows, or Linux), install\nit, and launch it."},"569":{"id":"/docs/raspberry-pi/operating-system-15","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#flash-the-operating-system","content":"Plug the external SSD into your regular computer, then walk through\nthe Imager one step at a time."},"570":{"id":"/docs/raspberry-pi/operating-system-16","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#flash-the-operating-system","content":"In the &#x2A;*\"Raspberry Pi device\"*&#x2A; section, click &#x2A;*\"Choose device\"**\nand select your model, **Raspberry Pi 5** (or Pi 4)."},"571":{"id":"/docs/raspberry-pi/operating-system-17","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#flash-the-operating-system","content":"In the &#x2A;*\"Operating system\"*&#x2A; section, click &#x2A;*\"Choose OS\"*&#x2A; and\nselect &#x2A;*\"Raspberry Pi OS (64-bit)\"** right at the top of the list."},"572":{"id":"/docs/raspberry-pi/operating-system-18","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#flash-the-operating-system","content":"In the &#x2A;*\"Storage\"*&#x2A; section, click &#x2A;*\"Choose storage\"** and pick\nyour external SSD. Double-check, this drive will be wiped."},"573":{"id":"/docs/raspberry-pi/operating-system-19","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#flash-the-operating-system","content":"Click &#x2A;*\"NEXT\"*&#x2A;. When the Imager asks about &#x2A;*\"Use OS\ncustomisation\"*&#x2A;, click &#x2A;*\"EDIT SETTINGS\"**."},"574":{"id":"/docs/raspberry-pi/operating-system-20","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"This is the clever part: you can set the hostname, create your user,\nhand over your Wi-Fi credentials, and enable SSH **before** the Pi\neven boots once. That's what \"headless\" means in practice. Sounds\nlike black magic, but it's really just a small config file that the\nPi reads on first boot."},"575":{"id":"/docs/raspberry-pi/operating-system-21","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"On the &#x2A;*\"General\"** tab:"},"576":{"id":"/docs/raspberry-pi/operating-system-22","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"**Set hostname**, choose a name for your node, for example\n`raspibolt`. The Pi then answers to `raspibolt.local` from any\ndevice on the same network that speaks mDNS (most do)."},"577":{"id":"/docs/raspberry-pi/operating-system-23","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"**Set username and password**, turn this on, enter the username\n`admin`, and use your &#x2A;*password \\[A]**. Every command in this\nguide assumes the user is called `admin`."},"578":{"id":"/docs/raspberry-pi/operating-system-24","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"**Configure wifi**, only if you plan to connect over Wi-Fi.\nEnter the SSID and password, and set the two-letter country code\n(e.g. `US`, `DE`, `CH`). Leave this blank if you'll use Ethernet,\nwhich, if you're sitting near the router, is what you want."},"579":{"id":"/docs/raspberry-pi/operating-system-25","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"**Set locale settings**, pick your timezone and keyboard layout."},"580":{"id":"/docs/raspberry-pi/operating-system-26","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"On the &#x2A;*\"Services\"** tab:"},"581":{"id":"/docs/raspberry-pi/operating-system-27","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"**Enable SSH*&#x2A;, check the box and select &#x2A;*\"Use password\nauthentication\"**. This lets you reach the Pi over the network\nin the next section."},"582":{"id":"/docs/raspberry-pi/operating-system-28","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"On the &#x2A;*\"Options\"** tab:"},"583":{"id":"/docs/raspberry-pi/operating-system-29","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"Optional: uncheck &#x2A;*\"Enable telemetry\"** if you'd rather not send\nusage data to the Raspberry Pi Foundation."},"584":{"id":"/docs/raspberry-pi/operating-system-30","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#pre-configure-the-system","content":"Click &#x2A;*\"SAVE\"** to lock in the settings."},"585":{"id":"/docs/raspberry-pi/operating-system-31","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#write-to-the-ssd","content":"Back on the main screen, the Imager asks &#x2A;*\"Use OS customisation?\"*&#x2A;.\nClick &#x2A;*\"YES\"*&#x2A;. Read the final warning, confirm you picked the\nright drive, and click &#x2A;*\"YES\"** again to start writing."},"586":{"id":"/docs/raspberry-pi/operating-system-32","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#write-to-the-ssd","content":"The Imager writes the operating system and verifies every byte. When\nit reports &#x2A;*\"Success\"**, safely eject the SSD."},"587":{"id":"/docs/raspberry-pi/operating-system-33","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#boot-your-pi","content":"Plug the SSD into a **USB 3 port** on the Pi (the blue ones,\nUSB 2 ports are not fast enough)."},"588":{"id":"/docs/raspberry-pi/operating-system-34","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#boot-your-pi","content":"If you skipped the Wi-Fi settings, connect an Ethernet cable."},"589":{"id":"/docs/raspberry-pi/operating-system-35","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#boot-your-pi","content":"Power the Pi on by plugging in the USB-C power supply."},"590":{"id":"/docs/raspberry-pi/operating-system-36","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#boot-your-pi","content":"The Pi boots straight from the SSD. No microSD card needed."},"591":{"id":"/docs/raspberry-pi/operating-system-37","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#boot-your-pi","content":"Every Pi 5 ships with USB boot enabled out of the box. The old\nbootloader-on-microSD ritual is gone."},"592":{"id":"/docs/raspberry-pi/operating-system-38","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#boot-your-pi","content":"On a **Pi 4**, USB boot is enabled by default on any board shipped\nafter September 2020. If your Pi 4 is older and refuses to boot\nfrom the SSD, see the section below on fixing the bootloader."},"593":{"id":"/docs/raspberry-pi/operating-system-39","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#is-it-alive","content":"Keep an eye on the two LEDs on the Pi:"},"594":{"id":"/docs/raspberry-pi/operating-system-40","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#is-it-alive","content":"A solid **red** LED means the Pi is powered."},"595":{"id":"/docs/raspberry-pi/operating-system-41","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#is-it-alive","content":"A flickering **green** LED means the SSD is being read, exactly\nwhat you want. Boot takes 20-40 seconds on an SSD."},"596":{"id":"/docs/raspberry-pi/operating-system-42","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#is-it-alive","content":"A **solid green** LED that never flickers usually means the Pi\ndidn't find anything bootable and is sitting there waiting."},"597":{"id":"/docs/raspberry-pi/operating-system-43","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#is-it-alive","content":"If the green LED is flickering, you're in business. Move on to the\nnext page. Done."},"598":{"id":"/docs/raspberry-pi/operating-system-44","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Some older Pi 4 boards shipped with a bootloader that can't boot\nfrom USB. You fix this once, using a microSD card, and then the Pi\nwill happily boot from USB forever after."},"599":{"id":"/docs/raspberry-pi/operating-system-45","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Grab a microSD card (any size, the data is erased)."},"600":{"id":"/docs/raspberry-pi/operating-system-46","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"On your regular computer, launch Raspberry Pi Imager."},"601":{"id":"/docs/raspberry-pi/operating-system-47","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Click &#x2A;*\"Choose device\"** and pick your Pi model."},"602":{"id":"/docs/raspberry-pi/operating-system-48","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Click &#x2A;*\"Choose OS\"*&#x2A; → &#x2A;*\"Misc utility images\"*&#x2A; →\n&#x2A;*\"Bootloader\"*&#x2A; → pick your Pi family → &#x2A;*\"USB Boot\"**."},"603":{"id":"/docs/raspberry-pi/operating-system-49","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Click &#x2A;*\"Choose storage\"** and select the microSD card."},"604":{"id":"/docs/raspberry-pi/operating-system-50","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Click &#x2A;*\"NEXT\"*&#x2A; → &#x2A;*\"YES\"** to write the bootloader."},"605":{"id":"/docs/raspberry-pi/operating-system-51","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Boot the Pi from this microSD card. When the green LED blinks\nsteadily, disconnect power, remove the microSD, and reboot with\nthe SSD attached."},"606":{"id":"/docs/raspberry-pi/operating-system-52","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"Your Pi should now boot from the SSD."},"607":{"id":"/docs/raspberry-pi/operating-system-53","page_id":"/docs/raspberry-pi/operating-system","tags":[],"type":"text","url":"/docs/raspberry-pi/operating-system#if-your-pi-refuses-to-boot-from-usb","content":"If USB boot still doesn't work after reflashing, the drive or\nenclosure is most likely the problem, see\nTroubleshooting for known-good chipsets\nand workarounds."},"608":{"id":"/docs/raspberry-pi/preparations","page_id":"/docs/raspberry-pi/preparations","type":"page","content":"Preparations","breadcrumbs":["Docs","Hardware"],"tags":[],"url":"/docs/raspberry-pi/preparations"},"609":{"id":"/docs/raspberry-pi/preparations-0","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations","content":"Get the hardware sorted and pick your passwords before you boot anything."},"610":{"id":"/docs/raspberry-pi/preparations-1","page_id":"/docs/raspberry-pi/preparations","type":"heading","tags":[],"url":"/docs/raspberry-pi/preparations#what-you-need","content":"What you need"},"611":{"id":"/docs/raspberry-pi/preparations-2","page_id":"/docs/raspberry-pi/preparations","type":"heading","tags":[],"url":"/docs/raspberry-pi/preparations#why-2-tb","content":"Why 2 TB?"},"612":{"id":"/docs/raspberry-pi/preparations-3","page_id":"/docs/raspberry-pi/preparations","type":"heading","tags":[],"url":"/docs/raspberry-pi/preparations#other-platforms","content":"Other platforms"},"613":{"id":"/docs/raspberry-pi/preparations-4","page_id":"/docs/raspberry-pi/preparations","type":"heading","tags":[],"url":"/docs/raspberry-pi/preparations#passwords","content":"Passwords"},"614":{"id":"/docs/raspberry-pi/preparations-5","page_id":"/docs/raspberry-pi/preparations","type":"heading","tags":[],"url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"Secure your home network"},"615":{"id":"/docs/raspberry-pi/preparations-6","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations","content":"Before you boot a single terminal, get the hardware sorted and pick\nyour passwords. Five minutes of prep saves an hour of hunting for a\nmissing cable later, and keeps you from inventing a password on the\nfly when you should be paying attention."},"616":{"id":"/docs/raspberry-pi/preparations-7","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"You're building on the **Raspberry Pi 5**, a credit-card-sized\ncomputer that draws about the power of a phone charger and still has\nenough muscle to run a full Bitcoin and Lightning node. It's the\nprimary target throughout this guide. The older Pi 4 works too, and\ngets its own callouts wherever the story differs."},"617":{"id":"/docs/raspberry-pi/preparations-8","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Part"},"618":{"id":"/docs/raspberry-pi/preparations-9","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Recommendation"},"619":{"id":"/docs/raspberry-pi/preparations-10","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Computer"},"620":{"id":"/docs/raspberry-pi/preparations-11","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Raspberry Pi 5, 8 GB RAM"},"621":{"id":"/docs/raspberry-pi/preparations-12","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Power supply"},"622":{"id":"/docs/raspberry-pi/preparations-13","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Official **27W USB-C PD** power supply"},"623":{"id":"/docs/raspberry-pi/preparations-14","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Storage"},"624":{"id":"/docs/raspberry-pi/preparations-15","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"**2 TB USB 3 SSD** in an external enclosure"},"625":{"id":"/docs/raspberry-pi/preparations-16","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Cooling"},"626":{"id":"/docs/raspberry-pi/preparations-17","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Active cooler (official or compatible)"},"627":{"id":"/docs/raspberry-pi/preparations-18","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Cable"},"628":{"id":"/docs/raspberry-pi/preparations-19","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Short USB 3 cable rated for SSDs (often included with the enclosure)"},"629":{"id":"/docs/raspberry-pi/preparations-20","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Case"},"630":{"id":"/docs/raspberry-pi/preparations-21","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"Optional, but recommended for protection"},"631":{"id":"/docs/raspberry-pi/preparations-22","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#what-you-need","content":"No microSD card? Correct, you'll boot the operating system directly\nfrom the SSD. It's faster, more reliable, and one fewer component to\nlose."},"632":{"id":"/docs/raspberry-pi/preparations-23","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#why-2-tb","content":"The Bitcoin blockchain is a big, growing thing. As of 2026 it's\naround **700 GB**, adding roughly 7 GB every month. On top of that,\nthe Electrs index (which makes your wallet fast) needs another\n\\~70 GB, and the operating system eats \\~20 GB for itself and logs. A\n1 TB drive is basically full on day one. Give yourself the 2 TB of\nbreathing room."},"633":{"id":"/docs/raspberry-pi/preparations-24","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#why-2-tb","content":"Not all USB-to-SATA enclosures play well with the Pi. The ones\nbased on **JMicron** chipsets (JMS578, JMS580, JMS583 and friends)\nare a long-running source of reset loops, dropped connections, and\nfailed boots."},"634":{"id":"/docs/raspberry-pi/preparations-25","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#why-2-tb","content":"Enclosures built around the **ASMedia ASM1153E** chipset are the\nsafe bet. If you're buying new, pick one that advertises it on the\nproduct page."},"635":{"id":"/docs/raspberry-pi/preparations-26","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#why-2-tb","content":"The Pi 5 also supports NVMe SSDs through the official &#x2A;*M.2 HAT+**.\nNVMe builds index faster and syncs the blockchain noticeably\nquicker, at the cost of more hardware and a little more assembly.\nA good USB 3 SATA SSD is perfectly fine for everything in this\nguide, NVMe is a nice-to-have, not a requirement."},"636":{"id":"/docs/raspberry-pi/preparations-27","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#why-2-tb","content":"The Pi 4 still gets you there, just slower, initial block download\nand Electrs indexing take noticeably longer. Use the **4 GB model\nor larger** (8 GB preferred) and the **official 15W USB-C** power\nsupply. Wherever the Pi 4 needs a different step, this guide\nflags it."},"637":{"id":"/docs/raspberry-pi/preparations-28","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#other-platforms","content":"Not a Pi person? The guide sticks to standard Debian, which means it\nalso runs happily on other Debian 13 machines, a cloud server, a VM\non your laptop, an Intel NUC, or another ARM board. The shell\ncommands are identical; only the hardware chapters differ."},"638":{"id":"/docs/raspberry-pi/preparations-29","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"You'll need several passwords during the build. Pick them **up\nfront** and write them all down in one place, so you're not inventing\none under pressure two hours in. This is why a few quiet minutes\nnow beat frantic guessing later. Every password should be **unique\nand at least 12 characters long**, and avoid exotic special\ncharacters, spaces, or quote marks (`'` or `\"`), some config files\ndon't like them."},"639":{"id":"/docs/raspberry-pi/preparations-30","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Label"},"640":{"id":"/docs/raspberry-pi/preparations-31","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Purpose"},"641":{"id":"/docs/raspberry-pi/preparations-32","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"`[ A ]`"},"642":{"id":"/docs/raspberry-pi/preparations-33","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Master user password (`admin` login)"},"643":{"id":"/docs/raspberry-pi/preparations-34","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"`[ B ]`"},"644":{"id":"/docs/raspberry-pi/preparations-35","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Bitcoin Core RPC password"},"645":{"id":"/docs/raspberry-pi/preparations-36","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"`[ C ]`"},"646":{"id":"/docs/raspberry-pi/preparations-37","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Lightning wallet password (LND)"},"647":{"id":"/docs/raspberry-pi/preparations-38","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"`[ D ]`"},"648":{"id":"/docs/raspberry-pi/preparations-39","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Block explorer password (optional)"},"649":{"id":"/docs/raspberry-pi/preparations-40","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"`[ E ]`"},"650":{"id":"/docs/raspberry-pi/preparations-41","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Ride The Lightning (RTL) web app password"},"651":{"id":"/docs/raspberry-pi/preparations-42","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"Store the list in an open-source password manager like\nKeePassXC, free, offline, no cloud\ninvolved. When the build is done, keep any paper notes out of\nsight."},"652":{"id":"/docs/raspberry-pi/preparations-43","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#passwords","content":"If you need inspiration for strong but memorable passwords, the\nfamous xkcd \"Password Strength\" comic is\nfunnier than this guide and still correct."},"653":{"id":"/docs/raspberry-pi/preparations-44","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"Your node is only as private as the network you reach it from. It's\nworth spending a few minutes on home hygiene before you start:"},"654":{"id":"/docs/raspberry-pi/preparations-45","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"Change the default admin password on your router (most brand-new\nrouters still ship with `admin` / `admin`, truly)."},"655":{"id":"/docs/raspberry-pi/preparations-46","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"Install the latest firmware update for the router."},"656":{"id":"/docs/raspberry-pi/preparations-47","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"Disable WPS and UPnP if the router lets you."},"657":{"id":"/docs/raspberry-pi/preparations-48","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"Use WPA2 or WPA3 for Wi-Fi, with a strong password."},"658":{"id":"/docs/raspberry-pi/preparations-49","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"Keep your phone and laptop patched and protected with a screen\nlock."},"659":{"id":"/docs/raspberry-pi/preparations-50","page_id":"/docs/raspberry-pi/preparations","tags":[],"type":"text","url":"/docs/raspberry-pi/preparations#secure-your-home-network","content":"For a full walk-through, read\nHow to Secure Your Home Network Against Threats\nand apply as many points as your router supports."},"660":{"id":"/docs/raspberry-pi/privacy","page_id":"/docs/raspberry-pi/privacy","type":"page","content":"Privacy","breadcrumbs":["Docs","Hardware"],"tags":[],"url":"/docs/raspberry-pi/privacy"},"661":{"id":"/docs/raspberry-pi/privacy-0","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy","content":"Route Bitcoin and Lightning traffic through Tor, then add Tailscale for painless remote access."},"662":{"id":"/docs/raspberry-pi/privacy-1","page_id":"/docs/raspberry-pi/privacy","type":"heading","tags":[],"url":"/docs/raspberry-pi/privacy#why-tor","content":"Why Tor"},"663":{"id":"/docs/raspberry-pi/privacy-2","page_id":"/docs/raspberry-pi/privacy","type":"heading","tags":[],"url":"/docs/raspberry-pi/privacy#install-tor","content":"Install Tor"},"664":{"id":"/docs/raspberry-pi/privacy-3","page_id":"/docs/raspberry-pi/privacy","type":"heading","tags":[],"url":"/docs/raspberry-pi/privacy#configure-tor","content":"Configure Tor"},"665":{"id":"/docs/raspberry-pi/privacy-4","page_id":"/docs/raspberry-pi/privacy","type":"heading","tags":[],"url":"/docs/raspberry-pi/privacy#ssh-from-anywhere-with-tailscale","content":"SSH from anywhere with Tailscale"},"666":{"id":"/docs/raspberry-pi/privacy-5","page_id":"/docs/raspberry-pi/privacy","type":"heading","tags":[],"url":"/docs/raspberry-pi/privacy#install-tailscale-on-the-pi","content":"Install Tailscale on the Pi"},"667":{"id":"/docs/raspberry-pi/privacy-6","page_id":"/docs/raspberry-pi/privacy","type":"heading","tags":[],"url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"Connect from your computer or phone"},"668":{"id":"/docs/raspberry-pi/privacy-7","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy","content":"Why hand the whole world your home IP address along with every\nBitcoin transaction your node broadcasts? You don't have to. Install\nand configure **Tor** so Bitcoin Core and Lightning can route their\npeer-to-peer traffic through the Tor network. Your IP stays off the\npublic Bitcoin and Lightning peer maps."},"669":{"id":"/docs/raspberry-pi/privacy-8","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy","content":"Then add **Tailscale**, a mesh VPN, so you can SSH into the Pi\nfrom anywhere without opening a single port on your router."},"670":{"id":"/docs/raspberry-pi/privacy-9","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#why-tor","content":"Running a node at home makes you a first-class peer on the Bitcoin\nand Lightning networks. That's the good news. The flip side is that\nwithout privacy work, it also broadcasts to the world that somebody\nat **your** IP address runs a Lightning node, and services like\niplocation.net happily turn that IP\ninto a rough physical location."},"671":{"id":"/docs/raspberry-pi/privacy-10","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#why-tor","content":"**Tor** (The Onion Router) is a free, open-source anonymity network\nmaintained by the Tor Project. Traffic\nis encrypted in layers and bounced through a handful of volunteer\nrelays, so no single hop sees both where it came from and where it's\ngoing. Bitcoin Core and LND will plug into it later in the guide."},"672":{"id":"/docs/raspberry-pi/privacy-11","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Add the Tor Project's official repository rather than leaning on the\nDebian package, this way you get current Tor releases straight from\nupstream."},"673":{"id":"/docs/raspberry-pi/privacy-12","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Fetch the Tor Project's signing key, dearmor it into a keyring\nfile, and clean up the original:"},"674":{"id":"/docs/raspberry-pi/privacy-13","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Tell apt about the new repository. Modern Debian prefers the\n**deb822** format, looks unfamiliar compared to the old one-line\n`sources.list` syntax, but it's just one file, one stanza,\nclearly signed:"},"675":{"id":"/docs/raspberry-pi/privacy-14","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Paste, save, and exit:"},"676":{"id":"/docs/raspberry-pi/privacy-15","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Install `tor` along with the Tor Project's keyring package (which\nkeeps the signing key up to date automatically):"},"677":{"id":"/docs/raspberry-pi/privacy-16","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Confirm Tor landed:"},"678":{"id":"/docs/raspberry-pi/privacy-17","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Expected output (version number will drift):"},"679":{"id":"/docs/raspberry-pi/privacy-18","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tor","content":"Older Tor install guides want you to `apt install apt-transport-https`\nfirst. On Trixie that package is a no-op, HTTPS support is built\ninto `apt` itself. Skip it with a clear conscience."},"680":{"id":"/docs/raspberry-pi/privacy-19","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"Bitcoin Core will talk to the Tor daemon through Tor's **control\nport**. Enable that port and allow cookie-based authentication so\nlocal services can use it without a password."},"681":{"id":"/docs/raspberry-pi/privacy-20","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"Open the Tor configuration:"},"682":{"id":"/docs/raspberry-pi/privacy-21","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"Uncomment or add these lines:"},"683":{"id":"/docs/raspberry-pi/privacy-22","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"Reload Tor so the changes take effect:"},"684":{"id":"/docs/raspberry-pi/privacy-23","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"Verify Tor is listening on both the SOCKS port (9050) and the\ncontrol port (9051):"},"685":{"id":"/docs/raspberry-pi/privacy-24","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"Expected output:"},"686":{"id":"/docs/raspberry-pi/privacy-25","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"Optional, tail Tor's live log to watch it at work:"},"687":{"id":"/docs/raspberry-pi/privacy-26","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"But not every byte of traffic is routed through Tor yet. What\nyou've done is open the door, applications that opt in (Bitcoin\nCore, LND, and friends later in the guide) can now use it."},"688":{"id":"/docs/raspberry-pi/privacy-27","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#configure-tor","content":"**Main takeaway:** Tor is running and ready; the apps that matter\nwill plug into it later in the guide."},"689":{"id":"/docs/raspberry-pi/privacy-28","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#ssh-from-anywhere-with-tailscale","content":"Getting into the Pi from the sofa is easy, it's on your LAN. Getting\ninto it from a café, a friend's house, or another country is\ntraditionally a pain: port forwarding, dynamic DNS, firewall\njuggling, and a stable home IP you probably don't have."},"690":{"id":"/docs/raspberry-pi/privacy-29","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#ssh-from-anywhere-with-tailscale","content":"Tailscale sidesteps the whole mess. It\nbuilds a small, private mesh VPN between **your** devices using\nWireGuard. The Pi gets a stable private address (`100.x.y.z`) that\nonly devices you've authorised can reach. Your router does nothing.\nYour ISP sees encrypted traffic to a few discovery servers. Anyone\non the public internet sees nothing."},"691":{"id":"/docs/raspberry-pi/privacy-30","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#ssh-from-anywhere-with-tailscale","content":"Tailscale's control plane is a proprietary SaaS. The data path is\nstill direct device-to-device WireGuard, Tailscale never sees your\ntraffic, but device authorisation runs through their servers. If\nthat doesn't fit your threat model,\nHeadscale is a fully open\nsource, self-hosted control plane that speaks the same protocol.\nThe Pi-side setup below works unchanged; you just point\n`tailscale up` at your Headscale server with `--login-server`.\nRunning Headscale itself is its own project, beyond this guide."},"692":{"id":"/docs/raspberry-pi/privacy-31","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tailscale-on-the-pi","content":"Add Tailscale's apt repository, install the client, and start it:"},"693":{"id":"/docs/raspberry-pi/privacy-32","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tailscale-on-the-pi","content":"Bring the Pi onto your tailnet. This prints a one-time URL,\nopen it on any device, log in (a personal Tailscale account is\nfree for up to 100 devices), and authorise the Pi:"},"694":{"id":"/docs/raspberry-pi/privacy-33","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tailscale-on-the-pi","content":"Confirm it's connected and read its tailnet IP:"},"695":{"id":"/docs/raspberry-pi/privacy-34","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tailscale-on-the-pi","content":"You'll see a stable `100.x.y.z` address. That address never\nchanges as long as the Pi stays on your tailnet, that's the\nwhole point."},"696":{"id":"/docs/raspberry-pi/privacy-35","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#install-tailscale-on-the-pi","content":"In the Tailscale admin console,\nenable **MagicDNS**. Your Pi then becomes reachable as\n`raspibolt.<your-tailnet>.ts.net` from any other device on the\ntailnet, no more memorising `100.x.y.z`. You can also give it a\ncustom short name from the same console."},"697":{"id":"/docs/raspberry-pi/privacy-36","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"Install Tailscale on whatever device you want to SSH **from**:"},"698":{"id":"/docs/raspberry-pi/privacy-37","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"**macOS:** `brew install tailscale && sudo tailscale up`, or the Mac App Store app."},"699":{"id":"/docs/raspberry-pi/privacy-38","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"**Linux:** the same apt commands above, swapping `trixie` for your distribution's codename. Or the one-liner `curl -fsSL https://tailscale.com/install.sh | sh`."},"700":{"id":"/docs/raspberry-pi/privacy-39","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"**Windows:** installer from tailscale.com/download."},"701":{"id":"/docs/raspberry-pi/privacy-40","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"**iOS / Android:** Tailscale in the App Store or Play Store."},"702":{"id":"/docs/raspberry-pi/privacy-41","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"Log in with the same account. Once both devices are on the tailnet,\nSSH to the Pi's tailnet IP (or MagicDNS name if you enabled it):"},"703":{"id":"/docs/raspberry-pi/privacy-42","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"Same SSH key, same hardened `sshd` config, now reachable from\nanywhere without opening a port."},"704":{"id":"/docs/raspberry-pi/privacy-43","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"Tailscale makes remote SSH so frictionless that the old \"open\nport 22 to the internet\" pattern stops being necessary. Keep your\nufw rule scoped to the LAN (`192.168.0.0/24` or similar), the\ntailnet interface bypasses ufw by default on a fresh install, so\nTailscale devices can still reach the Pi without the firewall\nbeing in the way."},"705":{"id":"/docs/raspberry-pi/privacy-44","page_id":"/docs/raspberry-pi/privacy","tags":[],"type":"text","url":"/docs/raspberry-pi/privacy#connect-from-your-computer-or-phone","content":"**Main takeaway:** Tor keeps Bitcoin and Lightning peer traffic\nprivate. Tailscale keeps your own remote access private and\nconvenient. Different jobs, different tools, you want both."},"706":{"id":"/docs/raspberry-pi/remote-access","page_id":"/docs/raspberry-pi/remote-access","type":"page","content":"Remote access","breadcrumbs":["Docs","Hardware"],"tags":[],"url":"/docs/raspberry-pi/remote-access"},"707":{"id":"/docs/raspberry-pi/remote-access-0","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access","content":"SSH to the Pi from macOS, Linux, or Windows OpenSSH. Command-line basics for first-timers. Generate and install an ed25519 key for passwordless login."},"708":{"id":"/docs/raspberry-pi/remote-access-1","page_id":"/docs/raspberry-pi/remote-access","type":"heading","tags":[],"url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"Find your Pi on the network"},"709":{"id":"/docs/raspberry-pi/remote-access-2","page_id":"/docs/raspberry-pi/remote-access","type":"heading","tags":[],"url":"/docs/raspberry-pi/remote-access#connect-via-ssh","content":"Connect via SSH"},"710":{"id":"/docs/raspberry-pi/remote-access-3","page_id":"/docs/raspberry-pi/remote-access","type":"heading","tags":[],"url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"Working on the command line"},"711":{"id":"/docs/raspberry-pi/remote-access-4","page_id":"/docs/raspberry-pi/remote-access","type":"heading","tags":[],"url":"/docs/raspberry-pi/remote-access#set-up-an-ssh-key","content":"Set up an SSH key"},"712":{"id":"/docs/raspberry-pi/remote-access-5","page_id":"/docs/raspberry-pi/remote-access","type":"heading","tags":[],"url":"/docs/raspberry-pi/remote-access#generate-the-key-pair","content":"Generate the key pair"},"713":{"id":"/docs/raspberry-pi/remote-access-6","page_id":"/docs/raspberry-pi/remote-access","type":"heading","tags":[],"url":"/docs/raspberry-pi/remote-access#copy-the-public-key-to-the-pi","content":"Copy the public key to the Pi"},"714":{"id":"/docs/raspberry-pi/remote-access-7","page_id":"/docs/raspberry-pi/remote-access","type":"heading","tags":[],"url":"/docs/raspberry-pi/remote-access#verify-the-key-works","content":"Verify the key works"},"715":{"id":"/docs/raspberry-pi/remote-access-8","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access","content":"Your Pi is running somewhere in the corner of the room, with no\nscreen and no keyboard. Time to connect to it from the comfort of\nyour regular computer using **SSH**, the Secure Shell, and learn\njust enough command-line to get through the rest of the guide\nwithout cursing the terminal."},"716":{"id":"/docs/raspberry-pi/remote-access-9","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"Where did your Pi end up on the local network? Give it a minute or\ntwo after the first boot, it's expanding the filesystem, generating\nSSH keys, and settling in."},"717":{"id":"/docs/raspberry-pi/remote-access-10","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"Open a terminal on your regular computer:"},"718":{"id":"/docs/raspberry-pi/remote-access-11","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"**macOS**: open **Terminal** from `Applications → Utilities`."},"719":{"id":"/docs/raspberry-pi/remote-access-12","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"**Linux**: use whichever terminal your distribution ships."},"720":{"id":"/docs/raspberry-pi/remote-access-13","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"**Windows**: open **Windows Terminal** or **PowerShell** from the\nStart menu."},"721":{"id":"/docs/raspberry-pi/remote-access-14","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"Try to reach the Pi by its hostname. Press `Ctrl`-`C` to stop:"},"722":{"id":"/docs/raspberry-pi/remote-access-15","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"You should see replies like `64 bytes from raspibolt.local (192.168.0.20)...`.\nThat IP address on the right (yours will differ) is where the Pi\nactually lives on your network."},"723":{"id":"/docs/raspberry-pi/remote-access-16","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#find-your-pi-on-the-network","content":"If `ping` fails, mDNS (the `.local` name-discovery magic) isn't\nworking on your network, a common quirk of some routers. The\nofficial Raspberry Pi guide\nshows how to find the IP directly on your router or with `nmap`.\nOnce you have the IP (say `192.168.0.20`), use it wherever this guide\nsays `raspibolt.local`."},"724":{"id":"/docs/raspberry-pi/remote-access-17","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#connect-via-ssh","content":"SSH is built into every current macOS, Linux, and Windows, no extra\nclient to install. Connect with:"},"725":{"id":"/docs/raspberry-pi/remote-access-18","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#connect-via-ssh","content":"Log in with &#x2A;*password \\[A]**, the one you set in the Imager."},"726":{"id":"/docs/raspberry-pi/remote-access-19","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#connect-via-ssh","content":"The first time you connect, SSH asks you to confirm the Pi's host key\nfingerprint. Type `yes` and press Enter. You're now inside the Pi."},"727":{"id":"/docs/raspberry-pi/remote-access-20","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#connect-via-ssh","content":"PuTTY is no longer necessary on Windows 10 or 11, the built-in\nOpenSSH client does everything this guide needs. If you already\nhave a PuTTY setup you love, it still works, but the commands here\nassume the native `ssh`."},"728":{"id":"/docs/raspberry-pi/remote-access-21","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"You're going to spend a lot of time at this prompt, so a few basics\nare worth a minute of your life:"},"729":{"id":"/docs/raspberry-pi/remote-access-22","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"**Tab completion**, press `Tab` to auto-complete commands,\nfilenames, and paths. Press it twice to see all matches. Once you\nstart using it you'll wonder how you ever lived without it."},"730":{"id":"/docs/raspberry-pi/remote-access-23","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"**Command history**, press the up and down arrow keys to cycle\nthrough previous commands. No need to retype anything."},"731":{"id":"/docs/raspberry-pi/remote-access-24","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"**Admin privileges with `sudo`**, the `admin` user can't change\nsystem files directly, which is deliberate. Prefix any such\ncommand with `sudo` (\"superuser do\"), and the Pi asks for your\npassword before running it. Service users like `bitcoin` (coming\nlater) have no `sudo` at all, that's intentional too."},"732":{"id":"/docs/raspberry-pi/remote-access-25","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"**Editing files with nano**, this guide uses the `nano` editor.\nTo save: press `Ctrl`-`O`, confirm the filename, press Enter.\nTo exit: press `Ctrl`-`X`. That's it. (If you already love `vim`\nor `emacs`, use those; nano is just the friendliest default.)"},"733":{"id":"/docs/raspberry-pi/remote-access-26","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"**Copy and paste**, in most terminals, highlight with the mouse\nto copy and press `Ctrl`-`Shift`-`V` to paste. On macOS Terminal,\nuse `Cmd`-`C` / `Cmd`-`V`. In Windows Terminal, right-click to\npaste at the cursor."},"734":{"id":"/docs/raspberry-pi/remote-access-27","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#working-on-the-command-line","content":"A selective reference of useful Linux commands lives in the\nFAQ, bookmark it."},"735":{"id":"/docs/raspberry-pi/remote-access-28","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#set-up-an-ssh-key","content":"Passwords work, but an **SSH key pair** is better in every way:\nit's safer (a stolen password is useless without the key file), and\nit's less typing (no password prompts on every login). This is why\nthe next few minutes of setup pay off every single time you log in.\nThe plan is to set up the key here, then disable password logins\nentirely in the Security section."},"736":{"id":"/docs/raspberry-pi/remote-access-29","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#set-up-an-ssh-key","content":"Key pairs sound like a cryptography homework assignment, but the\nworkflow is mechanical: run one command, copy one file. This guide\nuses **Ed25519** keys. They're short, fast, and well supported by\nevery current SSH client and server."},"737":{"id":"/docs/raspberry-pi/remote-access-30","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#generate-the-key-pair","content":"On your **regular computer** (not the Pi), run:"},"738":{"id":"/docs/raspberry-pi/remote-access-31","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#generate-the-key-pair","content":"Accept the default file location by pressing Enter, and pick a\nstrong passphrase when prompted. The passphrase protects the key\nfile on disk, you'll type it once per session, and your OS\nkeychain can remember it after that."},"739":{"id":"/docs/raspberry-pi/remote-access-32","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#generate-the-key-pair","content":"Two new files appear in `~/.ssh/` (on Windows:\n`%USERPROFILE%\\.ssh\\`):"},"740":{"id":"/docs/raspberry-pi/remote-access-33","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#generate-the-key-pair","content":"`id_ed25519`, the **private** key. This stays on your computer\nand nowhere else. Ever."},"741":{"id":"/docs/raspberry-pi/remote-access-34","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#generate-the-key-pair","content":"`id_ed25519.pub`, the **public** key. This is what you hand to\nthe Pi (and any other server you want to reach)."},"742":{"id":"/docs/raspberry-pi/remote-access-35","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#generate-the-key-pair","content":"If you've been using a working `id_rsa` for years, it still works,\nRSA 4096-bit keys are fine. Anything smaller than 4096-bit RSA is\nnot. New keys should be Ed25519."},"743":{"id":"/docs/raspberry-pi/remote-access-36","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#copy-the-public-key-to-the-pi","content":"On **macOS or Linux**, one command does it:"},"744":{"id":"/docs/raspberry-pi/remote-access-37","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#copy-the-public-key-to-the-pi","content":"Enter &#x2A;*password \\[A]** one last time. `ssh-copy-id` appends your\npublic key to `~/.ssh/authorized_keys` on the Pi, creating the\ndirectory and file if needed."},"745":{"id":"/docs/raspberry-pi/remote-access-38","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#copy-the-public-key-to-the-pi","content":"On **Windows**, `ssh-copy-id` isn't shipped by default. Run this\none-liner in PowerShell instead, it pipes your public key over SSH\nand sets the right permissions on the Pi:"},"746":{"id":"/docs/raspberry-pi/remote-access-39","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#verify-the-key-works","content":"Open a fresh terminal and connect again:"},"747":{"id":"/docs/raspberry-pi/remote-access-40","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#verify-the-key-works","content":"You should be logged in &#x2A;*without being asked for password \\[A]**,\nonly the passphrase that unlocks your local key file. If that's\nwhat happened, the key is working."},"748":{"id":"/docs/raspberry-pi/remote-access-41","page_id":"/docs/raspberry-pi/remote-access","tags":[],"type":"text","url":"/docs/raspberry-pi/remote-access#verify-the-key-works","content":"Password logins on the Pi are still enabled at this point; you'll\nturn them off in the next chapter on Security."},"749":{"id":"/docs/raspberry-pi/security","page_id":"/docs/raspberry-pi/security","type":"page","content":"Security","breadcrumbs":["Docs","Hardware"],"tags":[],"url":"/docs/raspberry-pi/security"},"750":{"id":"/docs/raspberry-pi/security-0","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security","content":"SSH hardening with ed25519 keys, UFW firewall rules, fail2ban brute-force protection on systemd, open-files limit, disable Bluetooth and Wi-Fi radios."},"751":{"id":"/docs/raspberry-pi/security-1","page_id":"/docs/raspberry-pi/security","type":"heading","tags":[],"url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"Disable password SSH login"},"752":{"id":"/docs/raspberry-pi/security-2","page_id":"/docs/raspberry-pi/security","type":"heading","tags":[],"url":"/docs/raspberry-pi/security#firewall-ufw","content":"Firewall (ufw)"},"753":{"id":"/docs/raspberry-pi/security-3","page_id":"/docs/raspberry-pi/security","type":"heading","tags":[],"url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"Brute-force protection (fail2ban)"},"754":{"id":"/docs/raspberry-pi/security-4","page_id":"/docs/raspberry-pi/security","type":"heading","tags":[],"url":"/docs/raspberry-pi/security#raise-the-open-files-limit","content":"Raise the open-files limit"},"755":{"id":"/docs/raspberry-pi/security-5","page_id":"/docs/raspberry-pi/security","type":"heading","tags":[],"url":"/docs/raspberry-pi/security#disable-bluetooth-and-wi-fi","content":"Disable Bluetooth and Wi-Fi"},"756":{"id":"/docs/raspberry-pi/security-6","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security","content":"What does \"hardening\" actually mean for a little computer in your\nliving room? Closing doors, mostly. Your Pi is about to be reachable\nfrom the internet, and before you take that step you'll want to\nlock SSH down to keys only, tighten the SSH daemon, turn on a\nfirewall, add brute-force protection, bump the open-files limit, and\nswitch off the radios you don't need. Nothing exotic, all standard\nDebian hygiene, applied in the right order."},"757":{"id":"/docs/raspberry-pi/security-7","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"You already set up an Ed25519 key in\nRemote access. Time to turn\noff password logins entirely so only someone holding the private key\ncan reach the Pi."},"758":{"id":"/docs/raspberry-pi/security-8","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"Before touching anything, open a **second** SSH session in a new\nterminal window and confirm it logs in **without** asking for\npassword \\[A]. Leave that second session open while you make the\nchanges, if something goes sideways, you still have a working shell\nto undo it. Seriously. You don't want to learn this the hard way."},"759":{"id":"/docs/raspberry-pi/security-9","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"Instead of editing the main `sshd_config` (which gets rewritten\non package updates), drop a small override file into the\n`sshd_config.d/` directory, that's the modern Debian way:"},"760":{"id":"/docs/raspberry-pi/security-10","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"First time with `nano`? Paste the content, then press `Ctrl`-`O`\nto save, `Enter` to confirm the filename, and `Ctrl`-`X` to exit."},"761":{"id":"/docs/raspberry-pi/security-11","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"Paste the following. The cipher-suite lines look like alphabet\nsoup, but they're really just a curated list of modern\nalgorithms, copy them as-is and move on:"},"762":{"id":"/docs/raspberry-pi/security-12","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"Sanity-check the config before restarting the daemon, this\ncatches typos that would otherwise lock you out:"},"763":{"id":"/docs/raspberry-pi/security-13","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"No output means the file is valid."},"764":{"id":"/docs/raspberry-pi/security-14","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"Restart the SSH daemon and log out:"},"765":{"id":"/docs/raspberry-pi/security-15","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"Open a fresh SSH session. You should land in a shell using your\nkey; password \\[A] should no longer be accepted."},"766":{"id":"/docs/raspberry-pi/security-16","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"If you lose your private key, recovery means attaching a keyboard\nand screen to the Pi. Keep a copy of `~/.ssh/id_ed25519` somewhere\nsafe, an encrypted USB stick, or a password manager that supports\nfile attachments."},"767":{"id":"/docs/raspberry-pi/security-17","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-password-ssh-login","content":"**Main takeaway:** only your private key can reach the Pi over\nSSH now, passwords are off the table."},"768":{"id":"/docs/raspberry-pi/security-18","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"The **Uncomplicated Firewall** (`ufw`) is Debian's friendly front-end\nto `iptables`. For now it only needs to allow SSH, every service\nyou add later will open its own port when the time comes."},"769":{"id":"/docs/raspberry-pi/security-19","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"Install `ufw`:"},"770":{"id":"/docs/raspberry-pi/security-20","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"If you see `ERROR: Couldn't determine iptables version`, reboot\nthe Pi once after installing `ufw` and carry on."},"771":{"id":"/docs/raspberry-pi/security-21","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"Set default policies, allow SSH with rate limiting, turn off\nlogging, and bring the firewall up, all in one go:"},"772":{"id":"/docs/raspberry-pi/security-22","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"`ufw limit ssh` blocks any IP making six or more connection\nattempts within 30 seconds, a first layer of brute-force defence\non top of what `fail2ban` does below."},"773":{"id":"/docs/raspberry-pi/security-23","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"Make sure `ufw` comes up at boot, and check the active rules:"},"774":{"id":"/docs/raspberry-pi/security-24","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"Expected output:"},"775":{"id":"/docs/raspberry-pi/security-25","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"If you ever lock yourself out (wrong SSH port, busted config),\nattach a keyboard and screen to the Pi, log in locally, and fix the\nrules. Not fun, but always possible."},"776":{"id":"/docs/raspberry-pi/security-26","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#firewall-ufw","content":"**Main takeaway:** nothing reaches the Pi from the network except\nrate-limited SSH, every other port stays shut by default."},"777":{"id":"/docs/raspberry-pi/security-27","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"`fail2ban` is a watchful little daemon that tails the SSH log and\nbans IP addresses that rack up failed logins. On Trixie there's a\nwrinkle: `rsyslog` is no longer installed by default, so `fail2ban`\nhas to read authentication events straight from the systemd journal.\nSounds fiddly, but it's two extra pieces and you're done."},"778":{"id":"/docs/raspberry-pi/security-28","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"Install `fail2ban` and the Python bindings for the systemd journal:"},"779":{"id":"/docs/raspberry-pi/security-29","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"Create a local configuration that uses the journal backend:"},"780":{"id":"/docs/raspberry-pi/security-30","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"Paste:"},"781":{"id":"/docs/raspberry-pi/security-31","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"Restart `fail2ban` and confirm the SSH jail is running:"},"782":{"id":"/docs/raspberry-pi/security-32","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"Expected output:"},"783":{"id":"/docs/raspberry-pi/security-33","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"Stock Debian `fail2ban` assumes `rsyslog` is writing `/var/log/auth.log`.\nOn Trixie it isn't, skip the two changes above and `fail2ban` will\nrun happily, read an empty log, and ban precisely nobody."},"784":{"id":"/docs/raspberry-pi/security-34","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#brute-force-protection-fail2ban","content":"**Main takeaway:** any IP that fumbles five logins gets a\nten-minute timeout, automatically, in the background, forever."},"785":{"id":"/docs/raspberry-pi/security-35","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#raise-the-open-files-limit","content":"Under heavy load, or a deliberate flood, `bitcoind` and LND open a\nlot of TCP connections at once. The default file-handle limit is far\ntoo low for that and throws `too many open files` errors."},"786":{"id":"/docs/raspberry-pi/security-36","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#raise-the-open-files-limit","content":"Create `/etc/security/limits.d/90-limits.conf`:"},"787":{"id":"/docs/raspberry-pi/security-37","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#raise-the-open-files-limit","content":"Paste:"},"788":{"id":"/docs/raspberry-pi/security-38","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#raise-the-open-files-limit","content":"Make sure PAM actually applies those limits on login. Open each\nof these files and add a `pam_limits.so` line, right before any\ntrailing comment:"},"789":{"id":"/docs/raspberry-pi/security-39","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#raise-the-open-files-limit","content":"Add:"},"790":{"id":"/docs/raspberry-pi/security-40","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#raise-the-open-files-limit","content":"The new limits kick in at the next login."},"791":{"id":"/docs/raspberry-pi/security-41","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-bluetooth-and-wi-fi","content":"A node dedicated to Bitcoin has no use for Bluetooth, and if you're\nconnected over Ethernet, no use for Wi-Fi either. Turning off the\nradios you aren't using removes another slice of attack surface."},"792":{"id":"/docs/raspberry-pi/security-42","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-bluetooth-and-wi-fi","content":"Edit the firmware configuration:"},"793":{"id":"/docs/raspberry-pi/security-43","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-bluetooth-and-wi-fi","content":"Disable Bluetooth by adding this line at the end of the file:"},"794":{"id":"/docs/raspberry-pi/security-44","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-bluetooth-and-wi-fi","content":"If the Pi is connected by Ethernet cable, also disable Wi-Fi:"},"795":{"id":"/docs/raspberry-pi/security-45","page_id":"/docs/raspberry-pi/security","tags":[],"type":"text","url":"/docs/raspberry-pi/security#disable-bluetooth-and-wi-fi","content":"Save and exit. The radios stay off from the next reboot onward."},"796":{"id":"/docs/raspberry-pi/system-configuration","page_id":"/docs/raspberry-pi/system-configuration","type":"page","content":"System configuration","breadcrumbs":["Docs","Hardware"],"tags":[],"url":"/docs/raspberry-pi/system-configuration"},"797":{"id":"/docs/raspberry-pi/system-configuration-0","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration","content":"apt full-upgrade, verify SSD speed with hdparm, create /data directory and service-user symlinks, confirm zram swap is active on Trixie."},"798":{"id":"/docs/raspberry-pi/system-configuration-1","page_id":"/docs/raspberry-pi/system-configuration","type":"heading","tags":[],"url":"/docs/raspberry-pi/system-configuration#log-back-in","content":"Log back in"},"799":{"id":"/docs/raspberry-pi/system-configuration-2","page_id":"/docs/raspberry-pi/system-configuration","type":"heading","tags":[],"url":"/docs/raspberry-pi/system-configuration#system-update","content":"System update"},"800":{"id":"/docs/raspberry-pi/system-configuration-3","page_id":"/docs/raspberry-pi/system-configuration","type":"heading","tags":[],"url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"Check SSD performance"},"801":{"id":"/docs/raspberry-pi/system-configuration-4","page_id":"/docs/raspberry-pi/system-configuration","type":"heading","tags":[],"url":"/docs/raspberry-pi/system-configuration#data-directory","content":"Data directory"},"802":{"id":"/docs/raspberry-pi/system-configuration-5","page_id":"/docs/raspberry-pi/system-configuration","type":"heading","tags":[],"url":"/docs/raspberry-pi/system-configuration#swap","content":"Swap"},"803":{"id":"/docs/raspberry-pi/system-configuration-6","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration","content":"Fresh install, fresh habits. You'll patch the system, make sure the\nSSD is pulling its weight, carve out a tidy place for all the node\ndata to live, and confirm that swap is doing its job. Quick pages,\nall of it, but it's the groundwork the rest of the guide leans on."},"804":{"id":"/docs/raspberry-pi/system-configuration-7","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#log-back-in","content":"Open an SSH session to the Pi as the `admin` user:"},"805":{"id":"/docs/raspberry-pi/system-configuration-8","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#log-back-in","content":"To end a session at any time, type `exit`. And a quick reminder:\nanything that touches system files needs `sudo` in front of it\n(the Pi will ask for &#x2A;*password \\[A]** the first time each session)."},"806":{"id":"/docs/raspberry-pi/system-configuration-9","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#system-update","content":"Keeping the system patched is table stakes. Debian's `apt` package\nmanager handles OS updates and application upgrades in the same\ncommand."},"807":{"id":"/docs/raspberry-pi/system-configuration-10","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#system-update","content":"Set a default locale. This silences the noisy `LC_ALL: cannot\nchange locale` warnings that some tools throw when you SSH in from\na machine with a different language setting:"},"808":{"id":"/docs/raspberry-pi/system-configuration-11","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#system-update","content":"Refresh the package index and install every available upgrade in\none go:"},"809":{"id":"/docs/raspberry-pi/system-configuration-12","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#system-update","content":"Install `git`, you'll need it later to clone source code:"},"810":{"id":"/docs/raspberry-pi/system-configuration-13","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#system-update","content":"Run `sudo apt update && sudo apt full-upgrade` every few months to\npick up security fixes. Set a reminder if you're the forgetful type."},"811":{"id":"/docs/raspberry-pi/system-configuration-14","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"A fast SSD is non-negotiable. A slow drive drags the initial block\ndownload into the weekend and turns the Electrs index build into a\nslog. This is why it pays to benchmark now, before you've committed\na few hundred gigabytes of blockchain data to the wrong enclosure.\nThe Pi 5 handles USB 3 storage well, but some enclosures still\nunderperform, this is the moment to catch that."},"812":{"id":"/docs/raspberry-pi/system-configuration-15","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"Install `hdparm`, a classic disk benchmarking tool:"},"813":{"id":"/docs/raspberry-pi/system-configuration-16","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"Confirm your SSD shows up as `/dev/sda`:"},"814":{"id":"/docs/raspberry-pi/system-configuration-17","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"Measure raw read throughput:"},"815":{"id":"/docs/raspberry-pi/system-configuration-18","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"Expected output (your number will differ):"},"816":{"id":"/docs/raspberry-pi/system-configuration-19","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"Anything above **100 MB/s** is fine for a full node. If you see\nnumbers below 50 MB/s, the enclosure is probably falling back to UAS\nmode with a buggy driver, a well-known problem with certain chipsets\n(hello again, JMicron). The\nFix bad USB3 performance\nsection in Troubleshooting walks through disabling UAS for a specific\ndrive."},"817":{"id":"/docs/raspberry-pi/system-configuration-20","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#check-ssd-performance","content":"On NVMe the device is `/dev/nvme0n1`, not `/dev/sda`. You can skip\nthis check entirely, NVMe drives comfortably clear any throughput\nbar this guide sets."},"818":{"id":"/docs/raspberry-pi/system-configuration-21","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#data-directory","content":"Everything the node cares about, the blockchain, Lightning channel\nstate, backups, will live under `/data/`. Keeping it outside any\nuser's home directory makes permissions obvious and means you can\nmove it to a bigger drive later with nothing more than a mount."},"819":{"id":"/docs/raspberry-pi/system-configuration-22","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#data-directory","content":"Create it once, owned by `admin`:"},"820":{"id":"/docs/raspberry-pi/system-configuration-23","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#swap","content":"Swap is the safety net: when RAM fills up, the system offloads idle\npages to \"swap\" instead of crashing. Compressed swap held in RAM\nsounds like a contradiction, but that's exactly what zram is, and\nit works beautifully for a node. On Raspberry Pi OS Trixie this is\nhandled out of the box by the &#x2A;*`rpi-swap`** service, which uses\n**zram** rather than a file on the SSD. Clever, and already running."},"821":{"id":"/docs/raspberry-pi/system-configuration-24","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#swap","content":"But you do **not** need to install `dphys-swapfile` or edit\n`/etc/dphys-swapfile`. Old guides told you to; ignore them."},"822":{"id":"/docs/raspberry-pi/system-configuration-25","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#swap","content":"Verify that swap is active:"},"823":{"id":"/docs/raspberry-pi/system-configuration-26","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#swap","content":"You should see something like:"},"824":{"id":"/docs/raspberry-pi/system-configuration-27","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#swap","content":"On an 8 GB Pi 5, the default 2 GB zram swap is plenty."},"825":{"id":"/docs/raspberry-pi/system-configuration-28","page_id":"/docs/raspberry-pi/system-configuration","tags":[],"type":"text","url":"/docs/raspberry-pi/system-configuration#swap","content":"A swapfile on an SSD wears the flash with every heavy swap burst,\nand on a microSD card it's painfully slow. `zram` sidesteps both:\npages are compressed and kept in RAM, so an 8 GB Pi effectively gets\na little more memory without ever touching the disk."},"826":{"id":"/docs/lightning/channel-backup","page_id":"/docs/lightning/channel-backup","type":"page","content":"Channel backup","breadcrumbs":["Docs","Lightning"],"tags":[],"url":"/docs/lightning/channel-backup"},"827":{"id":"/docs/lightning/channel-backup-0","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup","content":"Automated off-Pi sync of channel.backup (SCB, static channel backup) via systemd.path and scp. Restore flow with lncli restorechanbackup if the SSD dies."},"828":{"id":"/docs/lightning/channel-backup-1","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"What the SCB actually does"},"829":{"id":"/docs/lightning/channel-backup-2","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#strategy","content":"Strategy"},"830":{"id":"/docs/lightning/channel-backup-3","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#set-up-the-ssh-key-for-lnd","content":"Set up the SSH key for lnd"},"831":{"id":"/docs/lightning/channel-backup-4","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#write-the-sync-script","content":"Write the sync script"},"832":{"id":"/docs/lightning/channel-backup-5","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#systemd-path--service","content":"systemd path + service"},"833":{"id":"/docs/lightning/channel-backup-6","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#test-it","content":"Test it"},"834":{"id":"/docs/lightning/channel-backup-7","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#restore-flow","content":"Restore flow"},"835":{"id":"/docs/lightning/channel-backup-8","page_id":"/docs/lightning/channel-backup","type":"heading","tags":[],"url":"/docs/lightning/channel-backup#close-channels-gracefully-when-you-can","content":"Close channels gracefully when you can"},"836":{"id":"/docs/lightning/channel-backup-9","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup","content":"The 24-word seed restores your on-chain wallet. It does **not**\nrestore your Lightning channels. For that you need the **Static\nChannel Backup**, a small file LND updates every time a channel\nstate changes, and the missing half of a complete recovery plan."},"837":{"id":"/docs/lightning/channel-backup-10","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup","content":"This page explains what the SCB can and can't do, walks you\nthrough an automated offsite sync, and covers the restore flow."},"838":{"id":"/docs/lightning/channel-backup-11","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"The Static Channel Backup (SCB) is a single file:\n`/data/lnd/data/chain/bitcoin/mainnet/channel.backup`. LND rewrites\nit every time a channel opens, closes, or changes state. It\ncontains enough information, each peer's pubkey, the channel\nfunding outpoint, the commit transaction, for a **new** LND\ninstance to know who to ask for funds back."},"839":{"id":"/docs/lightning/channel-backup-12","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"It does **not** re-open your channels. It does **not** give you\naccess to off-chain liquidity on a fresh node. What it does, on\nrestore, is send a request to every channel peer asking them to\nforce-close the channel at the latest state they know about. Your\nfunds then land in your on-chain wallet after the usual\ncommit-timeout."},"840":{"id":"/docs/lightning/channel-backup-13","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"The consequences matter:"},"841":{"id":"/docs/lightning/channel-backup-14","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"**Recovery depends on your peers being online and honest.** An\noffline peer means locked funds until they come back. A\nmalicious peer could, in principle, refuse."},"842":{"id":"/docs/lightning/channel-backup-15","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"**Your SCB must be current.** If the peer closes at a state\nnewer than the one in your SCB, LND sees a state it doesn't\nrecognise and refuses to claim. You'll still get a force-close\nfrom the peer, just the slow path, not the SCB-accelerated one."},"843":{"id":"/docs/lightning/channel-backup-16","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"**Never use the SCB on a node that is still running the same\nchannels elsewhere.** Restoring triggers force-closes; doing\nthat against a node that thinks the channels are fine gets your\nbalances punished to the peer. Treat the SCB like a one-shot\nrecovery tool."},"844":{"id":"/docs/lightning/channel-backup-17","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#what-the-scb-actually-does","content":"A channel backup that lives on the same SSD as LND is no backup\nat all, the scenario it's meant to survive is the SSD dying. The\nwhole point of this page is to get a copy of `channel.backup` onto\na machine that isn't the Pi."},"845":{"id":"/docs/lightning/channel-backup-18","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#strategy","content":"This guide sets up one thing: a **systemd path unit** that watches\n`channel.backup&#x60; for changes and an **`scp` script** that ships\nthe file to a remote host on every update. No polling, no cron,\nno extra long-running process, systemd notices the file change,\nfires the service, the service copies the file, and goes away."},"846":{"id":"/docs/lightning/channel-backup-19","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#strategy","content":"You need:"},"847":{"id":"/docs/lightning/channel-backup-20","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#strategy","content":"A **remote host** you trust, another machine on your LAN, a\nVPS you own, an always-on box at a friend's place, or a cheap\nhome NAS. Anywhere `ssh` can reach."},"848":{"id":"/docs/lightning/channel-backup-21","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#strategy","content":"An **SSH key** on the Pi that you've added to\n`~/.ssh/authorized_keys` on the remote host."},"849":{"id":"/docs/lightning/channel-backup-22","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#strategy","content":"The rest of this page assumes the remote host is at\n`backup@10.0.0.50` with the SCB going into\n`/home/backup/raspibolt-scb/`. Substitute your own host, user,\nand path."},"850":{"id":"/docs/lightning/channel-backup-23","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#set-up-the-ssh-key-for-lnd","content":"The sync has to run as the `lnd` user, that's the only account\nthat can read `channel.backup`. So the SSH key lives in\n`/home/lnd/.ssh/`."},"851":{"id":"/docs/lightning/channel-backup-24","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#set-up-the-ssh-key-for-lnd","content":"As `admin`, become `lnd` and generate a key (no passphrase,\na passphrase would defeat unattended sync):"},"852":{"id":"/docs/lightning/channel-backup-25","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#set-up-the-ssh-key-for-lnd","content":"Copy the public key into the remote host's\n`authorized_keys`. On the **remote host**, run:"},"853":{"id":"/docs/lightning/channel-backup-26","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#set-up-the-ssh-key-for-lnd","content":"Back on the **Pi** as `lnd`, do the first connection by hand\nso the remote host's fingerprint lands in `known_hosts`:"},"854":{"id":"/docs/lightning/channel-backup-27","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#set-up-the-ssh-key-for-lnd","content":"Accept the fingerprint. You should see `ok`. Exit the `lnd`\nsession:"},"855":{"id":"/docs/lightning/channel-backup-28","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#write-the-sync-script","content":"As `admin`, create the script:"},"856":{"id":"/docs/lightning/channel-backup-29","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#write-the-sync-script","content":"Paste:"},"857":{"id":"/docs/lightning/channel-backup-30","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#write-the-sync-script","content":"Make it executable:"},"858":{"id":"/docs/lightning/channel-backup-31","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#systemd-path--service","content":"A **path unit** watches a file. When the file changes, systemd\nactivates a matching **service unit**. The two go together."},"859":{"id":"/docs/lightning/channel-backup-32","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#systemd-path--service","content":"Create the service unit. This runs the sync script once and\nexits:"},"860":{"id":"/docs/lightning/channel-backup-33","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#systemd-path--service","content":"Paste:"},"861":{"id":"/docs/lightning/channel-backup-34","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#systemd-path--service","content":"Create the path unit that triggers it:"},"862":{"id":"/docs/lightning/channel-backup-35","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#systemd-path--service","content":"Paste:"},"863":{"id":"/docs/lightning/channel-backup-36","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#systemd-path--service","content":"Enable and start the **path** unit (not the service, systemd\nactivates the service for you on file change):"},"864":{"id":"/docs/lightning/channel-backup-37","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#test-it","content":"As `admin`, follow the service journal in one SSH session:"},"865":{"id":"/docs/lightning/channel-backup-38","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#test-it","content":"In a second session, touch the backup file to simulate a\nchange. `touch` updates the mtime, which is enough to fire\n`PathChanged`:"},"866":{"id":"/docs/lightning/channel-backup-39","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#test-it","content":"In the first session you should see\n`Started Sync LND channel.backup to offsite host`, the scp\nlines, and a clean exit."},"867":{"id":"/docs/lightning/channel-backup-40","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#test-it","content":"On the remote host, list the target directory. You should see\nthe timestamped file plus `channel.backup.latest`:"},"868":{"id":"/docs/lightning/channel-backup-41","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#test-it","content":"Keep the first session running for the first real channel\nopen or close. When LND updates the SCB for real, you should\nsee a fresh sync event land the same way."},"869":{"id":"/docs/lightning/channel-backup-42","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#test-it","content":"Every channel state change produces a new file. Over years that\nadds up, not a lot of bytes (the SCB is typically well under\n100 KB), but a lot of entries. A cron job on the remote host that\nkeeps the last 100 timestamped copies plus `channel.backup.latest`\nis plenty."},"870":{"id":"/docs/lightning/channel-backup-43","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"You only ever run through this when the Pi is toast. The high\nlevel is: fresh Pi, same 24-word seed, latest SCB, pray."},"871":{"id":"/docs/lightning/channel-backup-44","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"Build a new Pi following the earlier sections. Get to the\npoint where LND is installed, `lnd.conf` is in place, and the\nservice is enabled, but **do not** run `lncli create` yet."},"872":{"id":"/docs/lightning/channel-backup-45","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"Pull `channel.backup.latest` from your remote host onto the\nnew Pi:"},"873":{"id":"/docs/lightning/channel-backup-46","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"Start LND in the foreground as the `lnd` user:"},"874":{"id":"/docs/lightning/channel-backup-47","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"In a second session, create the wallet from the existing seed\n**with** the SCB attached. The `--recovery_window` tells LND\nhow many derivation steps to scan for on-chain activity,\n10000 is plenty for a home node. The `--multi_file` flag\ntells `lncli create` to also accept an SCB:"},"875":{"id":"/docs/lightning/channel-backup-48","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"Answer `y` to the \"existing cipher seed\" prompt and paste the\n24 words. When prompted for an SCB, point at `/tmp/channel.backup`."},"876":{"id":"/docs/lightning/channel-backup-49","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"(Alternatively, create the wallet first and then run\n`lncli restorechanbackup --multi_file /tmp/channel.backup`.\nSame end result.)"},"877":{"id":"/docs/lightning/channel-backup-50","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"Watch the log. LND will reach out to each peer, ask them to\nforce-close at the latest state they know about, and wait.\nThe on-chain commit transactions take the usual time to\nconfirm; expect funds to land in your on-chain wallet over the\nfollowing hours or days, not minutes."},"878":{"id":"/docs/lightning/channel-backup-51","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"Once all channels have settled, you can reopen new channels\nagainst the restored on-chain balance, you're back in\nbusiness."},"879":{"id":"/docs/lightning/channel-backup-52","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"If the SCB you restore from is older than what your peers\nactually have, LND will ask for a close at an outdated state.\nWell-behaved peers will still close at the latest state they\nknow about (to their own benefit), and the amount you get back\nis whatever the **peer** says you should, not whatever you\nthought the balance was."},"880":{"id":"/docs/lightning/channel-backup-53","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#restore-flow","content":"The sync above is designed to keep the SCB fresh to within\nseconds. If you ever see a gap of days between the last sync and\n\"now\", something broke, and you need to know about it. A small\ncron job on the remote host that alerts on stale files is a good\nidea."},"881":{"id":"/docs/lightning/channel-backup-54","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#close-channels-gracefully-when-you-can","content":"Best-case recovery is the one you don't need: close your channels\non your own terms **before** decommissioning a node. A cooperative\nclose settles at the latest state with both peers agreeing,\ndoesn't trigger commit-delay timeouts, and pays lower on-chain\nfees. Planning to retire the Pi or move to new hardware?"},"882":{"id":"/docs/lightning/channel-backup-55","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#close-channels-gracefully-when-you-can","content":"Close them one by one before you touch anything else."},"883":{"id":"/docs/lightning/channel-backup-56","page_id":"/docs/lightning/channel-backup","tags":[],"type":"text","url":"/docs/lightning/channel-backup#close-channels-gracefully-when-you-can","content":"**Main takeaway:** the seed is half of recovery, the SCB is the\nother half, and the SCB is only useful if it lives somewhere the\nPi's SSD can't take with it. Set up the sync, test it, and keep\nan eye on the freshness."},"884":{"id":"/docs/lightning","page_id":"/docs/lightning","type":"page","content":"Overview","breadcrumbs":["Docs","Lightning"],"tags":[],"url":"/docs/lightning"},"885":{"id":"/docs/lightning-0","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning","content":"Install LND, wire up a web dashboard and mobile app, and keep your channels safe."},"886":{"id":"/docs/lightning-1","page_id":"/docs/lightning","type":"heading","tags":[],"url":"/docs/lightning#what-youll-do","content":"What you'll do"},"887":{"id":"/docs/lightning-2","page_id":"/docs/lightning","type":"heading","tags":[],"url":"/docs/lightning#assumptions","content":"Assumptions"},"888":{"id":"/docs/lightning-3","page_id":"/docs/lightning","type":"heading","tags":[],"url":"/docs/lightning#pages-in-this-section","content":"Pages in this section"},"889":{"id":"/docs/lightning-4","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning","content":"So Bitcoin is running. Why bolt a second network on top of it?"},"890":{"id":"/docs/lightning-5","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning","content":"Because Bitcoin's base layer is deliberately slow and deliberately\nexpensive. Every transaction lands in a block that thousands of\nnodes worldwide will validate and store forever, and that's exactly\nwhat you want for settling serious money, not for buying a coffee.\nThe **Lightning Network** is the second layer that fixes the coffee\nproblem: payments settle in milliseconds, cost fractions of a cent,\nand only touch the base chain when a channel opens or closes."},"891":{"id":"/docs/lightning-6","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning","content":"This section turns your Bitcoin node into a Lightning node."},"892":{"id":"/docs/lightning-7","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#what-youll-do","content":"By the end of this section you'll have:"},"893":{"id":"/docs/lightning-8","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#what-youll-do","content":"**LND** running as a systemd service, connected to bitcoind over\nRPC + ZMQ, and routing its own peer traffic through Tor."},"894":{"id":"/docs/lightning-9","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#what-youll-do","content":"A **24-word seed** written down on paper and locked away, the\nonly rope back to your on-chain funds if the Pi dies."},"895":{"id":"/docs/lightning-10","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#what-youll-do","content":"**Ride The Lightning (RTL)** on `https://rtl.raspibolt.local`,\nreachable from your LAN so you can manage channels in a browser."},"896":{"id":"/docs/lightning-11","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#what-youll-do","content":"**Zeus** on your phone, connected to the Pi over a private Tor\nonion, full node control from wherever you are."},"897":{"id":"/docs/lightning-12","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#what-youll-do","content":"An **automated channel backup** that rsyncs your\n`channel.backup` file to an offsite host every time it changes."},"898":{"id":"/docs/lightning-13","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#what-youll-do","content":"Budget roughly **two to three hours** of hands-on time, most of it\nwaiting for `npm install` and your first channel to confirm."},"899":{"id":"/docs/lightning-14","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#assumptions","content":"You finished the Bitcoin section and `bitcoind` is\n**fully synced**, Lightning won't initial-sync its graph against\na blockchain that's still catching up."},"900":{"id":"/docs/lightning-15","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#assumptions","content":"`bitcoind` exposes the RPC port on `127.0.0.1:8332` and the ZMQ\nstreams on ports `28332` and `28333`, exactly as configured in\nBitcoin client."},"901":{"id":"/docs/lightning-16","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#assumptions","content":"**Tor** is installed and its SOCKS proxy is live on\n`127.0.0.1:9050` (see Privacy)."},"902":{"id":"/docs/lightning-17","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#assumptions","content":"**Caddy** is running as the reverse proxy for your LAN-only\nservices, installed earlier in the Bitcoin section."},"903":{"id":"/docs/lightning-18","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#assumptions","content":"If you want to see where LND plugs into everything else before\ndiving in, Architecture has the full picture."},"904":{"id":"/docs/lightning-19","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#assumptions","content":"Up until now, a bad step on the Pi costs you a reinstall. A bad\nstep on Lightning can cost you satoshis. The 24-word seed LND\ngenerates is the **only** way to recover on-chain funds, and a\nstale channel backup can mean peers settle against you. Before you\nsend meaningful amounts to this node, read\nChannel backup, then actually\nset the backup up. Don't skip it."},"905":{"id":"/docs/lightning-20","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#pages-in-this-section","content":"Lightning client, download,\nverify, and run LND 0.20.1-beta; create the wallet and seed;\nset up auto-unlock."},"906":{"id":"/docs/lightning-21","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#pages-in-this-section","content":"Web app, install Node.js and RTL\n0.15.6; point it at LND; expose it through Caddy."},"907":{"id":"/docs/lightning-22","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#pages-in-this-section","content":"Mobile app, set up a Tor hidden\nservice for LND's REST API and pair the Zeus phone app with it."},"908":{"id":"/docs/lightning-23","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#pages-in-this-section","content":"Channel backup, watch the\n`channel.backup` file and ship a copy offsite on every change;\nwalk through the restore flow."},"909":{"id":"/docs/lightning-24","page_id":"/docs/lightning","tags":[],"type":"text","url":"/docs/lightning#pages-in-this-section","content":"When Lightning is up, keep an eye on it for a few days before\ncommitting serious sats. Channels that open smoothly don't always\nclose smoothly, and you'll want to see a few state updates flow\nthrough the backup pipeline before trusting it."},"910":{"id":"/docs/lightning/lightning-client","page_id":"/docs/lightning/lightning-client","type":"page","content":"Lightning client","breadcrumbs":["Docs","Lightning"],"tags":[],"url":"/docs/lightning/lightning-client"},"911":{"id":"/docs/lightning/lightning-client-0","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client","content":"Install and configure LND (Lightning Network Daemon). Write lnd.conf for bitcoind RPC and ZMQ, generate the 24-word seed, set up auto-unlock, enable watchtower and wumbo channels."},"912":{"id":"/docs/lightning/lightning-client-1","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#create-the-system-user-and-data-directory","content":"Create the system user and data directory"},"913":{"id":"/docs/lightning/lightning-client-2","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#download-lnd","content":"Download LND"},"914":{"id":"/docs/lightning/lightning-client-3","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#verify-the-signature","content":"Verify the signature"},"915":{"id":"/docs/lightning/lightning-client-4","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#install-the-binaries","content":"Install the binaries"},"916":{"id":"/docs/lightning/lightning-client-5","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#set-the-wallet-unlock-password","content":"Set the wallet unlock password"},"917":{"id":"/docs/lightning/lightning-client-6","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#write-lndconf","content":"Write lnd.conf"},"918":{"id":"/docs/lightning/lightning-client-7","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#systemd-unit","content":"systemd unit"},"919":{"id":"/docs/lightning/lightning-client-8","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Create the wallet and the seed"},"920":{"id":"/docs/lightning/lightning-client-9","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#start-lnd-under-systemd","content":"Start LND under systemd"},"921":{"id":"/docs/lightning/lightning-client-10","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#fund-the-node-and-open-a-channel","content":"Fund the node and open a channel"},"922":{"id":"/docs/lightning/lightning-client-11","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#add-watchtowers","content":"Add watchtowers"},"923":{"id":"/docs/lightning/lightning-client-12","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#useful-lncli-commands","content":"Useful lncli commands"},"924":{"id":"/docs/lightning/lightning-client-13","page_id":"/docs/lightning/lightning-client","type":"heading","tags":[],"url":"/docs/lightning/lightning-client#upgrading-lnd","content":"Upgrading LND"},"925":{"id":"/docs/lightning/lightning-client-14","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client","content":"Which Lightning implementation should a first-time node run? You'll\ninstall **LND** (the Lightning Network Daemon) from\nLightning Labs, the most widely\nused, best-documented, and best-tooled implementation for a node\noperator who wants a web UI and a mobile app to work out of the box.\nCore Lightning and Eclair are excellent too, but LND has the\necosystem advantage, and that matters when you're starting out."},"926":{"id":"/docs/lightning/lightning-client-15","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client","content":"This page takes you from zero to a running `lnd` service with a\n24-word seed, an auto-unlocking wallet, and a healthy `getinfo`\nresponse."},"927":{"id":"/docs/lightning/lightning-client-16","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client","content":"Lightning isn't a testbed. The wallet you create here holds real\nbitcoin, and every channel open or close is an on-chain transaction\nthat costs real fees. Until you have your 24-word seed **written\ndown on paper** and your `channel.backup` file syncing off-Pi\n(next page after this one), don't fund the wallet. A lost seed or\nmissing SCB on a dead SSD means the funds are gone, no support desk.\nBudget about **30 minutes** of hands-on time for this page."},"928":{"id":"/docs/lightning/lightning-client-17","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-system-user-and-data-directory","content":"LND is a long-running daemon that manages real money. It gets its\nown unprivileged system user and a dedicated data directory on the\nSSD, with the home-directory `~/.lnd` path symlinked to the real\nlocation. Same pattern you used for `bitcoind`."},"929":{"id":"/docs/lightning/lightning-client-18","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-system-user-and-data-directory","content":"As user `admin`, create the `lnd` user. Give it group membership\nin `bitcoin` (so it can read `bitcoin.conf` for auto-RPC) and in\n`debian-tor` (so it can read Tor's cookie file for the control\nport):"},"930":{"id":"/docs/lightning/lightning-client-19","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-system-user-and-data-directory","content":"The third command puts `admin` into the `lnd` group so you can\nrun `lncli` later without `sudo`."},"931":{"id":"/docs/lightning/lightning-client-20","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-system-user-and-data-directory","content":"Create the data directory on the SSD and hand it to `lnd`:"},"932":{"id":"/docs/lightning/lightning-client-21","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-system-user-and-data-directory","content":"Open a shell as the `lnd` user and set up the symlinks. LND\nlooks for its data in `~/.lnd` by default; pointing that at\n`/data/lnd` means every tool and tutorial that assumes the\ndefault path still works:"},"933":{"id":"/docs/lightning/lightning-client-22","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-system-user-and-data-directory","content":"The two symlinks should show in cyan, not red. Red means a\nbroken link, usually because the target directory doesn't exist\nyet."},"934":{"id":"/docs/lightning/lightning-client-23","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#download-lnd","content":"LND ships as a statically linked binary tarball. You'll download\nit, verify the SHA256 checksum, verify the GPG signature on the\nmanifest, and only then copy the binaries into place."},"935":{"id":"/docs/lightning/lightning-client-24","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#download-lnd","content":"Still as the `lnd` user, grab the release archive, the manifest,\nand the maintainer's signature:"},"936":{"id":"/docs/lightning/lightning-client-25","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#download-lnd","content":"Verify the checksum of the binary against the manifest. The\n`--ignore-missing` flag lets you check only the file you\ndownloaded, not every platform listed in the manifest:"},"937":{"id":"/docs/lightning/lightning-client-26","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#download-lnd","content":"Expected output:"},"938":{"id":"/docs/lightning/lightning-client-27","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#verify-the-signature","content":"The checksum proves the download wasn't corrupted in transit. It\ndoes not prove the manifest itself is authentic, for that you need\nto verify the PGP signature against the maintainer's public key.\nLND releases are signed by Olaoluwa \"Roasbeef\" Osuntokun."},"939":{"id":"/docs/lightning/lightning-client-28","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#verify-the-signature","content":"Import the signing key from the LND repo (the\n`scripts/keys/roasbeef.asc` path is the canonical source):"},"940":{"id":"/docs/lightning/lightning-client-29","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#verify-the-signature","content":"Verify the manifest against the signature:"},"941":{"id":"/docs/lightning/lightning-client-30","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#verify-the-signature","content":"Look for a `Good signature from \"Olaoluwa Osuntokun\"` line. The\nfull fingerprint should read\n`A5B6 1896 952D 9FDA 83BC 054C DC42 612E 8923 7182`. GPG will\nalso warn that the key isn't certified with a trusted signature.\nThat's expected; you haven't built a web of trust around this\nkey, you've just pinned its fingerprint."},"942":{"id":"/docs/lightning/lightning-client-31","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#verify-the-signature","content":"A corrupt download trips the checksum. A compromised download\nserver serves a real binary with a **matching** checksum and a\nforged manifest. The signature check is what catches that, the\nattacker would also need Roasbeef's private key, which they do not\nhave."},"943":{"id":"/docs/lightning/lightning-client-32","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#install-the-binaries","content":"Step back out of the `lnd` shell first, installing binaries into\n`/usr/local/bin` needs `admin`'s `sudo`:"},"944":{"id":"/docs/lightning/lightning-client-33","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#install-the-binaries","content":"Extract the archive and install both binaries:"},"945":{"id":"/docs/lightning/lightning-client-34","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#install-the-binaries","content":"Expected output:"},"946":{"id":"/docs/lightning/lightning-client-35","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#set-the-wallet-unlock-password","content":"LND's wallet is password-protected and asks for the password on\nevery startup. You have two options:"},"947":{"id":"/docs/lightning/lightning-client-36","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#set-the-wallet-unlock-password","content":"**Manual unlock** every time the Pi reboots. Most secure at rest:\nthe password lives only in your head, but a power blip at 3 a.m.\nleaves LND offline until you're awake to type a password."},"948":{"id":"/docs/lightning/lightning-client-37","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#set-the-wallet-unlock-password","content":"**Auto-unlock** from a file on disk. Trades at-rest encryption\nfor uptime. On a single-user home node behind a firewall this is\nthe right default; an attacker who can read files as `lnd` has\nalready lost you the game."},"949":{"id":"/docs/lightning/lightning-client-38","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#set-the-wallet-unlock-password","content":"This guide picks auto-unlock. You can switch later."},"950":{"id":"/docs/lightning/lightning-client-39","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#set-the-wallet-unlock-password","content":"Become `lnd` again and create the password file, then enter\npassword `[C]` (one you haven't used anywhere else):"},"951":{"id":"/docs/lightning/lightning-client-40","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#set-the-wallet-unlock-password","content":"Lock the file down so only `lnd` can read it:"},"952":{"id":"/docs/lightning/lightning-client-41","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#write-lndconf","content":"LND reads its configuration from `/data/lnd/lnd.conf` (resolved\nvia the `~/.lnd` symlink). This file does the heavy lifting,\nchain backend, Tor, channel policy, watchtower client, all of it."},"953":{"id":"/docs/lightning/lightning-client-42","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#write-lndconf","content":"Create the config file:"},"954":{"id":"/docs/lightning/lightning-client-43","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#write-lndconf","content":"Paste the following. Replace `YourAlias` with whatever name you\nwant to show up in channel graphs, and pick a hex colour you\nlike:"},"955":{"id":"/docs/lightning/lightning-client-44","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#write-lndconf","content":"Replace `PASSWORD_B_REPLACE_ME` with the `rpcpass` from your\n`bitcoin.conf` (password `[B]` from the Bitcoin section)."},"956":{"id":"/docs/lightning/lightning-client-45","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#write-lndconf","content":"`tor.streamisolation=true` gives every outbound Lightning\nconnection its own Tor circuit, so two peers can't correlate you\nfrom the same exit. Good privacy default."},"957":{"id":"/docs/lightning/lightning-client-46","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#write-lndconf","content":"But `skip-proxy-for-clearnet-targets=true` is also on, which keeps\nlocal clearnet connections, like the one to `bitcoind` on\n`127.0.0.1:8332`, off of Tor entirely. Without that, LND tries to\nsend RPC calls through Tor to a localhost IP, and Tor (rightly)\nrefuses. The combination gives you Tor for everything public and\ndirect sockets for everything local."},"958":{"id":"/docs/lightning/lightning-client-47","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#systemd-unit","content":"Running `lnd` by hand once is fine for the initial wallet setup.\nFor actual operation you want it under systemd so it starts at\nboot, restarts after crashes, and only comes up after `bitcoind`\nis ready."},"959":{"id":"/docs/lightning/lightning-client-48","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#systemd-unit","content":"Back as user `admin`, create the unit file:"},"960":{"id":"/docs/lightning/lightning-client-49","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#systemd-unit","content":"Paste:"},"961":{"id":"/docs/lightning/lightning-client-50","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#systemd-unit","content":"Reload systemd and enable the unit (don't start it yet, you\nneed to create the wallet first):"},"962":{"id":"/docs/lightning/lightning-client-51","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"First start is a two-window affair: LND runs in the foreground in\none SSH session and waits for you to create the wallet from a\nsecond session."},"963":{"id":"/docs/lightning/lightning-client-52","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Still as `admin`, start LND in the foreground:"},"964":{"id":"/docs/lightning/lightning-client-53","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"You'll see it print startup logs and then sit on a line like\n`Waiting for wallet encryption password. Use 'lncli create' ...`.\nLeave this window open."},"965":{"id":"/docs/lightning/lightning-client-54","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Open a **second** SSH session to the Pi. Become the `lnd` user\nand run `lncli create`:"},"966":{"id":"/docs/lightning/lightning-client-55","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"At the prompts:"},"967":{"id":"/docs/lightning/lightning-client-56","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Enter password `[C]` as the wallet password. Use exactly the\nsame password you wrote into `password.txt`."},"968":{"id":"/docs/lightning/lightning-client-57","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"When asked about an existing cipher seed, answer `n`, you\nwant a fresh seed."},"969":{"id":"/docs/lightning/lightning-client-58","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"When asked about a seed passphrase, press Enter to skip it\nunless you know what you're doing. A passphrase adds a 25th\nword that you also have to back up; lose it and the 24 words\nalone will not restore the wallet."},"970":{"id":"/docs/lightning/lightning-client-59","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"LND prints a 24-word cipher seed. &#x2A;*Stop scrolling. Read this\npart.**"},"971":{"id":"/docs/lightning/lightning-client-60","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"These 24 words are the only rope back to the on-chain funds on\nthis node. If the Pi dies, the SSD dies, or the house burns down,\nthe seed, and **only** the seed, can restore your wallet on a\nfresh LND."},"972":{"id":"/docs/lightning/lightning-client-61","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"**Write the words down on paper.** Twice. Keep the two copies in\ntwo different physical locations."},"973":{"id":"/docs/lightning/lightning-client-62","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"**Do not** photograph the screen, do not type the words into any\ntext file, do not email them to yourself, do not put them in a\npassword manager unless it's one you trust with your life."},"974":{"id":"/docs/lightning/lightning-client-63","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"The RaspiBolt backup card\nis a nice printable template if you want one."},"975":{"id":"/docs/lightning/lightning-client-64","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Anyone with these words can empty every on-chain sat on this\nnode. The seed does **not** restore Lightning channel balances,\nfor that, see Channel backup."},"976":{"id":"/docs/lightning/lightning-client-65","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Seriously. Write it down before you go any further."},"977":{"id":"/docs/lightning/lightning-client-66","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Once the seed is recorded, exit the second session:"},"978":{"id":"/docs/lightning/lightning-client-67","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Back in the first window where `lnd` is still running, stop it with\n`Ctrl-C`. Then start it again in the foreground to confirm the\nauto-unlock works:"},"979":{"id":"/docs/lightning/lightning-client-68","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#create-the-wallet-and-the-seed","content":"Look for `Attempting automatic wallet unlock with password` and\n`Opened wallet`. Stop it again with `Ctrl-C` and exit the `lnd`\nuser session:"},"980":{"id":"/docs/lightning/lightning-client-69","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#start-lnd-under-systemd","content":"As `admin`, start the service and follow the log:"},"981":{"id":"/docs/lightning/lightning-client-70","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#start-lnd-under-systemd","content":"Wait until you see `LNWL: Opened wallet` and then graph-sync\nprogress. Exit the log tail with `Ctrl-C`."},"982":{"id":"/docs/lightning/lightning-client-71","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#start-lnd-under-systemd","content":"Let `admin` use `lncli` without `sudo`. The `admin` user is\nalready in the `lnd` group; the remaining permissions tweak is\na symlink and a group-read bit on the macaroon:"},"983":{"id":"/docs/lightning/lightning-client-72","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#start-lnd-under-systemd","content":"Log out of the SSH session and log back in, group membership\nonly takes effect on a fresh shell. Then smoke-test:"},"984":{"id":"/docs/lightning/lightning-client-73","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#start-lnd-under-systemd","content":"`getinfo` should return an `identity_pubkey`, the current\n`block_height`, and `synced_to_chain: true` once LND has caught\nup with the graph. `getnetworkinfo` should show a non-zero\nnumber of nodes and channels, proof that LND is talking to the\nwider Lightning network over Tor."},"985":{"id":"/docs/lightning/lightning-client-74","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#start-lnd-under-systemd","content":"**Main takeaway:** LND is up, the wallet is unlocked, the 24-word\nseed is on paper, and `lncli` works from `admin`. You have a\nworking Lightning node."},"986":{"id":"/docs/lightning/lightning-client-75","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#fund-the-node-and-open-a-channel","content":"Generate a native-SegWit address and send a small amount of\non-chain sats to it from another wallet:"},"987":{"id":"/docs/lightning/lightning-client-76","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#fund-the-node-and-open-a-channel","content":"Wait for one confirmation, then:"},"988":{"id":"/docs/lightning/lightning-client-77","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#fund-the-node-and-open-a-channel","content":"Pick a well-connected peer from\nAmboss or\nLightningNetwork+. A peer URI\nlooks like `pubkey@host:port`. Connect, then open a channel\n(capacity in sats, explicit fee in sats/vByte from\nmempool.space):"},"989":{"id":"/docs/lightning/lightning-client-78","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#fund-the-node-and-open-a-channel","content":"Three confirmations later the channel is active:"},"990":{"id":"/docs/lightning/lightning-client-79","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#fund-the-node-and-open-a-channel","content":"Set up Channel backup **before**\nyou open your first real channel. The backup is only useful if it\nexists when you need it, and you need it as soon as the first\nchannel lands."},"991":{"id":"/docs/lightning/lightning-client-80","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#add-watchtowers","content":"Lightning channels assume both sides are honest. If a peer tries\nto settle an old channel state while your node is offline, they\nwalk away with funds that should have been yours. Watchtowers are\nthird-party nodes that watch your channels for you and punish\ncheaters, and because the worst a watchtower can do is fail\nsilently, you don't have to trust them."},"992":{"id":"/docs/lightning/lightning-client-81","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#add-watchtowers","content":"You already enabled `wtclient.active=true` in `lnd.conf`. Add a\ntower or two:"},"993":{"id":"/docs/lightning/lightning-client-82","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#add-watchtowers","content":"Openoms maintains a\nlist of public altruistic watchtowers;\nadd two or three more for redundancy."},"994":{"id":"/docs/lightning/lightning-client-83","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#useful-lncli-commands","content":"A small reference you'll come back to:"},"995":{"id":"/docs/lightning/lightning-client-84","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#useful-lncli-commands","content":"Full API reference at\napi.lightning.community."},"996":{"id":"/docs/lightning/lightning-client-85","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#upgrading-lnd","content":"LND release notes are non-negotiable reading, some releases ship\ndatabase migrations that are one-way. Before every upgrade:"},"997":{"id":"/docs/lightning/lightning-client-86","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#upgrading-lnd","content":"Read the\nrelease notes\nend to end."},"998":{"id":"/docs/lightning/lightning-client-87","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#upgrading-lnd","content":"Stop the service: `sudo systemctl stop lnd`."},"999":{"id":"/docs/lightning/lightning-client-88","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#upgrading-lnd","content":"Repeat the download, verify, and install steps above with the\nnew version."},"1000":{"id":"/docs/lightning/lightning-client-89","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#upgrading-lnd","content":"Update `0.20.1-beta` in `lib/versions.ts` so the rest of the\nguide agrees."},"1001":{"id":"/docs/lightning/lightning-client-90","page_id":"/docs/lightning/lightning-client","tags":[],"type":"text","url":"/docs/lightning/lightning-client#upgrading-lnd","content":"Start the service: `sudo systemctl start lnd` and tail the log\nuntil you see `synced_to_chain: true`."},"1002":{"id":"/docs/lightning/mobile-app","page_id":"/docs/lightning/mobile-app","type":"page","content":"Mobile app","breadcrumbs":["Docs","Lightning"],"tags":[],"url":"/docs/lightning/mobile-app"},"1003":{"id":"/docs/lightning/mobile-app-0","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app","content":"Pair the Zeus iOS/Android wallet with LND over a Tor hidden service (onion). Generate the lndconnect URL with qrencode, paste admin macaroon, connect."},"1004":{"id":"/docs/lightning/mobile-app-1","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#add-a-hidden-service-for-lnd-rest","content":"Add a hidden service for LND REST"},"1005":{"id":"/docs/lightning/mobile-app-2","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#allow-lnd-rest-on-loopback","content":"Allow LND REST on loopback"},"1006":{"id":"/docs/lightning/mobile-app-3","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Build the Zeus connect QR"},"1007":{"id":"/docs/lightning/mobile-app-4","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#pair-zeus","content":"Pair Zeus"},"1008":{"id":"/docs/lightning/mobile-app-5","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#stream-isolation-caveat","content":"Stream isolation caveat"},"1009":{"id":"/docs/lightning/mobile-app-6","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#troubleshooting","content":"Troubleshooting"},"1010":{"id":"/docs/lightning/mobile-app-7","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#zeus-hangs-on-connecting","content":"Zeus hangs on \"Connecting...\""},"1011":{"id":"/docs/lightning/mobile-app-8","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#unable-to-connect-to-lnd","content":"\"Unable to connect to LND\""},"1012":{"id":"/docs/lightning/mobile-app-9","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#payments-fail-with-no-route","content":"Payments fail with \"no route\""},"1013":{"id":"/docs/lightning/mobile-app-10","page_id":"/docs/lightning/mobile-app","type":"heading","tags":[],"url":"/docs/lightning/mobile-app#remove-zeus-access-later","content":"Remove Zeus access later"},"1014":{"id":"/docs/lightning/mobile-app-11","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app","content":"What does a Lightning node on the go look like? For this guide,\nit's Zeus, an open-source mobile app (iOS\nand Android) that talks directly to your own LND instance. No\ncustodian, no cloud relay, no third-party pairing server. Zeus\nreaches your node over a **Tor hidden service**, which means your\nPi's address stays secret and your home IP stays off Lightning\nNetwork traffic from your phone."},"1015":{"id":"/docs/lightning/mobile-app-12","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app","content":"You'll set up a dedicated onion for LND's REST API, mint a QR\ncode containing the onion URL, the port, and the admin macaroon,\nthen scan it with Zeus."},"1016":{"id":"/docs/lightning/mobile-app-13","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#add-a-hidden-service-for-lnd-rest","content":"Tor is already running on your Pi (set up in\nPrivacy). Adding a hidden service\nfor LND's REST API is three more lines in `torrc`."},"1017":{"id":"/docs/lightning/mobile-app-14","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#add-a-hidden-service-for-lnd-rest","content":"As user `admin`, open the Tor configuration:"},"1018":{"id":"/docs/lightning/mobile-app-15","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#add-a-hidden-service-for-lnd-rest","content":"Scroll to the section marked &#x2A;*\"This section is just for\nlocation-hidden services\"** and add:"},"1019":{"id":"/docs/lightning/mobile-app-16","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#add-a-hidden-service-for-lnd-rest","content":"Reload Tor and read the generated onion address:"},"1020":{"id":"/docs/lightning/mobile-app-17","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#add-a-hidden-service-for-lnd-rest","content":"You'll get back a string like `abcdefg...xyz.onion`. Save it in\nyour password manager, this is the only thing that lets Zeus\nfind your node, and by design nothing else on the internet can."},"1021":{"id":"/docs/lightning/mobile-app-18","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#add-a-hidden-service-for-lnd-rest","content":"A hidden service address is 56 random base32 characters, the\ninternet equivalent of an unlisted phone number. Anyone who\ndoesn't have the string cannot connect, cannot scan for it, and\ncannot even tell that your Pi exists as a Lightning endpoint.\nThat's a far stronger privacy position than opening port 8080 on\nyour router."},"1022":{"id":"/docs/lightning/mobile-app-19","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#allow-lnd-rest-on-loopback","content":"LND's REST API already listens on `127.0.0.1:8080` by default;\nthe hidden service above forwards the onion's port 8080 to that\nloopback socket, so nothing new needs to open on the firewall."},"1023":{"id":"/docs/lightning/mobile-app-20","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#allow-lnd-rest-on-loopback","content":"Confirm the port is live:"},"1024":{"id":"/docs/lightning/mobile-app-21","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#allow-lnd-rest-on-loopback","content":"You should see `lnd` listening on `127.0.0.1:8080`. If not, your\n`lnd.conf` overrides the default, check for a\n`restlisten` line and remove it or point it at `127.0.0.1:8080`."},"1025":{"id":"/docs/lightning/mobile-app-22","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Zeus has a built-in QR scanner that reads a JSON payload\ncontaining the onion URL, the port, and the admin macaroon as hex.\nYou'll paste that JSON into a QR code on the Pi, maximise the\nterminal window, and scan it with the phone."},"1026":{"id":"/docs/lightning/mobile-app-23","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Install `qrencode` for the QR render, and `xxd` for the macaroon\nhex/base64 conversion below. On Debian 13, `xxd` is its own\npackage and isn't pulled in by default:"},"1027":{"id":"/docs/lightning/mobile-app-24","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Grab the admin macaroon as uppercase hex:"},"1028":{"id":"/docs/lightning/mobile-app-25","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Grab the onion hostname:"},"1029":{"id":"/docs/lightning/mobile-app-26","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Build the Zeus config URL and render it as a QR code in the\nterminal. The `lndconnect://` scheme is what Zeus expects:"},"1030":{"id":"/docs/lightning/mobile-app-27","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Maximise your terminal window and shrink the font with\n`Ctrl`-`-` until the whole QR fits on screen."},"1031":{"id":"/docs/lightning/mobile-app-28","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#build-the-zeus-connect-qr","content":"Anyone who can photograph this screen has full control of your\nLightning node. Don't screenshot it. Don't paste it into a chat.\nClose the terminal as soon as Zeus has paired."},"1032":{"id":"/docs/lightning/mobile-app-29","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Install Zeus on your phone.\nzeusln.app has the direct links, Apple\nApp Store, Google Play, F-Droid, or a direct APK download if\nyou prefer to sideload."},"1033":{"id":"/docs/lightning/mobile-app-30","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"On the phone, make sure you have a Tor pathway. Zeus can\neither:"},"1034":{"id":"/docs/lightning/mobile-app-31","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Use **Orbot** (Android) or **Onion Browser** (iOS) as an\nexternal Tor proxy, the traditional setup, and the one this\nguide assumes."},"1035":{"id":"/docs/lightning/mobile-app-32","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Use its **built-in Tor daemon** (Android only, toggle in\nZeus settings), convenient, but note that channel ops will\nfail if the app is backgrounded aggressively by Android's\nbattery optimiser."},"1036":{"id":"/docs/lightning/mobile-app-33","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Open Zeus, tap **Get Started**, then **Connect a node**."},"1037":{"id":"/docs/lightning/mobile-app-34","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Tap the &#x2A;*+** at the top right, give the node a nickname\n(`RaspiBolt` works), choose **LND** as the interface and\n**REST** as the connection type, then tap **Scan lndconnect\nconfig**."},"1038":{"id":"/docs/lightning/mobile-app-35","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Scan the QR code from the Pi. Zeus fills in the onion URL,\nport, and macaroon automatically."},"1039":{"id":"/docs/lightning/mobile-app-36","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Tap **Save node config**. First connection takes a while,\nZeus has to build a Tor circuit to your hidden service, so\ngive it a minute."},"1040":{"id":"/docs/lightning/mobile-app-37","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#pair-zeus","content":"Set a Zeus PIN or password under\n**Settings → Security**. Someone with your unlocked phone has\nfull control of your node."},"1041":{"id":"/docs/lightning/mobile-app-38","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#stream-isolation-caveat","content":"You set `tor.streamisolation=true` in `lnd.conf`, this means\nevery outbound Lightning channel uses its own Tor circuit, and\npeers cannot correlate you across channels. That setting only\naffects LND's **outbound** connections to Lightning peers. It\ndoes not affect incoming hidden-service traffic from Zeus, which\nalways arrives on the hidden-service circuit regardless."},"1042":{"id":"/docs/lightning/mobile-app-39","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#stream-isolation-caveat","content":"In other words: Zeus over Tor works exactly the same with or\nwithout stream isolation enabled. The privacy win of stream\nisolation is elsewhere."},"1043":{"id":"/docs/lightning/mobile-app-40","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#zeus-hangs-on-connecting","content":"Tor on the Pi isn't running: `sudo systemctl status tor`."},"1044":{"id":"/docs/lightning/mobile-app-41","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#zeus-hangs-on-connecting","content":"Orbot on the phone isn't running, or the phone doesn't have\ninternet connectivity."},"1045":{"id":"/docs/lightning/mobile-app-42","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#zeus-hangs-on-connecting","content":"LND REST isn't on `127.0.0.1:8080`: `sudo ss -tulpn | grep 8080`."},"1046":{"id":"/docs/lightning/mobile-app-43","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#zeus-hangs-on-connecting","content":"The onion hostname in the QR doesn't match\n`/var/lib/tor/hidden_service_lnd_rest/hostname`, regenerate the\nQR."},"1047":{"id":"/docs/lightning/mobile-app-44","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#unable-to-connect-to-lnd","content":"Macaroon is malformed. Regenerate the QR with the exact\ncommands above; the base64url encoding matters."},"1048":{"id":"/docs/lightning/mobile-app-45","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#unable-to-connect-to-lnd","content":"LND is locked (password-file auto-unlock didn't trigger).\nCheck `sudo systemctl status lnd` and look for\n`Opened wallet`."},"1049":{"id":"/docs/lightning/mobile-app-46","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#payments-fail-with-no-route","content":"This is a node liquidity problem, not a Zeus problem. Check\nchannel balances in RTL and rebalance if needed."},"1050":{"id":"/docs/lightning/mobile-app-47","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#payments-fail-with-no-route","content":"**Main takeaway:** you have full, private control of your\nLightning node from your phone, payments, channel management,\ninvoicing, with zero third-party infrastructure between you and\nyour own Pi."},"1051":{"id":"/docs/lightning/mobile-app-48","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#remove-zeus-access-later","content":"If you ever want to pull the plug on Zeus pairing, phone lost,\nswitching apps, retiring the node, comment out the three hidden\nservice lines in `/etc/tor/torrc`:"},"1052":{"id":"/docs/lightning/mobile-app-49","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#remove-zeus-access-later","content":"Reload Tor:"},"1053":{"id":"/docs/lightning/mobile-app-50","page_id":"/docs/lightning/mobile-app","tags":[],"type":"text","url":"/docs/lightning/mobile-app#remove-zeus-access-later","content":"The onion address goes dark. Zeus immediately loses its connection."},"1054":{"id":"/docs/lightning/web-app","page_id":"/docs/lightning/web-app","type":"page","content":"Web app","breadcrumbs":["Docs","Lightning"],"tags":[],"url":"/docs/lightning/web-app"},"1055":{"id":"/docs/lightning/web-app-0","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app","content":"Ride The Lightning (RTL), the browser dashboard for LND. Node.js install, RTL-Config.json, Caddy reverse proxy on port 443 with self-signed internal TLS."},"1056":{"id":"/docs/lightning/web-app-1","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#install-nodejs-22","content":"Install Node.js 22"},"1057":{"id":"/docs/lightning/web-app-2","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#create-the-rtl-user","content":"Create the rtl user"},"1058":{"id":"/docs/lightning/web-app-3","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#install-rtl","content":"Install RTL"},"1059":{"id":"/docs/lightning/web-app-4","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#configure-rtl","content":"Configure RTL"},"1060":{"id":"/docs/lightning/web-app-5","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#systemd-unit","content":"systemd unit"},"1061":{"id":"/docs/lightning/web-app-6","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Expose RTL through Caddy"},"1062":{"id":"/docs/lightning/web-app-7","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#walk-around-the-ui","content":"Walk around the UI"},"1063":{"id":"/docs/lightning/web-app-8","page_id":"/docs/lightning/web-app","type":"heading","tags":[],"url":"/docs/lightning/web-app#upgrading-rtl","content":"Upgrading RTL"},"1064":{"id":"/docs/lightning/web-app-9","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app","content":"What does a Lightning node look like once you step away from the\ncommand line? For this guide, it looks like\nRide The Lightning\n(RTL), a well-maintained open-source web dashboard for LND that\ncovers channels, on-chain, routing, and fees in one place. No\nphone-home telemetry, no account, no upstream service; RTL runs on\nyour Pi and talks to LND over the loopback interface."},"1065":{"id":"/docs/lightning/web-app-10","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app","content":"You'll install Node.js 22, clone RTL 0.15.6 as its own\nunprivileged user, point it at LND's macaroon and TLS certificate,\nand expose it behind Caddy at `https://rtl.raspibolt.local` on your\nLAN."},"1066":{"id":"/docs/lightning/web-app-11","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-nodejs-22","content":"RTL is a Node.js application and needs a recent LTS runtime. The\nNodeSource repository gives you upstream Node without waiting for\nDebian backports."},"1067":{"id":"/docs/lightning/web-app-12","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-nodejs-22","content":"As user `admin`, add the NodeSource GPG key and apt source:"},"1068":{"id":"/docs/lightning/web-app-13","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-nodejs-22","content":"Install Node and verify:"},"1069":{"id":"/docs/lightning/web-app-14","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-nodejs-22","content":"Expected output, a `v22.x` line from `node`, and a `10.x` or\nnewer line from `npm`:"},"1070":{"id":"/docs/lightning/web-app-15","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-nodejs-22","content":"BTC RPC Explorer uses the same NodeSource setup. If Node 22 is\nalready present, skip this whole section."},"1071":{"id":"/docs/lightning/web-app-16","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#create-the-rtl-user","content":"RTL should not run as the `lnd` user, it's a web app with an\nexposed HTTP port, and a compromise there should not hand an\nattacker LND's admin macaroon. A dedicated `rtl` user keeps the\nblast radius small."},"1072":{"id":"/docs/lightning/web-app-17","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#create-the-rtl-user","content":"Create the user and copy in a read-only copy of LND's admin\nmacaroon. RTL only needs to **read** the macaroon; the copy is\nwhat keeps `rtl` out of `/data/lnd`:"},"1073":{"id":"/docs/lightning/web-app-18","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#create-the-rtl-user","content":"Anyone with `admin.macaroon` and network reach to LND's gRPC port\ncan open channels, close channels, and send payments. It is not\nthe seed, but it can drain active channels. Keep the file locked\ndown and do not commit it to any repository."},"1074":{"id":"/docs/lightning/web-app-19","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-rtl","content":"Become the `rtl` user, clone the repo, and check out the pinned\nrelease tag:"},"1075":{"id":"/docs/lightning/web-app-20","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-rtl","content":"Verify the tag signature. RTL tags are signed by Suheb; fetch\nthe key and verify:"},"1076":{"id":"/docs/lightning/web-app-21","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-rtl","content":"Look for `Good signature from \"saubyk\"`. The primary key\nfingerprint is `3E9B D443 6C28 8039 CA82 7A92 00C9 E2BC 2E45 666F`."},"1077":{"id":"/docs/lightning/web-app-22","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-rtl","content":"Install production dependencies. This pulls a few hundred\npackages and can take ten minutes or more, the process\noccasionally appears frozen on a single package, it's fine:"},"1078":{"id":"/docs/lightning/web-app-23","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#install-rtl","content":"Success looks like `added NNN packages ... found 0 vulnerabilities`."},"1079":{"id":"/docs/lightning/web-app-24","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#configure-rtl","content":"RTL ships a sample config; you copy it, edit a handful of fields,\nand you're done."},"1080":{"id":"/docs/lightning/web-app-25","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#configure-rtl","content":"As user `rtl`, still in `/home/rtl/RTL`:"},"1081":{"id":"/docs/lightning/web-app-26","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#configure-rtl","content":"Change these four values. `multiPass` is the password you'll\nuse to log into the RTL UI, make it a new one, password `[E]`,\nnot reused from anywhere else:"},"1082":{"id":"/docs/lightning/web-app-27","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#configure-rtl","content":"Further down in the `nodes` → `settings` block, point RTL at\nLND on loopback. Leave the URLs as-is if the sample already\nuses `127.0.0.1`; change `localhost` to `127.0.0.1` if you see\nit, Node 18+ resolves `localhost` via IPv6 first, which LND\ndoesn't listen on:"},"1083":{"id":"/docs/lightning/web-app-28","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#configure-rtl","content":"Also set `fiatConversion` to `true` if you want USD/EUR totals\nin the UI, and leave `Authentication → logoutRedirectLink`\nalone."},"1084":{"id":"/docs/lightning/web-app-29","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#configure-rtl","content":"Save, exit, and leave the `rtl` user session:"},"1085":{"id":"/docs/lightning/web-app-30","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#configure-rtl","content":"RTL can manage multiple LND, Core Lightning, or Eclair nodes from\none UI. This guide sticks to a single LND node for simplicity,\nwhen you're ready, the\nRTL docs\nwalk through adding more in the same `RTL-Config.json`."},"1086":{"id":"/docs/lightning/web-app-31","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#systemd-unit","content":"As `admin`, create the unit file:"},"1087":{"id":"/docs/lightning/web-app-32","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#systemd-unit","content":"Paste:"},"1088":{"id":"/docs/lightning/web-app-33","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#systemd-unit","content":"Enable and start:"},"1089":{"id":"/docs/lightning/web-app-34","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#systemd-unit","content":"The log should end with\n`Server is up and running, please open the UI at http://localhost:3000`.\nExit the tail with `Ctrl-C`."},"1090":{"id":"/docs/lightning/web-app-35","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"RTL listens on `127.0.0.1:3000`, plain HTTP, bound to loopback.\nYou'll front it with **Caddy** (already installed in the Bitcoin\nsection) so you can reach it over HTTPS from anywhere on your LAN.\nCaddy's internal CA issues a self-signed cert on the fly, which\nyour browser will warn about exactly once when you trust the root."},"1091":{"id":"/docs/lightning/web-app-36","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Open Caddy's site config:"},"1092":{"id":"/docs/lightning/web-app-37","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Add a site block for RTL. The `tls internal` line tells Caddy\nto mint a cert from its own CA rather than trying Let's Encrypt\n(which won't work for a `.local` hostname anyway):"},"1093":{"id":"/docs/lightning/web-app-38","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Reload Caddy and open the firewall for HTTPS on the LAN:"},"1094":{"id":"/docs/lightning/web-app-39","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Replace `192.168.0.0/16` with whatever your home LAN actually\nuses. If you want RTL reachable from anywhere on the LAN\nwithout LAN-scoping, drop the `from` clause, but think twice."},"1095":{"id":"/docs/lightning/web-app-40","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Point your desktop browser at `https://rtl.raspibolt.local`.\nIf your router resolves `.local` mDNS names, this works as-is;\nif not, either add a DNS entry on your router or hit the Pi's\nIP directly and trust the cert warning for that hostname."},"1096":{"id":"/docs/lightning/web-app-41","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Log in with password `[E]`."},"1097":{"id":"/docs/lightning/web-app-42","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#expose-rtl-through-caddy","content":"Let's Encrypt needs a public DNS name and an internet-reachable\nport 80 or a DNS-01 challenge. Your home node has neither, and\npublishing the RTL dashboard on the open internet is not something\nthis guide recommends. Caddy's internal CA produces a perfectly\ngood TLS cert; the browser warning is a one-time \"I trust this\nhost on my LAN\" click. If you want a trusted cert for your LAN,\nuse DNS-01 with a real domain you own, but that's a separate\nbonus guide."},"1098":{"id":"/docs/lightning/web-app-43","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"First-login tour:"},"1099":{"id":"/docs/lightning/web-app-44","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"**Home**, headline numbers. On-chain balance, channel balance,\npayments, invoices, and node ranking at a glance."},"1100":{"id":"/docs/lightning/web-app-45","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"**Lightning → Channels**, open channels, pending channels, and\nthe button to open a new one. Channel policy (base fee, fee\nrate, time lock) lives in the per-channel view."},"1101":{"id":"/docs/lightning/web-app-46","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"**Lightning → Payments**, pay an invoice by pasting it, or\ngenerate one to receive. The payments table shows every Lightning\npayment the node has sent."},"1102":{"id":"/docs/lightning/web-app-47","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"**Routing**, earnings from forwarded payments, plus a per-peer\nbreakdown. This is where you'll see whether your channel policy\nis attracting any volume."},"1103":{"id":"/docs/lightning/web-app-48","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"**On-chain**, deposits, sends, UTXOs, and the sweep tool."},"1104":{"id":"/docs/lightning/web-app-49","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"**Node Settings → Services → Watchtowers**, the towers you\nconfigured with `lncli wtclient add` show up here too."},"1105":{"id":"/docs/lightning/web-app-50","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#walk-around-the-ui","content":"**Main takeaway:** you now have a proper dashboard on your LAN.\nEverything `lncli` does, RTL does with a mouse, plus graphs."},"1106":{"id":"/docs/lightning/web-app-51","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#upgrading-rtl","content":"As `admin`, stop the service and become `rtl`:"},"1107":{"id":"/docs/lightning/web-app-52","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#upgrading-rtl","content":"Fetch, find the latest tag, check it out, verify the signature,\nreinstall dependencies:"},"1108":{"id":"/docs/lightning/web-app-53","page_id":"/docs/lightning/web-app","tags":[],"type":"text","url":"/docs/lightning/web-app#upgrading-rtl","content":"Update `0.15.6` in `lib/versions.ts` to keep this\nguide honest, then restart:"},"1109":{"id":"/docs/bonus/lightning/ambossping","page_id":"/docs/bonus/lightning/ambossping","type":"page","content":"AmbossPing","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/ambossping"},"1110":{"id":"/docs/bonus/lightning/ambossping-0","page_id":"/docs/bonus/lightning/ambossping","tags":[],"type":"text","url":"/docs/bonus/lightning/ambossping","content":"Shell script that sends health-check heartbeats from your node to the amboss.space monitoring service."},"1111":{"id":"/docs/bonus/lightning/ambossping-1","page_id":"/docs/bonus/lightning/ambossping","tags":[],"type":"text","url":"/docs/bonus/lightning/ambossping","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1112":{"id":"/docs/bonus/lightning/ambossping-2","page_id":"/docs/bonus/lightning/ambossping","tags":[],"type":"text","url":"/docs/bonus/lightning/ambossping","content":"AmbossPing is a small bash script that pings\namboss.space on a schedule to keep your node's\nmonitoring status fresh. Link your Telegram account to Amboss and\nyou'll receive push alerts whenever the ping status changes, without\nneeding ThunderHub or a heavier dashboard."},"1113":{"id":"/docs/bonus/lightning/balance-of-satoshis","page_id":"/docs/bonus/lightning/balance-of-satoshis","type":"page","content":"Balance of Satoshis","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/balance-of-satoshis"},"1114":{"id":"/docs/bonus/lightning/balance-of-satoshis-0","page_id":"/docs/bonus/lightning/balance-of-satoshis","tags":[],"type":"text","url":"/docs/bonus/lightning/balance-of-satoshis","content":"LND power-user toolkit for rebalancing channels, monitoring the node, and driving a Telegram bot."},"1115":{"id":"/docs/bonus/lightning/balance-of-satoshis-1","page_id":"/docs/bonus/lightning/balance-of-satoshis","tags":[],"type":"text","url":"/docs/bonus/lightning/balance-of-satoshis","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1116":{"id":"/docs/bonus/lightning/balance-of-satoshis-2","page_id":"/docs/bonus/lightning/balance-of-satoshis","tags":[],"type":"text","url":"/docs/bonus/lightning/balance-of-satoshis","content":"Balance of Satoshis\n(BoS) is a CLI toolkit for LND from Alex Bosworth. Its rebalancing\ncommand is the headline feature, but BoS bundles dozens of other\nutilities, node monitoring, Telegram bot integration, payment\nrouting inspection, that extend what you can do beyond `lncli`."},"1117":{"id":"/docs/bonus/lightning/charge-lnd","page_id":"/docs/bonus/lightning/charge-lnd","type":"page","content":"charge-lnd","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/charge-lnd"},"1118":{"id":"/docs/bonus/lightning/charge-lnd-0","page_id":"/docs/bonus/lightning/charge-lnd","tags":[],"type":"text","url":"/docs/bonus/lightning/charge-lnd","content":"Policy-based fee manager for LND that sets per-channel fee rates from rules you define."},"1119":{"id":"/docs/bonus/lightning/charge-lnd-1","page_id":"/docs/bonus/lightning/charge-lnd","tags":[],"type":"text","url":"/docs/bonus/lightning/charge-lnd","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1120":{"id":"/docs/bonus/lightning/charge-lnd-2","page_id":"/docs/bonus/lightning/charge-lnd","tags":[],"type":"text","url":"/docs/bonus/lightning/charge-lnd","content":"charge-lnd is a simple,\npolicy-based fee manager for LND. You write rules matching groups\nof channels (by peer, liquidity ratio, or activity) and charge-lnd\napplies the matching fee rate on a schedule, so you stop tweaking\nchannel fees by hand."},"1121":{"id":"/docs/bonus/lightning/circuit-breaker","page_id":"/docs/bonus/lightning/circuit-breaker","type":"page","content":"Circuit Breaker","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/circuit-breaker"},"1122":{"id":"/docs/bonus/lightning/circuit-breaker-0","page_id":"/docs/bonus/lightning/circuit-breaker","tags":[],"type":"text","url":"/docs/bonus/lightning/circuit-breaker","content":"Lightning firewall that protects LND from HTLC-flooding griefing attacks."},"1123":{"id":"/docs/bonus/lightning/circuit-breaker-1","page_id":"/docs/bonus/lightning/circuit-breaker","tags":[],"type":"text","url":"/docs/bonus/lightning/circuit-breaker","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1124":{"id":"/docs/bonus/lightning/circuit-breaker-2","page_id":"/docs/bonus/lightning/circuit-breaker","tags":[],"type":"text","url":"/docs/bonus/lightning/circuit-breaker","content":"Circuit Breaker\nis a rate-limiting firewall for LND that protects against\nHTLC-flooding griefing attacks. You set per-peer limits, and Circuit\nBreaker refuses to forward HTLCs that would saturate a channel and\nlock your liquidity."},"1125":{"id":"/docs/bonus/lightning/clboss","page_id":"/docs/bonus/lightning/clboss","type":"page","content":"CLBoss","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/clboss"},"1126":{"id":"/docs/bonus/lightning/clboss-0","page_id":"/docs/bonus/lightning/clboss","tags":[],"type":"text","url":"/docs/bonus/lightning/clboss","content":"Automated channel and liquidity manager for Core Lightning that opens, rebalances, and re-prices channels on its own."},"1127":{"id":"/docs/bonus/lightning/clboss-1","page_id":"/docs/bonus/lightning/clboss","tags":[],"type":"text","url":"/docs/bonus/lightning/clboss","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1128":{"id":"/docs/bonus/lightning/clboss-2","page_id":"/docs/bonus/lightning/clboss","tags":[],"type":"text","url":"/docs/bonus/lightning/clboss","content":"CLBoss is an automated manager\nfor Core Lightning nodes. It picks useful peers to open channels\nwith, acquires inbound capacity through Boltz swaps, rebalances\nexisting channels, and sets competitive forwarding fees, so your\nCLN node can run largely on autopilot."},"1129":{"id":"/docs/bonus/lightning/cln","page_id":"/docs/bonus/lightning/cln","type":"page","content":"Core Lightning","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/cln"},"1130":{"id":"/docs/bonus/lightning/cln-0","page_id":"/docs/bonus/lightning/cln","tags":[],"type":"text","url":"/docs/bonus/lightning/cln","content":"Alternative Lightning implementation you can run instead of LND, or side-by-side with it on the same node."},"1131":{"id":"/docs/bonus/lightning/cln-1","page_id":"/docs/bonus/lightning/cln","tags":[],"type":"text","url":"/docs/bonus/lightning/cln","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1132":{"id":"/docs/bonus/lightning/cln-2","page_id":"/docs/bonus/lightning/cln","tags":[],"type":"text","url":"/docs/bonus/lightning/cln","content":"Core Lightning (CLN)\nis a lightweight, highly customizable implementation of the\nLightning Network protocol from Blockstream. You can run it as a\ndrop-in replacement for LND on your RaspiBolt, or alongside LND so\nboth implementations share the same `bitcoind`."},"1133":{"id":"/docs/bonus/lightning","page_id":"/docs/bonus/lightning","type":"page","content":"Lightning bonus","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning"},"1134":{"id":"/docs/bonus/lightning-0","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning","content":"Extra Lightning tooling, dashboards, liquidity managers, fee automation, alternative implementations, and wallets."},"1135":{"id":"/docs/bonus/lightning-1","page_id":"/docs/bonus/lightning","type":"heading","tags":[],"url":"/docs/bonus/lightning#whats-in-this-section","content":"What's in this section"},"1136":{"id":"/docs/bonus/lightning-2","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning","content":"This section gathers Lightning tools that extend what the core\nRaspiBolt gives you: browser dashboards, CLI status scripts,\nliquidity and fee automation, the Core Lightning implementation as\nan alternative or companion to LND, and wallets that talk to your\nnode over the local network."},"1137":{"id":"/docs/bonus/lightning-3","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning","content":"The bonus pages are still being rewritten for v4. Each page links to\nthe v3 source while we work through the backlog."},"1138":{"id":"/docs/bonus/lightning-4","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Browser-based LND node manager."},"1139":{"id":"/docs/bonus/lightning-5","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Web GUI for LND routing-node automation."},"1140":{"id":"/docs/bonus/lightning-6","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Interactive text-mode channel viewer."},"1141":{"id":"/docs/bonus/lightning-7","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Quick CLI balance summary."},"1142":{"id":"/docs/bonus/lightning-8","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Quick CLI channel summary."},"1143":{"id":"/docs/bonus/lightning-9","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Health-check pings to amboss.space."},"1144":{"id":"/docs/bonus/lightning-10","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"LND power-user toolkit for rebalancing and monitoring."},"1145":{"id":"/docs/bonus/lightning-11","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Policy-based fee manager for LND."},"1146":{"id":"/docs/bonus/lightning-12","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Firewall that protects LND from HTLC-flooding attacks."},"1147":{"id":"/docs/bonus/lightning-13","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Circular rebalancing CLI for LND."},"1148":{"id":"/docs/bonus/lightning-14","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Lightweight LND rebalancer in Go."},"1149":{"id":"/docs/bonus/lightning-15","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Alternative Lightning implementation you can run instead of or alongside LND."},"1150":{"id":"/docs/bonus/lightning-16","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Lightning wallet and accounts system with extensions."},"1151":{"id":"/docs/bonus/lightning-17","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Automated channel and liquidity manager for Core Lightning."},"1152":{"id":"/docs/bonus/lightning-18","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Lightning Labs UI for Loop and Pool."},"1153":{"id":"/docs/bonus/lightning-19","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Cross-platform desktop Lightning wallet."},"1154":{"id":"/docs/bonus/lightning-20","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"iOS Lightning wallet pointed at your node."},"1155":{"id":"/docs/bonus/lightning-21","page_id":"/docs/bonus/lightning","tags":[],"type":"text","url":"/docs/bonus/lightning#whats-in-this-section","content":"Run lncli from another computer on your network."},"1156":{"id":"/docs/bonus/lightning/lightning-terminal","page_id":"/docs/bonus/lightning/lightning-terminal","type":"page","content":"Lightning Terminal","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/lightning-terminal"},"1157":{"id":"/docs/bonus/lightning/lightning-terminal-0","page_id":"/docs/bonus/lightning/lightning-terminal","tags":[],"type":"text","url":"/docs/bonus/lightning/lightning-terminal","content":"Browser-based UI from Lightning Labs for managing LND channel liquidity with Loop and Pool."},"1158":{"id":"/docs/bonus/lightning/lightning-terminal-1","page_id":"/docs/bonus/lightning/lightning-terminal","tags":[],"type":"text","url":"/docs/bonus/lightning/lightning-terminal","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1159":{"id":"/docs/bonus/lightning/lightning-terminal-2","page_id":"/docs/bonus/lightning/lightning-terminal","tags":[],"type":"text","url":"/docs/bonus/lightning/lightning-terminal","content":"Lightning Terminal\nis a web UI from Lightning Labs that helps LND operators manage\nchannel liquidity through the commercial Loop and Pool services. It\nbundles those services in a single interface and is useful if you\nwant managed submarine swaps or liquidity leases without writing\nscripts."},"1160":{"id":"/docs/bonus/lightning/lnbalance","page_id":"/docs/bonus/lightning/lnbalance","type":"page","content":"lnbalance","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/lnbalance"},"1161":{"id":"/docs/bonus/lightning/lnbalance-0","page_id":"/docs/bonus/lightning/lnbalance","tags":[],"type":"text","url":"/docs/bonus/lightning/lnbalance","content":"Simple shell script that prints a quick balance overview for your Lightning node."},"1162":{"id":"/docs/bonus/lightning/lnbalance-1","page_id":"/docs/bonus/lightning/lnbalance","tags":[],"type":"text","url":"/docs/bonus/lightning/lnbalance","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1163":{"id":"/docs/bonus/lightning/lnbalance-2","page_id":"/docs/bonus/lightning/lnbalance","tags":[],"type":"text","url":"/docs/bonus/lightning/lnbalance","content":"`lnbalance` is a compact shell script by\nRobClark56 that prints a one-screen\nbalance summary for your Lightning node. It's handy when you want\nnumbers on-demand from the terminal without waiting on a heavier\ndashboard."},"1164":{"id":"/docs/bonus/lightning/lnbits","page_id":"/docs/bonus/lightning/lnbits","type":"page","content":"LNbits","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/lnbits"},"1165":{"id":"/docs/bonus/lightning/lnbits-0","page_id":"/docs/bonus/lightning/lnbits","tags":[],"type":"text","url":"/docs/bonus/lightning/lnbits","content":"Free and open-source Lightning wallet and accounts system with a plug-in extension model."},"1166":{"id":"/docs/bonus/lightning/lnbits-1","page_id":"/docs/bonus/lightning/lnbits","tags":[],"type":"text","url":"/docs/bonus/lightning/lnbits","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1167":{"id":"/docs/bonus/lightning/lnbits-2","page_id":"/docs/bonus/lightning/lnbits","tags":[],"type":"text","url":"/docs/bonus/lightning/lnbits","content":"LNbits is a free and open-source\nLightning wallet and accounts system. It sits on top of your node\nand lets you carve out sub-wallets with their own balances, APIs,\nand third-party integrations, handy for splitting a family node,\npowering a point of sale, or experimenting with LN extensions."},"1168":{"id":"/docs/bonus/lightning/lnchannels","page_id":"/docs/bonus/lightning/lnchannels","type":"page","content":"lnchannels","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/lnchannels"},"1169":{"id":"/docs/bonus/lightning/lnchannels-0","page_id":"/docs/bonus/lightning/lnchannels","tags":[],"type":"text","url":"/docs/bonus/lightning/lnchannels","content":"Simple shell script that prints a summary of all channels on your Lightning node."},"1170":{"id":"/docs/bonus/lightning/lnchannels-1","page_id":"/docs/bonus/lightning/lnchannels","tags":[],"type":"text","url":"/docs/bonus/lightning/lnchannels","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1171":{"id":"/docs/bonus/lightning/lnchannels-2","page_id":"/docs/bonus/lightning/lnchannels","tags":[],"type":"text","url":"/docs/bonus/lightning/lnchannels","content":"`lnchannels` is a companion script by\nRobClark56 that prints a clean\noverview of all your Lightning channels and their state. It pairs\nwell with `lnbalance` for quick, terminal-only status checks on the\nnode."},"1172":{"id":"/docs/bonus/lightning/lndg","page_id":"/docs/bonus/lightning/lndg","type":"page","content":"LNDg","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/lndg"},"1173":{"id":"/docs/bonus/lightning/lndg-0","page_id":"/docs/bonus/lightning/lndg","tags":[],"type":"text","url":"/docs/bonus/lightning/lndg","content":"Lightweight web GUI for power users to monitor and automate LND routing-node operations."},"1174":{"id":"/docs/bonus/lightning/lndg-1","page_id":"/docs/bonus/lightning/lndg","tags":[],"type":"text","url":"/docs/bonus/lightning/lndg","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1175":{"id":"/docs/bonus/lightning/lndg-2","page_id":"/docs/bonus/lightning/lndg","tags":[],"type":"text","url":"/docs/bonus/lightning/lndg","content":"LNDg is a lightweight web\ninterface for LND aimed at routing-node operators. It surfaces\nchannel and forwarding data and can automate rebalancing, fee\nadjustments, and channel opens so you spend less time manually\nrunning `lncli` commands."},"1176":{"id":"/docs/bonus/lightning/lntop","page_id":"/docs/bonus/lightning/lntop","type":"page","content":"lntop","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/lntop"},"1177":{"id":"/docs/bonus/lightning/lntop-0","page_id":"/docs/bonus/lightning/lntop","tags":[],"type":"text","url":"/docs/bonus/lightning/lntop","content":"Interactive text-mode channel viewer for Lightning nodes, inspired by htop."},"1178":{"id":"/docs/bonus/lightning/lntop-1","page_id":"/docs/bonus/lightning/lntop","tags":[],"type":"text","url":"/docs/bonus/lightning/lntop","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1179":{"id":"/docs/bonus/lightning/lntop-2","page_id":"/docs/bonus/lightning/lntop","tags":[],"type":"text","url":"/docs/bonus/lightning/lntop","content":"lntop is an interactive,\ntext-mode channels viewer for Lightning nodes on Unix systems. If\nyou live in the terminal, it gives you a compact, keyboard-driven\noverview of channel state and flow without spinning up a browser."},"1180":{"id":"/docs/bonus/lightning/rebalance-lnd","page_id":"/docs/bonus/lightning/rebalance-lnd","type":"page","content":"rebalance-lnd","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/rebalance-lnd"},"1181":{"id":"/docs/bonus/lightning/rebalance-lnd-0","page_id":"/docs/bonus/lightning/rebalance-lnd","tags":[],"type":"text","url":"/docs/bonus/lightning/rebalance-lnd","content":"Command-line tool for circular rebalancing of LND channels to even out local and remote liquidity."},"1182":{"id":"/docs/bonus/lightning/rebalance-lnd-1","page_id":"/docs/bonus/lightning/rebalance-lnd","tags":[],"type":"text","url":"/docs/bonus/lightning/rebalance-lnd","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1183":{"id":"/docs/bonus/lightning/rebalance-lnd-2","page_id":"/docs/bonus/lightning/rebalance-lnd","tags":[],"type":"text","url":"/docs/bonus/lightning/rebalance-lnd","content":"rebalance-lnd by Carsten\nOtto is a focused CLI tool for circular rebalancing on LND: it sends\nsats out of channels with too much outbound liquidity and routes\nthem back through channels that need inbound. Useful when you want\npredictable, scriptable rebalances without a full automation stack."},"1184":{"id":"/docs/bonus/lightning/regolancer","page_id":"/docs/bonus/lightning/regolancer","type":"page","content":"regolancer","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/regolancer"},"1185":{"id":"/docs/bonus/lightning/regolancer-0","page_id":"/docs/bonus/lightning/regolancer","tags":[],"type":"text","url":"/docs/bonus/lightning/regolancer","content":"Lightweight LND rebalancer written in Go, focused on fast and efficient circular rebalances."},"1186":{"id":"/docs/bonus/lightning/regolancer-1","page_id":"/docs/bonus/lightning/regolancer","tags":[],"type":"text","url":"/docs/bonus/lightning/regolancer","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1187":{"id":"/docs/bonus/lightning/regolancer-2","page_id":"/docs/bonus/lightning/regolancer","tags":[],"type":"text","url":"/docs/bonus/lightning/regolancer","content":"regolancer is a compact LND\nrebalancer written in Go. It's quick to set up and runs\nefficiently on a Raspberry Pi, making it a good match when you want\nroutine circular rebalances without the overhead of a larger\nautomation tool."},"1188":{"id":"/docs/bonus/lightning/remote-lncli","page_id":"/docs/bonus/lightning/remote-lncli","type":"page","content":"Remote lncli","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/remote-lncli"},"1189":{"id":"/docs/bonus/lightning/remote-lncli-0","page_id":"/docs/bonus/lightning/remote-lncli","tags":[],"type":"text","url":"/docs/bonus/lightning/remote-lncli","content":"Run lncli from a separate computer on your network to control your RaspiBolt Lightning node remotely."},"1190":{"id":"/docs/bonus/lightning/remote-lncli-1","page_id":"/docs/bonus/lightning/remote-lncli","tags":[],"type":"text","url":"/docs/bonus/lightning/remote-lncli","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1191":{"id":"/docs/bonus/lightning/remote-lncli-2","page_id":"/docs/bonus/lightning/remote-lncli","tags":[],"type":"text","url":"/docs/bonus/lightning/remote-lncli","content":"This guide shows how to run `lncli` on a different machine on your\nnetwork, typically a Windows or Linux desktop, while LND itself\nkeeps running on the RaspiBolt. You get a responsive CLI without\nhaving to SSH into the node every time you want to inspect or drive\nit."},"1192":{"id":"/docs/bonus/lightning/thunderhub","page_id":"/docs/bonus/lightning/thunderhub","type":"page","content":"ThunderHub","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/thunderhub"},"1193":{"id":"/docs/bonus/lightning/thunderhub-0","page_id":"/docs/bonus/lightning/thunderhub","tags":[],"type":"text","url":"/docs/bonus/lightning/thunderhub","content":"Open-source browser dashboard for managing and monitoring an LND node from any device."},"1194":{"id":"/docs/bonus/lightning/thunderhub-1","page_id":"/docs/bonus/lightning/thunderhub","tags":[],"type":"text","url":"/docs/bonus/lightning/thunderhub","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1195":{"id":"/docs/bonus/lightning/thunderhub-2","page_id":"/docs/bonus/lightning/thunderhub","tags":[],"type":"text","url":"/docs/bonus/lightning/thunderhub","content":"ThunderHub is an\nopen-source LND node manager that runs in your browser. It gives you\nan intuitive UI for the full range of node operations, channels,\npayments, forwards, backups, accessible from any device on your\nnetwork."},"1196":{"id":"/docs/bonus/lightning/zap-desktop","page_id":"/docs/bonus/lightning/zap-desktop","type":"page","content":"Zap Desktop","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/zap-desktop"},"1197":{"id":"/docs/bonus/lightning/zap-desktop-0","page_id":"/docs/bonus/lightning/zap-desktop","tags":[],"type":"text","url":"/docs/bonus/lightning/zap-desktop","content":"Cross-platform Lightning Network wallet with a focus on user experience and ease of use."},"1198":{"id":"/docs/bonus/lightning/zap-desktop-1","page_id":"/docs/bonus/lightning/zap-desktop","tags":[],"type":"text","url":"/docs/bonus/lightning/zap-desktop","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1199":{"id":"/docs/bonus/lightning/zap-desktop-2","page_id":"/docs/bonus/lightning/zap-desktop","tags":[],"type":"text","url":"/docs/bonus/lightning/zap-desktop","content":"Zap Desktop is a\ncross-platform Lightning Network wallet focused on a smooth UX.\nPointing it at your RaspiBolt over gRPC gives you a graphical\ndesktop wallet that spends and receives using your own channels,\nno custodial backend in the middle."},"1200":{"id":"/docs/bonus/lightning/zap-ios","page_id":"/docs/bonus/lightning/zap-ios","type":"page","content":"Zap (iOS)","breadcrumbs":["Docs","Bonus","Lightning bonus"],"tags":[],"url":"/docs/bonus/lightning/zap-ios"},"1201":{"id":"/docs/bonus/lightning/zap-ios-0","page_id":"/docs/bonus/lightning/zap-ios","tags":[],"type":"text","url":"/docs/bonus/lightning/zap-ios","content":"iOS Lightning wallet that connects to your RaspiBolt over the local network for peer, channel, and payment management."},"1202":{"id":"/docs/bonus/lightning/zap-ios-1","page_id":"/docs/bonus/lightning/zap-ios","tags":[],"type":"text","url":"/docs/bonus/lightning/zap-ios","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1203":{"id":"/docs/bonus/lightning/zap-ios-2","page_id":"/docs/bonus/lightning/zap-ios","tags":[],"type":"text","url":"/docs/bonus/lightning/zap-ios","content":"Zap iOS is an iPhone Lightning\nwallet that talks to your own LND node over gRPC. It gives you a\nclean mobile UI for managing peers, opening channels, making\npayments, and generating invoices, all backed by the node running\nin your own home."},"1204":{"id":"/docs/bonus/raspberry-pi/aliases","page_id":"/docs/bonus/raspberry-pi/aliases","type":"page","content":"Aliases","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/aliases"},"1205":{"id":"/docs/bonus/raspberry-pi/aliases-0","page_id":"/docs/bonus/raspberry-pi/aliases","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/aliases","content":"Set up shell aliases for common node-management commands to cut typing and memorization."},"1206":{"id":"/docs/bonus/raspberry-pi/aliases-1","page_id":"/docs/bonus/raspberry-pi/aliases","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/aliases","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1207":{"id":"/docs/bonus/raspberry-pi/aliases-2","page_id":"/docs/bonus/raspberry-pi/aliases","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/aliases","content":"Aliases are shortcuts for long or frequently used shell commands.\nThe guide installs a curated `.bash_aliases` file so `admin` gets\nconcise shortcuts for inspecting Bitcoin Core, LND, system logs, and\nservice status, saving you the muscle memory of typing the full\ncommand every time."},"1208":{"id":"/docs/bonus/raspberry-pi/boot-from-microsd-card","page_id":"/docs/bonus/raspberry-pi/boot-from-microsd-card","type":"page","content":"Boot from microSD card","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/boot-from-microsd-card"},"1209":{"id":"/docs/bonus/raspberry-pi/boot-from-microsd-card-0","page_id":"/docs/bonus/raspberry-pi/boot-from-microsd-card","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/boot-from-microsd-card","content":"Boot the Raspberry Pi from microSD while using the external drive for blockchain and application data."},"1210":{"id":"/docs/bonus/raspberry-pi/boot-from-microsd-card-1","page_id":"/docs/bonus/raspberry-pi/boot-from-microsd-card","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/boot-from-microsd-card","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1211":{"id":"/docs/bonus/raspberry-pi/boot-from-microsd-card-2","page_id":"/docs/bonus/raspberry-pi/boot-from-microsd-card","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/boot-from-microsd-card","content":"Not every Raspberry Pi can boot directly from an external drive. If\nyours can't, or your USB-SATA enclosure is picky, this guide sets\nup a split configuration: boot the OS from a microSD card, then mount\nthe external drive for all the application and blockchain data."},"1212":{"id":"/docs/bonus/raspberry-pi/command-line","page_id":"/docs/bonus/raspberry-pi/command-line","type":"page","content":"Pimp the command line","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/command-line"},"1213":{"id":"/docs/bonus/raspberry-pi/command-line-0","page_id":"/docs/bonus/raspberry-pi/command-line","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/command-line","content":"Customize your shell prompt with colors and a Bitcoin symbol, and make ls output easier to read."},"1214":{"id":"/docs/bonus/raspberry-pi/command-line-1","page_id":"/docs/bonus/raspberry-pi/command-line","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/command-line","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1215":{"id":"/docs/bonus/raspberry-pi/command-line-2","page_id":"/docs/bonus/raspberry-pi/command-line","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/command-line","content":"A small quality-of-life tweak: make your shell prompt shine with a\ngolden Bitcoin symbol, enable color output for `ls`, and nudge the\ndefaults so the terminal is easier on the eyes. Purely cosmetic, but\nit takes two minutes and you'll appreciate it every time you log\nback in."},"1216":{"id":"/docs/bonus/raspberry-pi/go","page_id":"/docs/bonus/raspberry-pi/go","type":"page","content":"Install Go","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/go"},"1217":{"id":"/docs/bonus/raspberry-pi/go-0","page_id":"/docs/bonus/raspberry-pi/go","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/go","content":"Install, update, or uninstall the Go toolchain, which several bonus tools require."},"1218":{"id":"/docs/bonus/raspberry-pi/go-1","page_id":"/docs/bonus/raspberry-pi/go","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/go","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1219":{"id":"/docs/bonus/raspberry-pi/go-2","page_id":"/docs/bonus/raspberry-pi/go","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/go","content":"A few RaspiBolt bonus tools (regolancer and some monitoring\nhelpers) are written in Go. This short guide handles\ninstalling, upgrading, and removing the Go toolchain on the Pi, so\nyou can build those tools yourself without polluting the rest of\nthe system."},"1220":{"id":"/docs/bonus/raspberry-pi/homer","page_id":"/docs/bonus/raspberry-pi/homer","type":"page","content":"Homer","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/homer"},"1221":{"id":"/docs/bonus/raspberry-pi/homer-0","page_id":"/docs/bonus/raspberry-pi/homer","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/homer","content":"Browser-based dashboard with quick links to every web service running on your node."},"1222":{"id":"/docs/bonus/raspberry-pi/homer-1","page_id":"/docs/bonus/raspberry-pi/homer","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/homer","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1223":{"id":"/docs/bonus/raspberry-pi/homer-2","page_id":"/docs/bonus/raspberry-pi/homer","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/homer","content":"Homer is a simple\nbrowser-based dashboard for your self-hosted services. You list your\nweb tools in a YAML file and Homer renders a clean, bookmarkable\nhomepage, one click into RTL, ThunderHub, Mempool, BTC RPC\nExplorer, or whatever else you've spun up."},"1224":{"id":"/docs/bonus/raspberry-pi","page_id":"/docs/bonus/raspberry-pi","type":"page","content":"Raspberry Pi bonus","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi"},"1225":{"id":"/docs/bonus/raspberry-pi-0","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi","content":"Quality-of-life tweaks, alternative hardware, and operational helpers for the host system under your node."},"1226":{"id":"/docs/bonus/raspberry-pi-1","page_id":"/docs/bonus/raspberry-pi","type":"heading","tags":[],"url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"What's in this section"},"1227":{"id":"/docs/bonus/raspberry-pi-2","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi","content":"This section covers the host system rather than the Bitcoin or\nLightning stack: shell tweaks, dashboards, alternative boot and\nhardware configurations, UPS integration, and hardware-wallet-based\nSSH. None of it is required for a working node, it's what you\nreach for when you're ready to polish the setup."},"1228":{"id":"/docs/bonus/raspberry-pi-3","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi","content":"The bonus pages are still being rewritten for v4. Each page links to\nthe v3 source while we work through the backlog."},"1229":{"id":"/docs/bonus/raspberry-pi-4","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Login dashboard with node and system status."},"1230":{"id":"/docs/bonus/raspberry-pi-5","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Shell shortcuts for common node-management commands."},"1231":{"id":"/docs/bonus/raspberry-pi-6","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Colorful prompt and nicer ls defaults."},"1232":{"id":"/docs/bonus/raspberry-pi-7","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Browser dashboard with links to all your web services."},"1233":{"id":"/docs/bonus/raspberry-pi-8","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Install, update, or uninstall the Go toolchain."},"1234":{"id":"/docs/bonus/raspberry-pi-9","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Boot from microSD and use the external drive for data."},"1235":{"id":"/docs/bonus/raspberry-pi-10","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Migrate your node data to a larger drive."},"1236":{"id":"/docs/bonus/raspberry-pi-11","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Run RaspiBolt on an Odroid XU4 or compatible board."},"1237":{"id":"/docs/bonus/raspberry-pi-12","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Use a Trezor as a hardware-backed SSH key."},"1238":{"id":"/docs/bonus/raspberry-pi-13","page_id":"/docs/bonus/raspberry-pi","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi#whats-in-this-section","content":"Graceful shutdown when a connected UPS runs low."},"1239":{"id":"/docs/bonus/raspberry-pi/odroid-setup","page_id":"/docs/bonus/raspberry-pi/odroid-setup","type":"page","content":"Odroid setup","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/odroid-setup"},"1240":{"id":"/docs/bonus/raspberry-pi/odroid-setup-0","page_id":"/docs/bonus/raspberry-pi/odroid-setup","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/odroid-setup","content":"Run the RaspiBolt stack on an Odroid XU4 or compatible board as an alternative to a Raspberry Pi."},"1241":{"id":"/docs/bonus/raspberry-pi/odroid-setup-1","page_id":"/docs/bonus/raspberry-pi/odroid-setup","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/odroid-setup","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1242":{"id":"/docs/bonus/raspberry-pi/odroid-setup-2","page_id":"/docs/bonus/raspberry-pi/odroid-setup","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/odroid-setup","content":"If you'd rather run RaspiBolt on different hardware, this guide\nadapts the setup to the Odroid XU4\nand compatible boards like the HC1 and HC2. The main guide's\nsoftware choices still apply, only the OS bring-up and a handful\nof platform-specific tweaks change."},"1243":{"id":"/docs/bonus/raspberry-pi/system-overview","page_id":"/docs/bonus/raspberry-pi/system-overview","type":"page","content":"System overview","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/system-overview"},"1244":{"id":"/docs/bonus/raspberry-pi/system-overview-0","page_id":"/docs/bonus/raspberry-pi/system-overview","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/system-overview","content":"Greet yourself on SSH login with a one-screen status dashboard of Bitcoin, Lightning, and system health."},"1245":{"id":"/docs/bonus/raspberry-pi/system-overview-1","page_id":"/docs/bonus/raspberry-pi/system-overview","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/system-overview","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1246":{"id":"/docs/bonus/raspberry-pi/system-overview-2","page_id":"/docs/bonus/raspberry-pi/system-overview","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/system-overview","content":"The raspibolt-pulse\nscript prints a dense, color-coded status overview on every SSH\nlogin, block height, channel balances, disk usage, memory, and\nservice health all in one glance. It's the fastest way to confirm\nthe node is healthy before you start tinkering."},"1247":{"id":"/docs/bonus/raspberry-pi/trezor-agent","page_id":"/docs/bonus/raspberry-pi/trezor-agent","type":"page","content":"Trezor SSH agent","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/trezor-agent"},"1248":{"id":"/docs/bonus/raspberry-pi/trezor-agent-0","page_id":"/docs/bonus/raspberry-pi/trezor-agent","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/trezor-agent","content":"Use a Trezor hardware wallet as a second factor for SSH authentication to your node."},"1249":{"id":"/docs/bonus/raspberry-pi/trezor-agent-1","page_id":"/docs/bonus/raspberry-pi/trezor-agent","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/trezor-agent","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1250":{"id":"/docs/bonus/raspberry-pi/trezor-agent-2","page_id":"/docs/bonus/raspberry-pi/trezor-agent","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/trezor-agent","content":"Instead of trusting a plain SSH key on your laptop, you can let a\nTrezor hardware wallet sign SSH challenges. Your key never leaves\nthe device, and every login prompts you to physically confirm on\nthe Trezor, a meaningful bump in security for the admin account\nthat runs your node."},"1251":{"id":"/docs/bonus/raspberry-pi/upgrade-external-drive","page_id":"/docs/bonus/raspberry-pi/upgrade-external-drive","type":"page","content":"Upgrade external drive","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/upgrade-external-drive"},"1252":{"id":"/docs/bonus/raspberry-pi/upgrade-external-drive-0","page_id":"/docs/bonus/raspberry-pi/upgrade-external-drive","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/upgrade-external-drive","content":"Migrate from a smaller to a larger external drive as the blockchain outgrows your current storage."},"1253":{"id":"/docs/bonus/raspberry-pi/upgrade-external-drive-1","page_id":"/docs/bonus/raspberry-pi/upgrade-external-drive","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/upgrade-external-drive","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1254":{"id":"/docs/bonus/raspberry-pi/upgrade-external-drive-2","page_id":"/docs/bonus/raspberry-pi/upgrade-external-drive","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/upgrade-external-drive","content":"The blockchain keeps growing, so the 1 TB drive that felt generous\nthree years ago will eventually fill up. This guide walks through\ncloning your node's data onto a larger drive and swapping it in\nwithout losing channels or state, minimizing downtime for your\nLightning node along the way."},"1255":{"id":"/docs/bonus/raspberry-pi/ups-nut","page_id":"/docs/bonus/raspberry-pi/ups-nut","type":"page","content":"UPS with NUT","breadcrumbs":["Docs","Bonus","Raspberry Pi bonus"],"tags":[],"url":"/docs/bonus/raspberry-pi/ups-nut"},"1256":{"id":"/docs/bonus/raspberry-pi/ups-nut-0","page_id":"/docs/bonus/raspberry-pi/ups-nut","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/ups-nut","content":"Configure Network UPS Tools so your node shuts down cleanly when a connected UPS reaches a critical battery level."},"1257":{"id":"/docs/bonus/raspberry-pi/ups-nut-1","page_id":"/docs/bonus/raspberry-pi/ups-nut","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/ups-nut","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1258":{"id":"/docs/bonus/raspberry-pi/ups-nut-2","page_id":"/docs/bonus/raspberry-pi/ups-nut","tags":[],"type":"text","url":"/docs/bonus/raspberry-pi/ups-nut","content":"A sudden power loss can corrupt the Bitcoin or LND database and\nforce a lengthy resync. With a UPS and\nNetwork UPS Tools (NUT), your node\nwatches the battery level and triggers a clean shutdown before the\nUPS runs out, turning a brownout into a five-minute nuisance\ninstead of hours of downtime."},"1259":{"id":"/docs/bonus/bitcoin/Jam","page_id":"/docs/bonus/bitcoin/Jam","type":"page","content":"JAM (JoinMarket UI)","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/Jam"},"1260":{"id":"/docs/bonus/bitcoin/Jam-0","page_id":"/docs/bonus/bitcoin/Jam","tags":[],"type":"text","url":"/docs/bonus/bitcoin/Jam","content":"Web interface for JoinMarket focused on user-friendliness, with sensible defaults for CoinJoin newcomers."},"1261":{"id":"/docs/bonus/bitcoin/Jam-1","page_id":"/docs/bonus/bitcoin/Jam","tags":[],"type":"text","url":"/docs/bonus/bitcoin/Jam","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1262":{"id":"/docs/bonus/bitcoin/Jam-2","page_id":"/docs/bonus/bitcoin/Jam","tags":[],"type":"text","url":"/docs/bonus/bitcoin/Jam","content":"JAM is a web interface for\nJoinMarket that aims to make CoinJoin accessible to non-expert users.\nIt ships sensible defaults and a browser-based UI while still\nexposing the advanced knobs experienced JoinMarket users rely on."},"1263":{"id":"/docs/bonus/bitcoin/UTXOracle","page_id":"/docs/bonus/bitcoin/UTXOracle","type":"page","content":"UTXOracle","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/UTXOracle"},"1264":{"id":"/docs/bonus/bitcoin/UTXOracle-0","page_id":"/docs/bonus/bitcoin/UTXOracle","tags":[],"type":"text","url":"/docs/bonus/bitcoin/UTXOracle","content":"Python script that estimates the BTC/USD price from your own blockchain data, no external exchange required."},"1265":{"id":"/docs/bonus/bitcoin/UTXOracle-1","page_id":"/docs/bonus/bitcoin/UTXOracle","tags":[],"type":"text","url":"/docs/bonus/bitcoin/UTXOracle","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1266":{"id":"/docs/bonus/bitcoin/UTXOracle-2","page_id":"/docs/bonus/bitcoin/UTXOracle","tags":[],"type":"text","url":"/docs/bonus/bitcoin/UTXOracle","content":"UTXOracle is a Python script by Daniel Hinton\nand Steve Jeffress that derives a close BTC/USD price estimate directly\nfrom on-chain data, without talking to any exchange or external API.\nIt works because a predictable share of transaction outputs land on\nround-dollar amounts, so the blockchain itself carries enough signal\nto reconstruct a price."},"1267":{"id":"/docs/bonus/bitcoin/bisq","page_id":"/docs/bonus/bitcoin/bisq","type":"page","content":"Bisq","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/bisq"},"1268":{"id":"/docs/bonus/bitcoin/bisq-0","page_id":"/docs/bonus/bitcoin/bisq","tags":[],"type":"text","url":"/docs/bonus/bitcoin/bisq","content":"Decentralized desktop exchange for privately buying and selling non-KYC bitcoin."},"1269":{"id":"/docs/bonus/bitcoin/bisq-1","page_id":"/docs/bonus/bitcoin/bisq","tags":[],"type":"text","url":"/docs/bonus/bitcoin/bisq","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1270":{"id":"/docs/bonus/bitcoin/bisq-2","page_id":"/docs/bonus/bitcoin/bisq","tags":[],"type":"text","url":"/docs/bonus/bitcoin/bisq","content":"Bisq is a decentralized bitcoin exchange, a\ndesktop application that offers a private, censorship-resistant way\nto swap bitcoin for national currencies and other cryptocurrencies\nover the internet. Pointing Bisq at your own node keeps transaction\nlookups off third-party servers."},"1271":{"id":"/docs/bonus/bitcoin/bitboxapp","page_id":"/docs/bonus/bitcoin/bitboxapp","type":"page","content":"BitBoxApp","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/bitboxapp"},"1272":{"id":"/docs/bonus/bitcoin/bitboxapp-0","page_id":"/docs/bonus/bitcoin/bitboxapp","tags":[],"type":"text","url":"/docs/bonus/bitcoin/bitboxapp","content":"Beginner-friendly desktop wallet for the BitBox02 hardware wallet, pointed at your own node."},"1273":{"id":"/docs/bonus/bitcoin/bitboxapp-1","page_id":"/docs/bonus/bitcoin/bitboxapp","tags":[],"type":"text","url":"/docs/bonus/bitcoin/bitboxapp","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1274":{"id":"/docs/bonus/bitcoin/bitboxapp-2","page_id":"/docs/bonus/bitcoin/bitboxapp","tags":[],"type":"text","url":"/docs/bonus/bitcoin/bitboxapp","content":"The BitBoxApp is the beginner-friendly\ncompanion app to the BitBox02 hardware wallet from Shift Crypto. By\nconfiguring it to connect directly to your RaspiBolt instead of\nShift's servers, you verify your own transactions and avoid leaking\nwallet addresses to a third party."},"1275":{"id":"/docs/bonus/bitcoin/dojo","page_id":"/docs/bonus/bitcoin/dojo","type":"page","content":"Samourai Dojo","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/dojo"},"1276":{"id":"/docs/bonus/bitcoin/dojo-0","page_id":"/docs/bonus/bitcoin/dojo","tags":[],"type":"text","url":"/docs/bonus/bitcoin/dojo","content":"Personal backend for Samourai Wallet, HD account balances, BIP47 support, and transaction broadcasts via your own node."},"1277":{"id":"/docs/bonus/bitcoin/dojo-1","page_id":"/docs/bonus/bitcoin/dojo","tags":[],"type":"text","url":"/docs/bonus/bitcoin/dojo","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1278":{"id":"/docs/bonus/bitcoin/dojo-2","page_id":"/docs/bonus/bitcoin/dojo","tags":[],"type":"text","url":"/docs/bonus/bitcoin/dojo","content":"Samourai Dojo is the\nbacking server for Samourai Wallet. It exposes HD account and BIP47\nbalance and transaction data, serves unspent output lists, and\nbroadcasts transactions through your own `bitcoind`, removing the\nreliance on Samourai's hosted servers."},"1279":{"id":"/docs/bonus/bitcoin/electrum-personal-server","page_id":"/docs/bonus/bitcoin/electrum-personal-server","type":"page","content":"Electrum Personal Server","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/electrum-personal-server"},"1280":{"id":"/docs/bonus/bitcoin/electrum-personal-server-0","page_id":"/docs/bonus/bitcoin/electrum-personal-server","tags":[],"type":"text","url":"/docs/bonus/bitcoin/electrum-personal-server","content":"Lightweight Electrum server that serves only your own wallets, as an alternative to Electrs or Fulcrum."},"1281":{"id":"/docs/bonus/bitcoin/electrum-personal-server-1","page_id":"/docs/bonus/bitcoin/electrum-personal-server","tags":[],"type":"text","url":"/docs/bonus/bitcoin/electrum-personal-server","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1282":{"id":"/docs/bonus/bitcoin/electrum-personal-server-2","page_id":"/docs/bonus/bitcoin/electrum-personal-server","tags":[],"type":"text","url":"/docs/bonus/bitcoin/electrum-personal-server","content":"Electrum Personal Server\nis an alternative to Electrs and Fulcrum that only indexes the\naddresses in your own wallets rather than the entire chain. It uses\nfar less disk space at the cost of advance wallet registration and\nslower lookups for new addresses."},"1283":{"id":"/docs/bonus/bitcoin/electrum-wallet-desktop","page_id":"/docs/bonus/bitcoin/electrum-wallet-desktop","type":"page","content":"Electrum Wallet Desktop","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/electrum-wallet-desktop"},"1284":{"id":"/docs/bonus/bitcoin/electrum-wallet-desktop-0","page_id":"/docs/bonus/bitcoin/electrum-wallet-desktop","tags":[],"type":"text","url":"/docs/bonus/bitcoin/electrum-wallet-desktop","content":"Feature-rich desktop Bitcoin wallet for power users, connected to your own Electrum server."},"1285":{"id":"/docs/bonus/bitcoin/electrum-wallet-desktop-1","page_id":"/docs/bonus/bitcoin/electrum-wallet-desktop","tags":[],"type":"text","url":"/docs/bonus/bitcoin/electrum-wallet-desktop","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1286":{"id":"/docs/bonus/bitcoin/electrum-wallet-desktop-2","page_id":"/docs/bonus/bitcoin/electrum-wallet-desktop","tags":[],"type":"text","url":"/docs/bonus/bitcoin/electrum-wallet-desktop","content":"Electrum Wallet is a well-established,\nfeature-rich Bitcoin wallet for power users with broad hardware\nwallet support. Pointing it at your own Electrs or Fulcrum server\nkeeps address lookups private and removes the dependency on public\nElectrum servers."},"1287":{"id":"/docs/bonus/bitcoin/fulcrum","page_id":"/docs/bonus/bitcoin/fulcrum","type":"page","content":"Fulcrum","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/fulcrum"},"1288":{"id":"/docs/bonus/bitcoin/fulcrum-0","page_id":"/docs/bonus/bitcoin/fulcrum","tags":[],"type":"text","url":"/docs/bonus/bitcoin/fulcrum","content":"Fast and nimble Electrum-compatible SPV server, a performance-focused alternative to Electrs."},"1289":{"id":"/docs/bonus/bitcoin/fulcrum-1","page_id":"/docs/bonus/bitcoin/fulcrum","tags":[],"type":"text","url":"/docs/bonus/bitcoin/fulcrum","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1290":{"id":"/docs/bonus/bitcoin/fulcrum-2","page_id":"/docs/bonus/bitcoin/fulcrum","tags":[],"type":"text","url":"/docs/bonus/bitcoin/fulcrum","content":"Fulcrum is a fast SPV server\nfor Bitcoin, Bitcoin Cash, and Litecoin written in C++ by Calin\nCulianu. Independent benchmarks rank it as one of the quickest\nElectrum server implementations available, which makes it a solid\nalternative to Electrs when you want lower query latency."},"1291":{"id":"/docs/bonus/bitcoin/i2p","page_id":"/docs/bonus/bitcoin/i2p","type":"page","content":"I2P","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/i2p"},"1292":{"id":"/docs/bonus/bitcoin/i2p-0","page_id":"/docs/bonus/bitcoin/i2p","tags":[],"type":"text","url":"/docs/bonus/bitcoin/i2p","content":"Anonymous network layer you can run alongside Tor to give Bitcoin Core a second private transport."},"1293":{"id":"/docs/bonus/bitcoin/i2p-1","page_id":"/docs/bonus/bitcoin/i2p","tags":[],"type":"text","url":"/docs/bonus/bitcoin/i2p","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1294":{"id":"/docs/bonus/bitcoin/i2p-2","page_id":"/docs/bonus/bitcoin/i2p","tags":[],"type":"text","url":"/docs/bonus/bitcoin/i2p","content":"I2P, the Invisible Internet Protocol, is\nan anonymous, end-to-end encrypted network layer where peers never\nsee each other's real IP addresses. The guide installs\ni2pd, a C++ I2P daemon, so Bitcoin\nCore can reach peers over I2P in addition to clearnet and Tor."},"1295":{"id":"/docs/bonus/bitcoin","page_id":"/docs/bonus/bitcoin","type":"page","content":"Bitcoin bonus","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin"},"1296":{"id":"/docs/bonus/bitcoin-0","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin","content":"Additional Bitcoin software, explorers, wallets, alternative Electrum servers, privacy tools, and testnet."},"1297":{"id":"/docs/bonus/bitcoin-1","page_id":"/docs/bonus/bitcoin","type":"heading","tags":[],"url":"/docs/bonus/bitcoin#whats-in-this-section","content":"What's in this section"},"1298":{"id":"/docs/bonus/bitcoin-2","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin","content":"This section covers Bitcoin tooling that goes beyond the core\nRaspiBolt setup. You'll find self-hosted block explorers, desktop\nand CLI wallets, alternative Electrum server implementations,\nprivacy layers like JoinMarket and I2P, and a testnet variant of\nthe whole stack. Pick the pieces that match how you use your node."},"1299":{"id":"/docs/bonus/bitcoin-3","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin","content":"The bonus pages are still being rewritten for v4. Each page links to\nthe v3 source while we work through the backlog."},"1300":{"id":"/docs/bonus/bitcoin-4","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Self-hosted Bitcoin blockchain and mempool visualizer."},"1301":{"id":"/docs/bonus/bitcoin-5","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Estimate the BTC/USD price from your own blockchain data."},"1302":{"id":"/docs/bonus/bitcoin-6","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Reconstruct the Bitcoin white paper PDF from on-chain data."},"1303":{"id":"/docs/bonus/bitcoin-7","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Decentralized desktop exchange for non-KYC bitcoin."},"1304":{"id":"/docs/bonus/bitcoin-8","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Beginner-friendly companion app for the BitBox02."},"1305":{"id":"/docs/bonus/bitcoin-9","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Feature-rich desktop wallet for power users."},"1306":{"id":"/docs/bonus/bitcoin-10","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Bitcoin Core GUI focused on multisig with hardware wallets."},"1307":{"id":"/docs/bonus/bitcoin-11","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Headless Sparrow for systems without a display."},"1308":{"id":"/docs/bonus/bitcoin-12","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Personal backend for Samourai Wallet."},"1309":{"id":"/docs/bonus/bitcoin-13","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Lightweight Electrum server that indexes only your wallets."},"1310":{"id":"/docs/bonus/bitcoin-14","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Fast Electrum-compatible SPV server, alternative to Electrs."},"1311":{"id":"/docs/bonus/bitcoin-15","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Decentralized marketplace for CoinJoin transactions."},"1312":{"id":"/docs/bonus/bitcoin-16","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Friendly web interface for JoinMarket."},"1313":{"id":"/docs/bonus/bitcoin-17","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Anonymous network layer alongside Tor for Bitcoin Core."},"1314":{"id":"/docs/bonus/bitcoin-18","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"DIY steel backup for your seed phrases."},"1315":{"id":"/docs/bonus/bitcoin-19","page_id":"/docs/bonus/bitcoin","tags":[],"type":"text","url":"/docs/bonus/bitcoin#whats-in-this-section","content":"Run the full stack on testnet for safe experimentation."},"1316":{"id":"/docs/bonus/bitcoin/joinmarket","page_id":"/docs/bonus/bitcoin/joinmarket","type":"page","content":"JoinMarket","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/joinmarket"},"1317":{"id":"/docs/bonus/bitcoin/joinmarket-0","page_id":"/docs/bonus/bitcoin/joinmarket","tags":[],"type":"text","url":"/docs/bonus/bitcoin/joinmarket","content":"Decentralized marketplace for CoinJoin transactions to improve on-chain privacy, with optional yield from providing liquidity."},"1318":{"id":"/docs/bonus/bitcoin/joinmarket-1","page_id":"/docs/bonus/bitcoin/joinmarket","tags":[],"type":"text","url":"/docs/bonus/bitcoin/joinmarket","content":"This bonus page hasn't been rewritten for RaspiBolt v4 yet. The v3\nversion still works, see the original guide on GitHub\nwhile we port it over."},"1319":{"id":"/docs/bonus/bitcoin/joinmarket-2","page_id":"/docs/bonus/bitcoin/joinmarket","tags":[],"type":"text","url":"/docs/bonus/bitcoin/joinmarket","content":"JoinMarket\nis a decentralized marketplace for CoinJoin transactions. Running it\non your node lets you either mix your own coins by paying a small\nfee or become a liquidity maker and earn sats for providing the\ninputs others use to mix."},"1320":{"id":"/docs/bonus/bitcoin/mempool","page_id":"/docs/bonus/bitcoin/mempool","type":"page","content":"Mempool Explorer","breadcrumbs":["Docs","Bonus","Bitcoin bonus"],"tags":[],"url":"/docs/bonus/bitcoin/mempool"},"1321":{"id":"/docs/bonus/bitcoin/mempool-0","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool","content":"Self-hosted Bitcoin mempool visualizer and block explorer. Build Mempool v3 from source, MariaDB backend, Caddy HTTPS on port 4080."},"1322":{"id":"/docs/bonus/bitcoin/mempool-1","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#requirements","content":"Requirements"},"1323":{"id":"/docs/bonus/bitcoin/mempool-2","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#create-the-user","content":"Create the user"},"1324":{"id":"/docs/bonus/bitcoin/mempool-3","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#install-build-dependencies","content":"Install build dependencies"},"1325":{"id":"/docs/bonus/bitcoin/mempool-4","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#set-up-mariadb","content":"Set up MariaDB"},"1326":{"id":"/docs/bonus/bitcoin/mempool-5","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#install-mempool","content":"Install Mempool"},"1327":{"id":"/docs/bonus/bitcoin/mempool-6","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#configure-the-backend","content":"Configure the backend"},"1328":{"id":"/docs/bonus/bitcoin/mempool-7","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#build-the-backend","content":"Build the backend"},"1329":{"id":"/docs/bonus/bitcoin/mempool-8","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#build-the-frontend","content":"Build the frontend"},"1330":{"id":"/docs/bonus/bitcoin/mempool-9","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#autostart-on-boot","content":"Autostart on boot"},"1331":{"id":"/docs/bonus/bitcoin/mempool-10","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"HTTPS on the LAN with Caddy"},"1332":{"id":"/docs/bonus/bitcoin/mempool-11","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#upgrade","content":"Upgrade"},"1333":{"id":"/docs/bonus/bitcoin/mempool-12","page_id":"/docs/bonus/bitcoin/mempool","type":"heading","tags":[],"url":"/docs/bonus/bitcoin/mempool#uninstall","content":"Uninstall"},"1334":{"id":"/docs/bonus/bitcoin/mempool-13","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool","content":"Mempool is the same open-source\ncode that runs mempool.space, self-hosted on your own node. Transaction\nlookups, fee estimates, and UTXO queries stay on your LAN and never\nreach a third party."},"1335":{"id":"/docs/bonus/bitcoin/mempool-14","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool","content":"This guide builds Mempool v3.3.1 from source. The backend\nstores indexed data in MariaDB and serves the API on port 8999. Caddy\nputs the Angular frontend behind HTTPS on port 4080."},"1336":{"id":"/docs/bonus/bitcoin/mempool-15","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#requirements","content":"Electrum server running (Electrs on port 50001)"},"1337":{"id":"/docs/bonus/bitcoin/mempool-16","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#requirements","content":"Node.js 22 installed (from the BTC RPC Explorer guide or standalone via `nodesource.com`)"},"1338":{"id":"/docs/bonus/bitcoin/mempool-17","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#requirements","content":"Caddy installed (from the same guide or standalone via `caddyserver.com`)"},"1339":{"id":"/docs/bonus/bitcoin/mempool-18","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#requirements","content":"\\~5 GB free on the SSD: build artefacts under `/home/mempool/` take 4-5 GB; the MariaDB database starts small but\ngrows to \\~5 GB with full historical address indexing enabled"},"1340":{"id":"/docs/bonus/bitcoin/mempool-19","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#create-the-user","content":"A dedicated system user limits the blast radius of any bug. Adding it\nto the `bitcoin` group lets Mempool authenticate to Bitcoin Core via\nthe cookie file, the same approach BTC RPC Explorer uses."},"1341":{"id":"/docs/bonus/bitcoin/mempool-20","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#install-build-dependencies","content":"Mempool's backend includes a Rust-native block-template builder (GBT).\nDebian 13 Trixie ships Rust 1.85, which meets the 1.84 requirement:"},"1342":{"id":"/docs/bonus/bitcoin/mempool-21","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#set-up-mariadb","content":"Create the database and a dedicated user. Replace `YourPasswordM` with\nyour &#x2A;*password \\[M]** (new, used only for MariaDB here):"},"1343":{"id":"/docs/bonus/bitcoin/mempool-22","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#install-mempool","content":"Clone and check out the release as the `mempool` user:"},"1344":{"id":"/docs/bonus/bitcoin/mempool-23","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#configure-the-backend","content":"Write the config file. Replace `YourPasswordM` with your &#x2A;*password \\[M]**:"},"1345":{"id":"/docs/bonus/bitcoin/mempool-24","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#configure-the-backend","content":"`INDEXING_BLOCKS_AMOUNT: 0` disables historical address indexing on\nfirst run. Once the node is stable, raise it to `4320` (30 days) or\n`11000` (about 3 months) to unlock address balance history in the UI.\nRestart the service after changing it."},"1346":{"id":"/docs/bonus/bitcoin/mempool-25","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#build-the-backend","content":"`npm install` triggers a Rust compilation before installing Node.js packages.\nOn a Pi 5 that takes 5-10 minutes. Run the commands in a `tmux` or\n`screen` session."},"1347":{"id":"/docs/bonus/bitcoin/mempool-26","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#build-the-frontend","content":"Run in the same `tmux` or `screen` session. A dropped SSH connection\nwould abort the build."},"1348":{"id":"/docs/bonus/bitcoin/mempool-27","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#build-the-frontend","content":"The built frontend lands in `~/mempool/frontend/dist/mempool/browser`."},"1349":{"id":"/docs/bonus/bitcoin/mempool-28","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#build-the-frontend","content":"The standard build script compiles all 33 translation locales, which\ntakes several hours on a Pi. The commands above build only the English\nsource locale and produce the same result."},"1350":{"id":"/docs/bonus/bitcoin/mempool-29","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#autostart-on-boot","content":"Back as user `admin`, create the service file:"},"1351":{"id":"/docs/bonus/bitcoin/mempool-30","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#autostart-on-boot","content":"Paste:"},"1352":{"id":"/docs/bonus/bitcoin/mempool-31","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#autostart-on-boot","content":"Enable and start:"},"1353":{"id":"/docs/bonus/bitcoin/mempool-32","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#autostart-on-boot","content":"Wait for a line containing `Listening on http://127.0.0.1:8999/`. On\nfirst start, Mempool syncs its database from Electrs and Bitcoin Core.\nExpect 30-60 minutes before fee charts and address lookups populate\nfully."},"1354":{"id":"/docs/bonus/bitcoin/mempool-33","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#autostart-on-boot","content":"Press `Ctrl`-`C` to stop following the log."},"1355":{"id":"/docs/bonus/bitcoin/mempool-34","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"Add a Mempool block to the Caddyfile (create the file first if Caddy\nwas not already installed from the BTC RPC Explorer guide):"},"1356":{"id":"/docs/bonus/bitcoin/mempool-35","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"Open the Caddyfile:"},"1357":{"id":"/docs/bonus/bitcoin/mempool-36","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"Add the Mempool block after your existing blocks:"},"1358":{"id":"/docs/bonus/bitcoin/mempool-37","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"The `/api/*` block proxies API calls to the backend. Everything\nelse is served as a static file, falling back to `index.html` so\nAngular's client-side routing works for deep links."},"1359":{"id":"/docs/bonus/bitcoin/mempool-38","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"Open the firewall and reload Caddy:"},"1360":{"id":"/docs/bonus/bitcoin/mempool-39","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"Point your browser at `https://raspibolt.local:4080`. Accept the\none-time certificate warning."},"1361":{"id":"/docs/bonus/bitcoin/mempool-40","page_id":"/docs/bonus/bitcoin/mempool","tags":[],"type":"text","url":"/docs/bonus/bitcoin/mempool#https-on-the-lan-with-caddy","content":"**Main takeaway:** you now have a private Bitcoin block explorer and\nmempool visualizer. The node's own Electrs index answers every query."},"1362":{"id":"/docs/bonus/bitcoin/mempool-41","page_id":"/docs/bonus/bitcoin/mempool","tags